#import CountItems.mpat


#new:Script $Script_Interact_Salesman
{
	Call    FindItem   ( .Item:ReturnPipe *Var1 )
	If      *Var1  !=  FFFFFFFF
		Call	SpeakToPlayer ( .Npc:Self 00890104 00890101 00000000 $HelloAgain )
		Return
	EndIf
	Call	DisablePlayerInput ( .True )
	Call	ShowCoinCounter ( .True )
	If  *GF_BoughtReturnPipe == .False
		Call	SpeakToPlayer ( .Npc:Self 00890104 00890101 00000000 $SalesmanIntro )
	Else
		Call	SpeakToPlayer ( .Npc:Self 00890104 00890101 00000000 $SalesmanReplacement )
	EndIf
	% check if player can buy this item
	Call	AddCoin ( 0 )
	If  *GF_BoughtReturnPipe == .False
		Set  *Var2  100`
	Else
		Set  *Var2  500`
	EndIf
	If *Var0 < *Var2 % Not enough money
		Call	ContinueSpeech ( .Npc:Self 00890106 00890101 00000000 $YoureBroke )
		Call	ShowCoinCounter ( .False )
		Call	DisablePlayerInput ( .False )
		Return	
	EndIf
	Call	SetMessageValue ( *VarB 00000000 )
	Call  	ShowChoice    ( 001E000D ) % Yes No
	If *Var0 != .False % No
		Call	ShowCoinCounter ( .False )
		Call   ContinueSpeech ( .Npc:Self 00890107 00890101 00000000 $Goodbye )
		Call	DisablePlayerInput ( .False )
		Return
	EndIf
	Call  $Function_CountItems
	If *Var0 == .False %(Max inventory)
		Call   ContinueSpeech ( .Npc:Self 00890106 00890101 00000000 $TooManyItems )
		Call	ShowCoinCounter ( .False )
		Call	DisablePlayerInput ( .False )
		Return
	EndIf
	If  *GF_BoughtReturnPipe == .False
		Call	AddCoin ( -100` )
	Else
		Call	AddCoin ( -500` )
	EndIf
	ExecWait $Thanks
	Return
	End
}

#new:Script $Thanks
{
		Call  EndSpeech     ( 00000000  00890101 00890101 00000000 )
		Call	ShowCoinCounter ( .False )
		Call  SetNpcAnimation   ( 00000000 00890005 )
		Call	ShowGotItem ( .Item:ReturnPipe .True 00000000 )
		Call  AddItem   ( .Item:ReturnPipe 0 )
		Set   *GF_BoughtReturnPipe .True
		Call  SetNpcAnimation   ( 00000000 00890001 )
		Call	SpeakToPlayer ( .Npc:Self 00890107 00890101 00000000 $ThankYou )
		Call	DisablePlayerInput ( .False )
		Return
		End
}

#new:String $SalesmanIntro
{
[Style Right]
Good day, sir.[BR]
[Pause 10]Might I interest you in a little[BR]
doodad I recently obtained[BR]
during my trip to Flipside?[BR]
[Wait][Next]
It's only 100 Coins.[BR]
Take it or leave it.[BR]
[Yield][End]
}

#new:String $YoureBroke
{
[Next]
What rot.[BR]
You lack the funds, my good man.[BR]
[Wait][End]
}


#new:String $TooManyItems
{
[Next]
What rot.[BR]
You lack the space, good man.[BR]
[Wait][End]
}

#new:String $ThankYou
{
[Style Right]
Pleasure doing business with ye.[BR]
[Pause 20]Alright,[Pause 2] piss off now.[Wait][End]
}

#new:String $Goodbye
{
[Next]
[Pause 20]Alright,[Pause 2] piss off then.[Wait][End]
}

#new:String $SalesmanReplacement
{
[Style Right]
G'day again, sir.[BR]
[Pause 20]What's this? Did you MISPLACE[BR]
your Return Pipe?[BR]
[Wait][Next]
Oh no, this simply won't do.[BR]
That was a relic, boy.[BR]
[Pause 5]Oh well, it can't be helped[BR]
I suppose.[BR]
[Wait][Next]
I did manage to get ahold of[BR]
a spare, however.[BR]
[Pause 15]It's not cheap, mind.[BR]
[Wait][Next]
Replacement fees will be 500[BR]
Coins. Take it or leave it.[BR]
[Yield][End]
}

#new:String $HelloAgain
{
[Style Right]
Hello again, sir.[BR]
[Pause 10]Is that Return Pipe serving[BR]
you well?[BR]
[Wait][Next]
Don't expect it to work [Wave]all[/fx][BR]
the time, however.[BR]
[Pause 8][Wait][Next]
It's saved my butt plenty, but[BR]
at clutch moments, it randomly[BR]
decides to deactivate.[BR]
[Pause 10]Blasted thing...[BR]
[Wait][Next]
Still, it's quite useful.[BR]
[Pause 10]Take good care of it.[Wait][End]
}

