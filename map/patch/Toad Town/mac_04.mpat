@	$Script_Main
{
    0:  Switch  *GB_StoryProgress
			Case  .Story:Ch7_StarSpritDeparted  to  .Story:Ch8_ReachedPeachsCastle
				Exec  $DarknessFollow
   88:  	Default
				Call  EnableGroup   ( ~Model:darkness .False )
   9C:  EndSwitch
    0:  Set   *GB_WorldLocation  .Location:ToadTown
   10:  Call  SetSpriteShading  ( .Shading:None )
   20:  Call  SetCamPerspective ( .Cam:Default 00000003  25`  16`  4096` )
   40:  Call  SetCamBGColor     ( .Cam:Default  0`  0`  0` )
   5C:  Call  SetCamEnabled     ( .Cam:Default .True )
   70:  Call  SetCamLeadPlayer  ( .Cam:Default .False )
   84:  Call  GetEntryID        ( *Var0 )
   94:  If  *Var0  ==  ~Entry:Entry4
   A4:  	Call  MakeNpcs  ( .False $NpcGroupList_8024E824 )
   B8:  Else
   C0:  	Switch  *GB_StoryProgress
   CC:  		Case  <  .Story:Ch3_StarSpritDeparted % FFFFFFF3
   D8:  			Call  MakeNpcs  ( .False $NpcGroupList_8024DC88 )
   EC:  		Case  <  .Story:Ch4_BeganPeachMission % 6
   F8:  			Call  MakeNpcs  ( .False $NpcGroupList_8024DCAC )
  10C:  		Case  ==  .Story:Ch4_BeganPeachMission % 6
  118:  			Call  MakeNpcs  ( .False $NpcGroupList_8024DCD0 )
  12C:  		Case  <  .Story:Ch5_ReturnedToToadTown % 29
  138:  			Call  MakeNpcs  ( .False $NpcGroupList_8024DC88 )
  14C:  		Case  <  .Story:Ch7_BeganPeachMission % 58
  158:  			Call  MakeNpcs  ( .False $NpcGroupList_8024DCF4 )
  16C:  		Default
  174:  			Call  MakeNpcs  ( .False $NpcGroupList_8024DC88 )
  188:  	EndSwitch
  190:  EndIf
  198:  Set   *AreaFlag[031]  .False
  1A8:  ExecWait  $Script_MakeEntities
  1B4:  Exec  $Script_80242E88
  1C0:  Exec  $Script_80243B24
  1CC:  Exec  $Script_80243D9C
  1D8:  ExecWait  $Script_80246C58
  1E4:  If  *GB_StoryProgress  ==  .Story:Ch4_BeganPeachMission % 6
  1F4:  	Call  SetMusicTrack ( 00000000 .Song:StarSpiritTheme 00000001 00000008 )
  210:  Else
  218:  	Exec  $Script_802420C0
  224:  EndIf
  22C:  Exec  $Script_EnterWalk_80242280
  238:  Call  GetEntryID    ( *Var0 )
  248:  If  *Var0  ==  ~Entry:Entry5
  258:  	Wait  65`
  264:  Else
  26C:  	Wait  1`
  278:  EndIf
  280:  Set   *GF_MAC01_RowfBadgesChosen  .False
  290:  Return
  298:  End
}

