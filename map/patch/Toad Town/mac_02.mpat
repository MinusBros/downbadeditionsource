%Scrapped this cuz it kept killing the sound effects permanently
#new:Script  $PipeMusicCheck
{
		Wait  24`
		Label  A
		Wait  1`
		Call  GetPlayerPos  ( *Var1 *Var2 *Var3 )
		If  *Var1  <  -217`
			If  *Var3  >  157`
				Call  FadeInMusic   ( 00000001 .Song:ShyGuyInvasion 1` 4000` 0` 108` )
				Wait  1`
				Goto  14
			EndIf
		EndIf
		Goto  A
		Label  14
		Wait  1`
		Call  GetPlayerPos  ( *Var1 *Var2 *Var3 )
		If  *Var1  >= -217`
			Call  FadeOutMusic  ( 00000001 00000708 )
			Wait  1`
			Goto  A
		EndIf
		If  *Var3  <= 157`
			Call  FadeOutMusic  ( 00000001 00000708 )
			Wait  1`
			Goto  A
		EndIf
		Goto  14	
		Return
		End
}

