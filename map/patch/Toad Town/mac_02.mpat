				EndIf
			Case  .Story:Ch7_StarSpritDeparted  to  .Story:Ch8_ReachedPeachsCastle
				Call  SetMusicTrack ( 00000000 .Song:PeachWishes 00000000 00000008 ) % New song for dark Kinoko Town
   38:  	Default
   40:  		Exec  $Script_8024E150
   4C:  EndSwitch
		Call $ClearFlagCarryOverworldMusicToBattle()
		Set *Var0 .True
		Set     *Byte_Settings_BGM *Var0
   54:  Return
   5C:  End
}


#new:Script  $CheckOddKey
{
	If  *GF_MAC02_Item_OddKey == .True
		Return
	EndIf
	Label  A
	If  *GF_MAC02_Item_OddKey == .True
		Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
		If  *Var0  >  -400`
			Call  DisablePlayerInput        ( .True )
			Wait  64`
			Call  PlaySoundAtNpc    ( .NpcID:Toad_05 00000262 00000000 )
			Call  ShowEmote ( .NpcID:Toad_05 .Emote:Exclamation  -30`  20` .True  0`  0`  0`  0` )
			Wait  25`
			Call  SetNpcAnimation   ( .NpcID:Toad_05 00830102 )
			Call  NpcMoveTo ( .NpcID:Toad_05 -365` -221` 10` )
			Call  SetNpcAnimation   ( .NpcID:Toad_05 00830101 )
			If    *OddKeyCount < 2`
				Call  SpeakToPlayer ( .NpcID:Toad_05 00830108 00830101 00000000 000400A2 )
				Set   *GF_MAC02_Item_OddKey .False
				Call  FindKeyItem   ( .Item:OddKey *Var0 )
				Call  RemoveKeyItemAt ( *Var0 )			
			Else
				Call  SpeakToPlayer ( .NpcID:Toad_05 00830108 00830101 00000000 000400B2 )
				Set   *GF_MAC02_Item_OddKey .False
				Call  FindKeyItem   ( .Item:OddKey *Var0 )
				Call  RemoveKeyItemAt ( *Var0 )			
				Call  PlaySound ( 00000371 )
				Call  SetPlayerAnimation    ( 00010022 )
				Wait  36`
				Call  PlaySound ( 000003FB )
				Call  SetPlayerAnimation    ( 00010003 )
				Wait  60`
				Call  GotoMap   ( "gv_01" 00000003 )
				Return
			EndIf	
			Call  PushSong ( .Song:BattleEnd 00000002 ) 
			Wait  3`
			Call  ShowMessageAtScreenPos    ( 000400A3  160`  40` ) %Key left :(
			Call  PopSong ( )
			Wait  5`
			Call  FindKeyItem   ( .Item:OddKey *Var0 )
			Call  RemoveKeyItemAt ( *Var0 )	
			Add   *OddKeyCount 1`
			Call  DisablePlayerInput        ( .False )
		EndIf
		Return
	EndIf
	Wait   1`
	Goto   A
	Return
	End
}


