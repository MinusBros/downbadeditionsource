@	$Script_Interact_8024C618
{
		If  *GB_StoryProgress  >=  .Story:Ch3_StarSpritDeparted
			If  *NagitoadCompleted == .False
				Call  PushSong ( .Song:Fail 1` )	%Danganronpa theme, sketchy scuffed edition
				If   *NagitoadAskedForHopeFragments == .False
					Set *NagitoadAskedForHopeFragments .True
					Call  SpeakToPlayer ( .NpcID:Toad_08 00650505 00650501 00000000 000400A5 )
					Call  PopSong ( )
					Return
				Else
					Set   *Var6  7`   %Starts at 7. Each Hope Fragment flag removes 1 from the total
					If  *MAC00_HopeFragment == .True
						Sub  *Var6 1`
						Call  SetMessageString   ( 000400B1 0` )
					Else
						Call  SetMessageString   ( 000400A7 0` )
					EndIf
					If  *MAC01_HopeFragment == .True
						Sub  *Var6 1`
						Call  SetMessageString   ( 000400B1 1` )
					Else
						Call  SetMessageString   ( 000400A8 1` )
					EndIf
					If  *MAC02_HopeFragment == .True
						Sub  *Var6 1`
						Call  SetMessageString   ( 000400B1 2` )
					Else
						Call  SetMessageString   ( 000400A9 2` )
					EndIf
					If  *MAC03_HopeFragment == .True
						Sub  *Var6 1`
						Call  SetMessageString   ( 000400B1 3` )
					Else
						Call  SetMessageString   ( 000400AA 3` )
					EndIf
					If  *MAC04_HopeFragment == .True
						Sub  *Var6 1`
						Call  SetMessageString   ( 000400B1 4` )
					Else
						Call  SetMessageString   ( 000400AB 4` )
					EndIf
					If  *MAC05_HopeFragment == .True
						Sub  *Var6 1`
						Call  SetMessageString   ( 000400B1 5` )
					Else
						Call  SetMessageString   ( 000400AC 5` )
					EndIf
					If  *MAC07_HopeFragment == .True
						Sub  *Var6 1`
						Call  SetMessageString   ( 000400B1 7` )
					Else
						Call  SetMessageString   ( 000400AD 7` )
					EndIf
					Call  SetMessageValue   ( *Var6 6` )
					If  *Var6  > 0`
						Call  SpeakToPlayer ( .NpcID:Toad_08 00650505 00650501 00000000 000400A6 )
						Call  SpeakToPlayer ( .NpcID:Toad_08 00650504 00650501 00000000 000400AE )
						Call  SpeakToPlayer ( .NpcID:Toad_08 00650505 00650501 00000000 000400B0 )
					Else
						Set  *NagitoadCompleted .True
						Call  SpeakToPlayer ( .NpcID:Toad_08 00650504 00650501 00000000 000400AF )
			   10:  	Set   *Var0  000000F1
			   20:  	Set   *Var1  00000002
			   30:  	Call  ShowGotItem   ( *Var0 .True 00000000 )
			   3C:  	Call  AddBadge  ( .Item:PrettyLucky *Var0 )
						ExecWait  $ProblemSolved
					EndIf
				EndIf
				Call  PopSong ( )
				Return
			EndIf
		EndIf

		Call  RandInt   ( 1` *Var2 )
		If    *Var2 == 0`
			Set  *Var1 00650504
		Else
			Set  *Var1 00650505
		EndIf
