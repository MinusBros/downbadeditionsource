#new:Script  $NagitoadProblem
{
		Loop
			Call  ShowEmote ( .NpcID:Toad_08 .Emote:Frustration  1`  60` .True  0`  0`  0`  0` )
			Wait  60`
			If  *NagitoadCompleted == .True
				BreakLoop
			EndIf
		EndLoop
		Return
		End
}


