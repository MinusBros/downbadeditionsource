%Power Smash has been moved to Prologue.
%If you can make it past Blooper, you
%can get a copy of Defend Plus, but only 
%if you've grabbed Shrink Stomp first.

@	$Script_80241B34
{
		If    *GF_TIK02_Chest_ShrinkStomp == .False
			Set   *VarA  .Item:ShrinkStomp % 12F
		Else
			Set   *VarA  .Item:DefendPlusX
		EndIf
   10:  Set   *VarB  00000002
   20:  Set   *GF_TIK05_Chest_PowerSmash1  .True
   30:  ExecWait  $Script_8024186C
   3C:  Return
   44:  End
}