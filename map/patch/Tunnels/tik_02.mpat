%If Shrink Stomp has been grabbed, make this Defend Plus

@	$Script_8024120C
{
		If    *GF_TIK05_Chest_PowerSmash1 == .False
			Set   *VarA  .Item:ShrinkStomp % 12F
		Else
			Set   *VarA  .Item:DefendPlusX
		EndIf
		Set   *VarB  00000002
   20:  Set   *GF_TIK02_Chest_ShrinkStomp  .True
   30:  ExecWait  $Script_8024112C
   3C:  Return
   44:  End
}

@	$Script_8024112C
{
    0:  Call  DisablePlayerInput    ( .True )
   10:  Set   *Var0  *VarA
   20:  If  *VarA  !=  00000000
   30:  	ExecWait  $Script_802410C4
   3C:  EndIf
   44:  Switch  *VarB
   50:  	Case  ==  00000000
   5C:  		Call  AddItem   ( *VarA *Var0 )
   70:  	Case  ==  00000001
   7C:  		Call  AddKeyItem    ( *VarA )
   8C:  	Case  ==  00000002
   98:  		Call  AddBadge  ( *VarA *Var0 )
   AC:  EndSwitch
   B4:  Wait  15`
		Exec $AutoSave
   C0:  Call  DisablePlayerInput    ( .False )
   D0:  Return
   D8:  End
}