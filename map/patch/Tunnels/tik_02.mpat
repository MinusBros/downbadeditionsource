#import AutoSave.mpat

#new:Script $KillPlane
{
    0:  Label  0
    C:  Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
   24:  Wait  1`
   30:  If  *Var0  <  -250`
   40:  	Goto  0
   4C:  EndIf
   30:  If  *Var0  >  55`
   40:  	Goto  0
   4C:  EndIf
		Wait  1`
		Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
   C8:  If  *Var1  >  -63`
   D8:  	Goto  0
   E4:  EndIf
		Wait  1`
		Call  802CA988      ( 00000000 *Var2 *Var3 *Var4 *Var5 )
		Call  DisablePlayerInput    ( .True )
		Call  DisablePartnerAI      ( 00000000 )
		Call  SetPlayerAnimation    ( 00080013 )
		Call  FadeOutMusic      ( 00000000 00000024 )
		Wait  10`
		Wait  80`
   EC:  Call  GotoMap   ( "gv_01" 00000000 ) 
  100:  Wait  100`
  10C:  Return
  114:  End
}

