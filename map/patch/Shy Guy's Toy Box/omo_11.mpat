#import AutoSave.mpat

@	$Script_MakeEntities
{
   [98]  Call  MakeEntity        ( .Entity:HiddenYellowBlock ~Vec4d:Entity80242520 .Item:HotShroom 80000000 )
  [108]  Call  MakeEntity        ( .Entity:YellowBlock ~Vec4d:Entity80242590 .Item:StarPoint 80000000 )
  [178]  Call  MakeEntity        ( .Entity:YellowBlock ~Vec4d:Entity80242600 .Item:StarPoint 80000000 )
}


@	$Script_80241530
{
    0:  Call  SetMusicTrack ( 00000000 .Song:ShyGuyToybox 00000000 00000008 )
   			Thread
				Wait  25`
				Call  802D5FA4  ( 00000007 )
			EndThread
   1C:  Return
   24:  End
}


@	$AISettings_80242650
