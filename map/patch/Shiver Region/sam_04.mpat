				Exec  $Script_SetupTexturePan
				Call  $Function_SetupFog
				Call  EnableModel   ( ~Model:darkness .True )
				Exec  $CheckPos
				Exec  $AutoSave 
				Wait  1`
			EndIf
		EndIf
  30C:  Return
  314:  End
}



@	$Script_Init_802442F0
{
   14:  Call  BindNpcIdle       ( .Npc:Self $Script_Idle_802440E4 )
