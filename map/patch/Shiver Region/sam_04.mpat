  200:  Bind  $Script_ShakeTree_80240CE4 .Trigger:PointBomb $TriggerCoord_80241670 00000001 00000000
  21C:  Set   *Var0  $ShakeTreeEvent_Tree4
  22C:  Bind  $Script_ShakeTree_80240CE4 .Trigger:WallHammer ~Collider:miki4 00000001 00000000
  248:  Bind  $Script_ShakeTree_80240CE4 .Trigger:PointBomb $TriggerCoord_802416A4 00000001 00000000
  264:  Set   *Var0  $ShakeTreeEvent_Tree5
  274:  Bind  $Script_ShakeTree_80240CE4 .Trigger:WallHammer ~Collider:miki5 00000001 00000000
  290:  Bind  $Script_ShakeTree_80240CE4 .Trigger:PointBomb $TriggerCoord_802416D8 00000001 00000000
  2AC:  Set   *Var0  $ShakeTreeEvent_Tree6
  2BC:  Bind  $Script_ShakeTree_80240CE4 .Trigger:WallHammer ~Collider:miki6 00000001 00000000
  2D8:  Bind  $Script_ShakeTree_80240CE4 .Trigger:PointBomb $TriggerCoord_8024170C 00000001 00000000
  2F4:  Exec  $Script_EnterWalk_80240928
    0:  Call  GetEntryID    ( *Var0 )
   10:  If  *Var0  >  ~Entry:Entry3
			Exec	$Script_802408C4
		EndIf
  300:  Wait  1`
		If    *GF_SAM04_CodyDefeated == .False
			If    *GB_StoryProgress  ==  .Story:Ch7_GotSnowmanBucket
				Wait  1`
				
				Call  FadeOutMusic  ( 00000000 000001F4 )
				Call  PlayAmbientSounds ( .AmbientSounds:Wind )
