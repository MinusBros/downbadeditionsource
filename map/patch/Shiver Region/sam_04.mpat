#new:Script $Script_SetupTexturePan
{
	Call     802C9000 	( ~Model:ki1 0 )
	Call     802C9000 	( ~Model:ki3 0 )
	Call     802C9000 	( ~Model:ki4 0 )
	Call     802C9000 	( ~Model:ki5 0 )
	Call     802C9000 	( ~Model:ki6 0 )
	Call     802C9000 	( ~Model:miki1 0 )
	Call     802C9000 	( ~Model:miki3 0 )
	Call     802C9000 	( ~Model:miki4 0 )
	Call     802C9000 	( ~Model:mili5 0 )
	Call     802C9000 	( ~Model:miki2 0 )
	Call     802C9000 	( ~Model:miki6 0 )
	Call     802C9000 	( ~Model:ki2_3 0 )
	Call     802C9000 	( ~Model:ki2_2 0 )
	Call     802C9000 	( ~Model:ki2_1 0 )
	Thread
		Set  *Var[0] 0
		Set  *Var[1] 14A
		Set  *Var[2] 0
		Set  *Var[3] 123
		Set  *Var[4] 0
		Set  *Var[5] 1
		Set  *Var[6] 0
		Set  *Var[7] 1
		Set  *Var[8] 0
		Set  *Var[9] 0
		Set  *Var[A] 0
		Set  *Var[B] 0
		Set  *Var[C] 0
		Exec $Script_TexturePan_Update
	EndThread
	Return
	End
}

#new:Function $Function_SetupFog
{
	PUSH RA
	JAL       8011BB50
	NOP
	ADDIU     A0, R0, 3B6
	JAL       8011BB74
	ADDIU     A1, R0, 3D4
	ADDIU     A0, R0, 0
	ADDIU     A1, R0, 0
	ADDIU     A2, R0, A
	JAL       8011BB88
	ADDIU     A3, R0, FF
	ADDIU     V0, R0, 2
	JPOP RA
}

