#new:Script $Script_Init_Cody
{
		Call  BindNpcIdle   ( .Npc:Self $Script_Cody_Idle )
		Call  BindNpcDefeat     ( .Npc:Self $Script_Cody_Defeat )
		Call  SetNpcPos ( .Npc:Self 0` 0` -115` )
   C0:  Return
   C8:  End
}

#new:Script  $CheckPos
{
		Loop
   1C:  Call  GetPlayerPos  ( *Var0 *Var1 *Var2 ) 
		If  *Var0  >  -100`
			If *Var0 <  100`
				If  *Var2  <  23`
				   Call  DisablePlayerInput    ( .True )
				   Call  SpeakToPlayer     ( .Npc:Cody 00560502 00560501 00000000 00120182 )
				   Wait  5`
				   Set   *GF_SAM04_CodyDefeated  .True
				   Call  SetNpcVar ( .Npc:Cody 00000000 00000001 )
	   50:  	   Return
				EndIf
			EndIf
		EndIf
		Call  NpcFacePlayer ( .Npc:Cody 00000004 )
		Wait  1`
		EndLoop
		Return
		End
}

#new:Script  $Script_Cody_Idle
{
    0:  Loop
    C:  	Call  GetSelfVar    ( 00000000 *Var0 )
   20:  	If  *Var0  !=  00000000
   30:  		BreakLoop
   38:  	EndIf
   40:  	Wait  1`
   4C:  EndLoop
   54:  Call  DisablePlayerInput    ( .True )
   64:  Wait  10`
   70:  Call  GetNpcPos      ( .Npc:Cody *Var0 *Var1 *Var2 )
   88:  Call  UseSettingsFrom   ( .Cam:Default *Var0 *Var1 *Var2 )
   A4:  Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )
   C0:  Call  SetCamDistance    ( .Cam:Default  400` )
   D4:  Call  SetCamPitch       ( .Cam:Default *Fixed[17.0] *Fixed[-6.0] )
   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[4.0] )
  100:  Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
  118:  Call  DisablePlayerInput    ( .False )
		Call  StartBossBattle   ( .Song:Kazuya )	
		Return
		End
}

#new:Script  $Script_Cody_Defeat
{
	Thread
		Call  ResetCam      ( .Cam:Default *Fixed[4.0] )
		Wait  60`
		Call  ClearAmbientSounds    ( 000000FA )
		Call  GotoMap   ( "sam_04" 00000005 )
		Exec  $Script_802408C4
	EndThread
	Wait  1`
	Call  DoNpcDefeat ( )
	Return
	End
}


