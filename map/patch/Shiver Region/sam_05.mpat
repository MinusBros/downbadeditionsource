  114:  Call  ModifyColliderFlags   ( 00000003 ~Collider:ground 00000008 )
  12C:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o55 00000008 )
  144:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o59 00000008 )
  15C:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o60 00000008 )
  174:  Call  ModifyColliderFlags   ( 00000003 ~Collider:deilie 00000008 )
  18C:  Call  ModifyColliderFlags   ( 00000003 ~Collider:deiliw 00000008 )
    0:  Call  GetLoadType   ( *Var1 )
   10:  If  *Var1  ==  00000001
   20:  	Exec  EnterSavePoint
   2C:  	Exec  $Script_80241E88
   38:  	Return
   40:  EndIf
  1A4:  Set   *Var0  $Script_80241E88	
  1B4:  Exec  EnterWalk
  1C0:  Wait  1`
  1CC:  Return
  1D4:  End
}


