#new:Function $Function_SwapToGoombarius
{
    0:  ADDIU     SP, SP, FFE8
    4:  SW        RA, 10 (SP)
    8:  LW        V0, C (A0)
    C:  JAL       ~Func:get_variable
   10:  LW        A1, 0 (V0)
   14:  JAL       ~Func:switch_to_partner
   18:  COPY      A0, V0
   1C:  LW        RA, 10 (SP)
   20:  LI        V0, 2
   24:  JR        RA
   28:  ADDIU     SP, SP, 18
}

@ $Script_Main_EnterWalk
{
    0:  Set   *GB_WorldLocation  .Location:ShiverCity
   10:  Call  SetSpriteShading  ( .Shading:mim_01 )
   20:  Call  SetCamPerspective ( .Cam:Default 00000003 00000019 00000010 00001000 )
   40:  Call  SetCamBGColor     ( .Cam:Default 00000000 00000000 00000000 )
   5C:  Call  SetCamEnabled     ( .Cam:Default .True )
   70:  Call  SetCamLeadPlayer  ( .Cam:Default .False )
   84:  Switch  *GB_StoryProgress
   90:  	Case  <  .Story:Ch7_MayorMurderMystery % 3F
   9C:  		Call  MakeNpcs  ( .False $NpcGroupList_8024A178 )
   B0:  	Case  <  .Story:Ch7_MayorMurderSolved % 43
   BC:  		Call  MakeNpcs  ( .False $NpcGroupList_8024A1B4 )
   D0:  	Case  >=  .Story:Ch7_MayorMurderSolved % 43
   DC:  		Call  MakeNpcs  ( .False $NpcGroupList_8024A1F0 )
   F0:  EndSwitch
		If  *GB_StoryProgress  == .Story:Ch7_GotSnowmanScarf
				Set   *AreaFlag[008] .True
		EndIf
   F8:  ExecWait  $Script_MakeEntities
  104:  ExecWait  $Script_80241FB0
  110:  Exec  $Script_80242174
  11C:  ExecWait  $Script_802431BC
  128:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o341 00000008 )
  140:  Call  ModifyColliderFlags   ( 00000003 ~Collider:f_noki 00000008 )
  158:  Call  ModifyColliderFlags   ( 00000003 ~Collider:m_noki 00000008 )
  170:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o398 00000018 )
  188:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o399 00000008 )
  1A0:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o402 00000018 )
  1B8:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o408 00000008 )
  1D0:  Call  ModifyColliderFlags   ( 00000003 ~Collider:o409 00000008 )
  1E8:  Call  ModifyColliderFlags   ( 00000003 ~Collider:deilie 00000008 )
  200:  Set   *Var0  $Script_80242148
  210:  Exec  EnterWalk
  21C:  Wait  1`
  228:  Exec  $Script_802423E8
  234:  Return
  23C:  End
}

%I decided to give Lucky Day to Mayor Penguin so that
%you can still get it in Chapter 7, but not required
%to do the letter sidequest.

#new:Script $Script_802455D4
{
    0:  Call  ShowGotItem   ( *Var0 .True 00000000 )
   18:  Return
   20:  Return
   28:  End
}

#new:Script $Script_AddLuckyDay
{
    0:  If  *VarC  ==  00000002
   10:  	Set   *Var0  00000114
   20:  	Set   *Var1  00000002
   30:  	ExecWait  $Script_802455D4
   3C:  	Call  AddBadge  ( .Item:LuckyDay *Var0 )
   50:  EndIf
   58:  Return
   60:  End
}

@	$Script_Interact_8024672C
{
  [244]  		Wait  10`
  [348]  		Wait  2`
  [628]  ExecWait  $Script_AddLuckyDay
}


