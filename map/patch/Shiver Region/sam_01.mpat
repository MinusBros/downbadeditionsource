%Thought this thing from Dark Star was fooni, so add it for no reason
%Spawn Cody when the conditions are right

%Appear when...
%	Exit a building
%	Enter the map with the right story progress

%Disappear when...
%	Mario enters the room that you use to access the attack fx badge
%	

%*AreaFlag[008] is now the Cody visibility flag

#new:NpcGroup $NpcGroup_Cody
{
	00000010 $NpcSettings_802436D0 ~Vec3f:NPC_Cody % -272 0 -180
	00400C09 $Script_Init_Cody 00000000 00000000 0000010E
	~NoDrops
	~Movement:NPC_Cody
	~AnimationTable:NPC_Cody
	00000000 00000000 00000000 $PermaTattle
}

@	$NpcGroupList_8024A1F0
{
	00000009 $NpcGroup_80248468 00000001
	00000001 $NpcGroup_80249F88 00000000
	00000001 $NpcGroup_Cody     00000000
	00000000 00000000 00000000
}

#new:Script $Script_Init_Cody
{
   14:  Call  BindNpcIdle       ( .Npc:Self $Script_Idle_Cody )
		Call  BindNpcInteract       ( .Npc:Self $Script_Interact_Cody )
		Call  BindNpcIdle       ( .Npc:Self $Script_Idle_Cody )
		Call  BindNpcDefeat       ( .Npc:Self $Script_Defeat )
   8C:  Return
   94:  End
}

#new:Script $Script_Idle_Cody
{
	Label 0
	Wait 1
	If  *GB_StoryProgress < .Story:Ch7_GotSnowmanScarf
		Set *AreaFlag[008] .False
	EndIf
	If  *GB_StoryProgress  >=  .Story:Ch7_GotSnowmanBucket % 43
		Set *AreaFlag[008] .False
	EndIf
	If *AreaFlag[008] == .True
		If *MapFlag[9] == .True
			Return	%get rid of this script afterwards
		Else
			Call  SetNpcPos ( .Npc:Self -2` 107` -79` )
		EndIf
	Else
		Call  SetNpcPos ( .Npc:Self 00000000 FFFFFC18 00000000 )
	EndIf
	Goto 0
	Return
	End
}

#new:Script $Script_Interact_Cody
{
	Call	 DisablePlayerInput ( .True )
	Call	 DisablePlayerInput ( .False )
	Set 	 *MapFlag[9]	.True
	Return
	End
}


#new:Script $Script_Defeat
{
	Return
	End
}



