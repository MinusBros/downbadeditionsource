#new:Script $GoombariusInteraction2
{
				Call  GetCurrentPartnerID   ( *Var0 )
				If  *Var0  ==  .Partner:Goombario % 2
						Wait  4`
						Call  DisablePartnerAI  ( 00000000 )
						Call  SpeakToPlayer    ( .Npc:Partner 0001000F 0001000E 00000005 00120014 ) % 
						Call  SpeakToPlayer ( .Npc:Self 00CF0004 00CF0001 00000000 00120015 )
						Call  SpeakToPlayer    ( .Npc:Partner 00010008 00010001 00000005 00120016 ) % 
						Call  EnablePartnerAI ( )
				EndIf	
				Return
				End
}

