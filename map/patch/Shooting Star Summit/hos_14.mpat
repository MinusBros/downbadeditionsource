#new:Script  $Script_Init_Bandit
{
	Call  BindNpcInteract   ( .Npc:Self $Script_Interact_Bandit )
		If  *GB_StoryProgress  >=  .Story:Ch2_StarSpiritRescued
			If   *PhantomCompleted == .False
				Exec  $BanditProblem
			EndIf
		EndIf
	Return
	End
}

#new:Script  $Script_Interact_Bandit
{
		If  *GB_StoryProgress  >=  .Story:Ch2_StarSpritDeparted
			If  *PhantomCompleted == .False
				Call  FindKeyItem   ( .Item:GoldWhackaBump *Var1 )
				If    *Var1 != FFFFFFFF
					Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest5 ) 
					Set   *Var0  $???_CheckGoldenBump
					Set   *Var1  00000005
					ExecWait  $Script_CheckForKeyItem	
					Switch *Var0
						Case   == 0`   %If you don't have the key item, resume script
						Case   == FFFFFFFF  %If you refuse to give the key item, say a funny line
							Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest6 ) 
							Return
						Default			%If you give him the key item
							Set  *PhantomCompleted .True
							Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest7 ) 
							Call	ShowCoinCounter ( .True )
							Wait    12`
							Call	AddCoin ( 1000` )
							Call	ShowCoinCounter ( .False )
							Wait    28`
							ExecWait  $ProblemSolved
							Return
					EndSwitch
				EndIf
				If  *GB_IWA00_Whacka_HitCount == 8`  %This dialogue only plays if you killed Whankha, but didn't grab the bump
					Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest8 ) 
					Return
				EndIf
				If  *PhantomAskedForDefeatedWhacka == .False
					Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest1 ) 
					Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest2 ) 
					Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest3 ) 
					Set  *PhantomAskedForDefeatedWhacka .True
				Else
					Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 $BanditQuest4 ) 
				EndIf
				Return
			EndIf
		EndIf


		
		Switch  *GB_StoryProgress
			Case  <  .Story:Ch2_StarSpritDeparted
				Set   *Var0  $Bandit1
			Case  <  .Story:Ch6_StarSpiritRescued
				Set   *Var0  $Bandit2
		Case  >=  .Story:Ch6_StarSpiritRescued
				Set   *Var0  $Bandit3
		EndSwitch
		Call  SpeakToPlayer ( .Npc:Self 009C020E 009C0201 00000000 *Var0 ) % variable string ID
		Return
		End
}


#new:Script  $BanditProblem
{
		Loop
			Call  ShowEmote ( .Npc:Bandit .Emote:Frustration  1`  60` .True  0`  0`  0`  0` )
			Wait  60`
			If  *PhantomCompleted == .True
				BreakLoop
			EndIf
		EndLoop
		Return
		End
}

