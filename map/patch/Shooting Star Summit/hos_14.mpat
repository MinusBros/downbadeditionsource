#new:Script_Main $Script_Main
{
	Set   *GB_WorldLocation  .Location:ShootingStarSummit
	Call  SetSpriteShading   ( .Shading:hos_01 )
	Call  MakeNpcs  ( .False $NpcGroupList_LoveHotel )
	Call  SetCamPerspective  ( .Cam:Default 00000003 00000019 00000010 00001000 )
	Call  SetCamBGColor      ( .Cam:Default 00000000 00000000 00000000 )
	Call  SetCamEnabled      ( .Cam:Default .True
	Call  SetCamLeadPlayer   ( .Cam:Default .False )
	Exec  $Script_MakeEntities
	Exec  $Script_SetupMusic
	Exec  $Script_SetupTexturePan
	Set   *Var0  $Script_CreateExitTriggers 	
	Exec	EnterWalk 
	Return
	End
}

#new:Script $Script_MakeEntities
{
		Switch  *GB_StoryProgress
			Case  <  .Story:Ch1_ReturnedToToadTown
				Call  MakeEntity    ( .Entity:YellowBlock ~Vec4d:Block1 .Item:Mushroom 80000000 )
			Case  <  .Story:Ch5_ReturnedToToadTown
				Call  MakeEntity    ( .Entity:YellowBlock ~Vec4d:Block1 .Item:SuperShroom 80000000 )
		Case  >=  .Story:Ch5_ReturnedToToadTown
				Call  MakeEntity    ( .Entity:YellowBlock ~Vec4d:Block1 .Item:UltraShroom 80000000 )
		EndSwitch	
	Call  AssignBlockFlag   ( *HOS14_Block1 )
		Switch  *GB_StoryProgress
			Case  <  .Story:Ch1_ReturnedToToadTown
				Call  MakeEntity    ( .Entity:YellowBlock ~Vec4d:Block2 .Item:HoneySyrup 80000000 )
			Case  <  .Story:Ch5_ReturnedToToadTown
				Call  MakeEntity    ( .Entity:YellowBlock ~Vec4d:Block2 .Item:MapleSyrup 80000000 )
		Case  >=  .Story:Ch5_ReturnedToToadTown
				Call  MakeEntity    ( .Entity:YellowBlock ~Vec4d:Block2 .Item:JamminJelly 80000000 )
		EndSwitch	
	Call  AssignBlockFlag   ( *HOS14_Block2 )
	Call  MakeItemEntity    ( .Item:HeartPiece ~Vec3d:Coin1 .ItemSpawnMode:Fixed_NeverVanish *HOS14_BlueCoin1 )
	Call  MakeItemEntity    ( .Item:HeartPiece ~Vec3d:Coin2 .ItemSpawnMode:Fixed_NeverVanish *HOS14_BlueCoin2 )
	Call  MakeItemEntity    ( .Item:HeartPiece ~Vec3d:Coin3 .ItemSpawnMode:Fixed_NeverVanish *HOS14_BlueCoin3 )
	Call  MakeEntity    ( .Entity:HiddenPanel ~Vec4d:HiddenPanel ~Model:stage 80000000 )
	Call  AssignPanelFlag   ( *HOS14_HiddenPanel )
	Call  MakeEntity    ( .Entity:Signpost ~Vec4d:Sign 80000000 )
	Call  AssignScript    ( $Script_ReadSign_Sign )
	Return
	End
}

