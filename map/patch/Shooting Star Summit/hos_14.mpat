#new:Script $Script_ExitS
{
	SetGroup 0000001B 
	Call     UseExitHeading ( 60` 0 )
	Exec     ExitWalk 
	Call     GotoMap     	( "hos_07" 4 )
	Wait     80`
	Return
	End
}


