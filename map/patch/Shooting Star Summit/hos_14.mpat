#new:Script $Script_Init_Koopa
{
    Call  BindNpcInteract   ( .Npc:Self $Script_Interact_Koopa )
    Return
    End
}

#new:Script  $Script_Interact_Koopa
{
		Switch  *GB_StoryProgress
			Case  <  .Story:Ch2_StarSpritDeparted
				Set   *Var0  $Koopa1
				Set   *Var1  $Goomba1
				Set   *Var2  $Koopa4
			Case  <  .Story:Ch6_StarSpiritRescued
				Set   *Var0  $Koopa2
				Set   *Var1  $Goomba2
				Set   *Var2  $Koopa5
		Case  >=  .Story:Ch6_StarSpiritRescued
				Set   *Var0  $Koopa3
				Set   *Var1  $Goomba3
				Set   *Var2  $Koopa6
		EndSwitch
		Call  SpeakToPlayer ( .Npc:Self 008F0207 008F0202 00000000 *Var0 ) % variable string ID
		Call  SpeakToPlayer ( .Npc:Goomba 0026010F 00260101 00000000 *Var1 ) % variable string ID
		Call  SpeakToPlayer ( .Npc:Self 008F0207 008F0202 00000000 *Var2 ) % variable string ID
		Return
		End
}

