#new:Script $Script_CreateExitTriggers
{
	Bind     $Script_ExitS  .Trigger:FloorAbove ~Collider:exit0 00000001 00000000 
	Bind     $Script_ExitN  .Trigger:FloorAbove ~Collider:exit1 00000001 00000000 
	Return
	End
}


#new:Script $Script_ExitS
{
	SetGroup 0000001B 
	Call     UseExitHeading ( 60` 0 )
	Exec     ExitWalk 
	Call     GotoMap     	( "hos_07" 4 )
	Wait     80`
	Return
	End
}


#new:Script $Script_ExitN
{
	SetGroup 0000001B 
	Call     UseExitHeading ( 60` 1 )
	Exec     ExitWalk 
	Call     GotoMap     	( "hos_16" 0 )
	Wait     80`
	Return
	End
}

#new:Script $Script_ReadSign_Sign
{
	Call  DisablePlayerInput        ( .True )
	Call  ShowMessageAtScreenPos    ( $String_ReadSign_Sign 000000A0 00000028 )
	Call  DisablePlayerInput        ( .False )
	Return
	End
}

#new:String $String_ReadSign_Sign
{
	[DelayOff][STYLE:SIGN]
	[CenterX:FF]
	[Down:03]Welcome to the Love Hotel.[BR]
	Please enjoy your stay.[BR]
	[DelayOn][WAIT][END]
}

