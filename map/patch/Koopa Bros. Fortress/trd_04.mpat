  15C:  	Call  TranslateModel    ( ~Model:k_dan 00000000 000000BB 00000000 )
  178:  	Call  TranslateModel    ( ~Model:k_kusari 00000000 000000BB 00000000 )
  194:  	Call  UpdateColliderTransform   ( ~Collider:o86 )
  1A4:  	Call  UpdateColliderTransform   ( ~Collider:o87 )
  1B4:  	Bind  $Script_80244120 .Trigger:AreaFlagSet *AreaFlag[004] 00000001 00000000
  1D0:  EndIf
  1D8:  Exec  $Script_80244938
  1E4:  Call  ModifyColliderFlags   ( 00000000 ~Collider:ttw 7FFFFE00 )
  1FC:  Call  EnableModel   ( ~Model:o34 .False )
  210:  Call  EnableModel   ( ~Model:dai .False )
  224:  Call  ModifyColliderFlags   ( 00000000 ~Collider:dai 7FFFFE00 )
  23C:  Exec  $Script_EnterDoubleDoor_80243F04
  248:  Wait  1`
  254:  Call  EnableTexPanning      ( ~Model:suimen .True )
		Exec  $Script_PartnerBlurb
  268:  Thread
