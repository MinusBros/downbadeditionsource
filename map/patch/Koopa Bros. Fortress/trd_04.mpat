}



#new:Script  $Script_PartnerBlurb
{
			Label  0
			Wait  1`
			Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
			If  *Var1  > -25`
				Goto  0
			EndIf
			Call  RandInt   ( 00000002 *Var6 )
			If    *Var6 == 0`
				Return
			EndIf
			If    *GB_StoryProgress == .Story:Ch1_LoweredFirstStairs
				Call  GetCurrentPartnerID   ( *Var0 )
				Switch  *Var0
					Case  ==  .Partner:Goombario % 1
						Call  SetPlayerFlagBits ( 000000C0 .True )
						Call  SpeakToPlayer ( .Npc:Partner FFFFFFFF FFFFFFFF 00000005 000C0144 ) 
						Wait  80`
						Call  SetPlayerFlagBits ( 000000C0 .False )
					Case  ==  .Partner:Kooper % 2
						Call  SpeakToPlayer ( .Npc:Partner FFFFFFFF FFFFFFFF 00000005 000C0145 ) % 
				EndSwitch
			EndIf
			Return
			End
}
