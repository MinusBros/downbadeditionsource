   70:  Call  SetCamEnabled     ( .Cam:Default .True )
   84:  Call  SetRenderMode     ( ~Model:suimen 00000016 )
   98:  If  *GB_StoryProgress  <  .Story:Ch1_LoweredFirstStairs % FFFFFFAA
