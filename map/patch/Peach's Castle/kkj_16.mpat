   AC:  Exec  ExitSingleDoor
   B8:  Wait  17`
		If  *GB_StoryProgress  ==  .Story:PostGame
			Call  GotoMap   ( "kkj_01" 00000002 )
		Else
			Call  GotoMap   ( $ASCII_80244808 00000002 ) % kkj_11
		EndIf
   D8:  Wait  100`
   E4:  Return
   EC:  End
}