@	$Script_Main
{
    0:  Set   *GB_WorldLocation  .Location:PeachsCastle
   10:  Call  SetSpriteShading  ( .Shading:kkj_26 )
   20:  Call  SetCamPerspective ( .Cam:Default 00000003  25`  16`  4096` )
   40:  Call  SetCamBGColor     ( .Cam:Default  0`  0`  0` )
   5C:  Call  SetCamEnabled     ( .Cam:Default .True )
   70:  Call  GetEntryID        ( *Var0 )
   80:  If  *Var0  ==  ~Entry:Entry1
   90:  	Set   *GB_StoryProgress  .Story:Ch7_BeganPeachMission
   A0:  EndIf
   A8:  Call  UseDoorSounds ( 00000005 )
   B8:  Call  GetDemoState  ( *Var0 )
   C8:  If  *Var0  !=  00000000
   D8:  	ExecWait  $Script_80240B78
   E4:  	Return
   EC:  EndIf
   F4:  Exec  $Script_802401F0
		If  *GB_StoryProgress  >=  .Story:Ch8_ReachedBowsersCastle
			Exec  $Script_CheckPos
		EndIf
  100:  Wait  1`
  10C:  Return
  114:  End
}


#new:Script $Script_CheckPos
{
	Label 1
	Wait  1`
	Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
	If *Var1  < -30`
		Call  DisablePlayerInput    ( .True )
		Call  DisablePartnerAI      ( 00000000 )
		Call  SetPlayerAnimation    ( 00080013 )
		Call  FadeOutMusic      ( 00000000 00000034 )
		Call  802CA988      ( 00000000 *Var2 *Var3 *Var4 *Var5 )
		Wait  80`
		Call  GotoMap       ( "gv_01" 00000000 )
		Wait  100`
		Return
	EndIf
	Goto  1
	Return
	End
}


%Prologue Peach scene
@	$Script_802403E0
{
  [174]  Wait  30`
  [198]  Wait  20`
  [1B4]  Wait  5`
}



