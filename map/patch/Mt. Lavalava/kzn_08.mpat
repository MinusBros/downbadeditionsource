%Swap Dizzy Stomp with a second Group Focus.
%If a player grabs the Group Focus in Dry Dry Outpost,
%it deletes the one from Rowf's shop.

@	$Script_80244CFC
{
    [0]  Set   *VarA  .Item:GroupFocus
}

%Buff the plant

@	$AISettings_80244F40
{
    0.0 % move speed
    10` % move time
    10` % wait time
  300.0 % alert radius
    0.0
    1`
    0.0 % chase speed
    0`
    0`
    0.0 % chase radius
    0.0
    0`
}