  4BC:  	Loop
  4C8:  		Call  ScaleModel    ( ~Model:o1286 *Fixed[1.02] 00000001 *Fixed[1.02] )
  4E4:  		Call  ScaleModel    ( ~Model:o1287 *Fixed[1.02] 00000001 *Fixed[1.02] )
  500:  		Call  ScaleModel    ( ~Model:o1289 *Fixed[1.02] 00000001 *Fixed[1.02] )
  51C:  		Call  ScaleModel    ( ~Model:o1290 *Fixed[1.02] 00000001 *Fixed[1.02] )
  538:  		Wait  10`
  544:  		Call  ScaleModel    ( ~Model:o1286 *Fixed[1.0] 00000001 *Fixed[1.0] )
