%Starting now, the second song of Bowser's Castle will play.


#define .Npc:RedCody           00
#define .Npc:GreenCody            01

@	$Script_Main
{
    0:  Set   *GB_WorldLocation  .Location:BowsersCastle
   10:  Call  SetSpriteShading  ( .Shading:tik_23 )
		If    *CodyBrothersDefeated == .False
			Call  MakeNpcs  ( .False $NpcGroupList_Cody )
		EndIf		
   20:  Call  SetCamPerspective ( .Cam:Default 00000003  25`  16`  4096` )
   40:  Call  SetCamBGColor     ( .Cam:Default  0`  0`  0` )
   5C:  Call  SetCamLeadPlayer  ( .Cam:Default .False )
   70:  Call  SetCamEnabled     ( .Cam:Default .True )
   84:  ExecWait  $Script_MakeEntities
   90:  Exec  $Script_EnterDoubleDoor_802407A4
   9C:  Wait  1`
		Exec  $Script_CheckPos
   A8:  Exec  $Script_80240390
   B4:  Call  EnableTexPanning  ( ~Model:o1286 .True )
   C8:  Call  EnableTexPanning  ( ~Model:o1287 .True )
   DC:  Call  EnableTexPanning  ( ~Model:o1289 .True )
   F0:  Call  EnableTexPanning  ( ~Model:o1290 .True )
  104:  Thread
  10C:  	Set   *Var0  00000001
  11C:  	Set   *Var1  00000014
  12C:  	Set   *Var2  00000014
