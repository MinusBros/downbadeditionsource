#new:Script $Script_CheckPos
{
	Label 1
	Wait  1`
	Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
	If *Var1  < -70`
		Call  DisablePlayerInput    ( .True )
		Call  DisablePartnerAI      ( 00000000 )
		Call  SetPlayerAnimation    ( 00080013 )
		Call  FadeOutMusic      ( 00000000 00000034 )
		Call  802CA988      ( 00000000 *Var2 *Var3 *Var4 *Var5 )
		Wait  80`
		Call  GotoMap       ( "gv_01" 00000000 )
		Wait  100`
		Return
	EndIf
	Goto  1
	Return
	End
}

@	$Script_80240390
{
    [0]  Call  SetMusicTrack ( 00000000 .Song:BowsersCastleCaves 00000000 00000008 )
   [34]  	Wait  20`
}




#new:Script $Script_Init_RedCody
{
		If  *CodyBrothersDefeated == .True
			Call  SetNpcPos ( .Npc:Self 0` -1000` 0` )
			Return
		EndIf
		Call  BindNpcIdle   ( .Npc:Self $Script_RedCody_Idle )
		Exec  $CheckPos
   C0:  Return
   C8:  End
}

#new:Script $Script_Init_GreenCody
{
		If  *CodyBrothersDefeated == .True
			Call  SetNpcPos ( .Npc:Self 0` -1000` 0` )
			Return
		EndIf
		Call  BindNpcIdle   ( .Npc:Self $Script_GreenCody_Idle )
   C0:  Return
   C8:  End
}

#new:Script  $CheckPos
{
		Loop
   1C:  Call  GetPlayerPos  ( *Var0 *Var1 *Var2 ) 
		If  *Var2  <  -260`
				   Call  DisablePlayerInput    ( .True )
				   Wait  25`		   
				   Call  SpeakToPlayer     ( .Npc:RedCody 00560102 00560101 00000000 001300D3 )
				   Wait  5`
				   Call  SpeakToPlayer     ( .Npc:GreenCody 00570402 00570401 00000000 001300D4 )
				   Call  SetNpcVar ( .Npc:RedCody 00000000 00000001 )
	   50:  	   Return
				EndIf
		Call  NpcFacePlayer ( .Npc:RedCody 00000004 )
		Call  NpcFacePlayer ( .Npc:GreenCody 00000004 )
		Wait  1`
		EndLoop
		Return
		End
}


#new:Script  $Script_RedCody_Idle
{
    0:  Loop
    C:  	Call  GetSelfVar    ( 00000000 *Var0 )
   20:  	If  *Var0  !=  00000000
   30:  		BreakLoop
   38:  	EndIf
   40:  	Wait  1`
   4C:  EndLoop
		Call  SetNpcFlagBits    ( .Npc:RedCody 00000100 .True )
		
   64:  Wait  10`
   70:  Call  GetNpcPos      ( .Npc:RedCody *Var0 *Var1 *Var2 )
   88:  Call  UseSettingsFrom   ( .Cam:Default *Var0 *Var1 *Var2 )
   A4:  Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )
   C0:  Call  SetCamDistance    ( .Cam:Default  500` )
   D4:  Call  SetCamPitch       ( .Cam:Default *Fixed[17.0] *Fixed[-6.0] )
   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[4.0] )
  100:  Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
		Call  ResetCam      ( .Cam:Default *Fixed[4.0] )
		Call  $SetFlagCarryOverworldMusicToBattle()
		Wait  1`
		Call  DisablePlayerInput    ( .False )
		Set   *CodyBrothersDefeated .True 	
		Call  SetMusicTrack ( 00000000 .Song:Epsilon 00000000 00000008 )
		Call  StartBossBattle   ( .Song:Epsilon )	
		Return
		End
}



#new:Script  $Script_GreenCody_Idle
{
    0:  Loop
			If  *CodyBrothersDefeated == .True	
				BreakLoop
			EndIf
   40:  	Wait  1`
   4C:  EndLoop
		Wait  5`
		Thread
			Call  SetNpcFlagBits    ( .Npc:Self 00000010 .False )
			Wait  28`		
			Call  SetNpcPos ( .Npc:Self 0` -1000` 0` )
			Call  SetMusicTrack ( 00000000 .Song:BowsersCastleCaves 00000000 00000008 )
		EndThread
		Wait  5`
		Call  DoNpcDefeat ( )
		Return
		End
}

