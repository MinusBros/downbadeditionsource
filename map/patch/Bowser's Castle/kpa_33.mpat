  1F8:  	Set   *Var0  00000002
  208:  	Set   *Var1  00000014
  218:  	Set   *Var2  00000014
  228:  	Set   *Var3  FFFFFFEC
  238:  	Set   *Var4  FFFFFFEC
  248:  	Set   *Var5  00000001
  258:  	Set   *Var6  00000001
  268:  	Set   *Var7  00000001
  278:  	Set   *Var8  00000001
  288:  	Set   *Var9  00000000
  298:  	Set   *VarA  00000000
  2A8:  	Set   *VarB  00000000
  2B8:  	Set   *VarC  00000000
  2C8:  	Exec  $Script_UpdateTexturePan_80240440
  2D4:  EndThread
  2DC:  Thread
  2E4:  	Set   *Var0  00000003
  2F4:  	Set   *Var1  00000014
  304:  	Set   *Var2  00000014
  314:  	Set   *Var3  FFFFFFEC
  324:  	Set   *Var4  FFFFFFEC
  334:  	Set   *Var5  00000001
  344:  	Set   *Var6  00000001
  354:  	Set   *Var7  00000001
  364:  	Set   *Var8  00000001
  374:  	Set   *Var9  00000000
  384:  	Set   *VarA  00000000
  394:  	Set   *VarB  00000000
  3A4:  	Set   *VarC  00000000
  3B4:  	Exec  $Script_UpdateTexturePan_80240440
  3C0:  EndThread
  3C8:  Thread
  3D0:  	Set   *Var0  00000004
  3E0:  	Set   *Var1  00000014
  3F0:  	Set   *Var2  00000014
  400:  	Set   *Var3  FFFFFFEC
  410:  	Set   *Var4  FFFFFFEC
