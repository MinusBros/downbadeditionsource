	.Npc:RedCody $NpcSettings_Cody ~Vec3f:RedCody
	00000C01 $Script_Init_RedCody 00000000 00000000 0000005F
	~NoDrops
	~Movement:RedCody
	~AnimationTable:RedCody
	00000000 00000000 00000000 00000000 % no tattle string
	%%%%%%%%%%%%
}


