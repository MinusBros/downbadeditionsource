
#new:Header $Header
{
00000000 00000000 00000000 00000000 
$Script_Main $EntryList 00000002 00000000 
00000000 00000000 00000000 00000000 
00000000 00000000 80200000 $Function_GetTattle 
}

#new:Function $Function_GetTattle
{
	ADDIU     SP, SP, FFE8
	LIO       V0, $MapTattle
	JR        RA
	ADDIU     SP, SP, 18
}

#string $MapTattle
{
[Style Tattle]
[EnableCDownNext]This is where we fought [SaveColor][Color:04]Xin Suì[RestoreColor] and[BR]
that [SaveColor][Color:09]stinky priest[RestoreColor].[BR]
[Pause 10]Though,[Pause 2] I guess we did find out he[BR]
was being mind-controlled.[BR]
[Wait][Next]
I'm petty when it comes to grudges.[BR]
Sue me.[BR]
[Wait][Next]
There's not really much to see here,[BR]
[Pause 2][PrintRising]but hey,[/fx][Pause 2] at least it's peaceful.[BR]
[Pause 10]A nice spot to bring a [Wave]cute little[BR]
lady[/fx] actually.[BR]
[Wait][Next][BR]

Wish I had one already.[BR]
[Wait][End]
}

#new:Function_Init $Function_Init
{
	PUSH	RA
	/%
	% Override map geometry
	LIA       A0, 800D9230
	LIA       A1, "XXX_shape"
	JAL       {Func:StringPrintf}
	RESERVED
	% Override map collision
	LIA       A0, 800D91E0
	LIA       A1, "XXX_hit"
	JAL       {Func:StringPrintf}
	RESERVED
	%/
	% Override texture package
	LIA		A0, 800B0CF0
	LIA		A1, "kpa_tex"
	JAL		~Func:sprintf
	RESERVED
	% Done
	DADDU	V0, R0, R0
	JPOP	RA
}

#new:EntryList $EntryList
{
~Vec4f:Entry0
~Vec4f:Entry1
}

#define .Disastar *GameByte[061]

#new:Script_Main $Script_Main
{
	Set     *GB_WorldLocation  .Location:PeachCastleGrounds %Yokubou no Naizou
	Call  SetSpriteShading  ( .Shading:None )
	Call     SetCamPerspective	( .Cam:Default  3  25` 16` 4096` ) % default type, half vertical FOV, near clip, and far clip
	Call     SetCamBGColor   	( .Cam:Default  0  0  0 ) % color values are RGB bytes; (0,0,0) is black, (255`,255`,255`) is white, etc.
	Call     SetCamEnabled 	 	( .Cam:Default  .True )   % Enabled?
	Call     MakeNpcs           ( 00000001 $NpcGroupList_Disastar)
	Call	GetLoadType 	( *Var[1] )
	If		*Var[1] ==  00000001 
		Exec	EnterSavePoint 
		Exec	$Script_MakeExits
	Else
		Call  GetEntryID        ( *Var0 )
		If  *Var0  ==  ~Entry:Entry1
			Exec  $XinSuiDefeat
			Exec	$Script_MakeExits
		Else
			Call  FadeOutMusic      ( 00000000 000005DC )
			Call  PlayAmbientSounds ( .AmbientSounds:Birds )
			Set		*Var[0] $Script_MakeExits 
			Exec	EnterWalk
		EndIf 
	EndIf
	Return
	End
}

	

#string $PriestDead
{
[Style Right]
[Wait][End]
}




#new:Script $PriestInit
{
	Return
	End
}



#new:Script  $XinSuiDefeat
{
	Call  DisablePlayerInput    ( .True )
	Call  DisablePartnerAI  ( 00000000 )
	Call  InterpPlayerYaw   (  90`  0` )
	Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
	Call  InterpNpcYaw  ( .Npc:Partner  90`  1` )
	Sub   *Var0 40`
	Add   *Var1 20`
	Call  SetNpcPos ( .Npc:Partner  *Var0  *Var1 *Var2 )
	Call  SetNpcPos ( .Npc:Priest  276`  -1110`  -560` )
	Call  SetNpcAnimation   ( .Npc:Priest 00870416 )
	Set  *GF_DNJ29_Disastar  00000001 
	Set  *MapFlag[0] .False 
	Call  FadeOutMusic      ( 00000000 000005DC )
	Wait  45`
		  2E4:  Call  GetCurrentPartnerID   ( *Var0 )
		  2F4:  Switch  *Var0
		  300:  	Case  ==  .Partner:Goombario
		  30C:  		Call  SpeakToPlayer ( .Npc:Partner 0001000C 0001000B 00000005 $GoombariusQuip ) % 
		  32C:  	Case  ==  .Partner:Kooper
		  338:  		Call  SpeakToPlayer ( .Npc:Partner 0002000F 00020002 00000005 $KooperQuip ) % 
		  358:  	Case  ==  .Partner:Bombette
		  364:  		Call  SpeakToPlayer ( .Npc:Partner 0003000D 00030013 00000005 $BombetteQuip ) % 
		  384:  	Case  ==  .Partner:Parakarry
		  390:  		Call  SpeakToPlayer ( .Npc:Partner 00040006 00040001 00000005 $ParakariusQuip ) % 
		  300:  	Case  ==  .Partner:Bow
		  30C:  		Call  SpeakToPlayer ( .Npc:Partner 00050004 00050001 00000005 $BowQuip ) % 
		  32C:  	Case  ==  .Partner:Watt
		  338:  		Call  SpeakToPlayer ( .Npc:Partner 00060006 00060001 00000005 $WattageQuip ) % 
		  358:  	Case  ==  .Partner:Sushie
		  364:  		Call  SpeakToPlayer ( .Npc:Partner 00070004 00070001 00000005 $SushieQuip ) % 
		  384:  	Case  ==  .Partner:Lakilester
		  390:  		Call  SpeakToPlayer ( .Npc:Partner 00080009 0008000E 00000005 $JonathanQuip ) % 
		  3B0:  EndSwitch	
	Wait  15`
	Call  SpeakToPlayer ( .Npc:Shisho FFFFFFFF FFFFFFFF 00000000 $Shisho1 )
	Call  SetMusicTrack ( 00000000 .Song:MasterBattle 00000001 00000008 )  %Sad variant
	Call  SetNpcPos ( .Npc:Shisho  200`  110`  -530` )
	Call  SetNpcPos ( .Npc:Chan  240`  110`  -530` )
	Call  SetNpcPos ( .Npc:Lee  280`  110`  -530` )
	Wait  5`
				Call  SetCamType    ( .Cam:Default 00000001 .False )
				Call  UseSettingsFrom   ( .Cam:Default  240`  110`  -530` )
				Call  SetPanTarget      ( .Cam:Default 240`  110`  -530` )	
				Call  SetCamDistance    ( .Cam:Default 390` )	
				Call  SetCamSpeed   ( .Cam:Default *Fixed[90.0] )	
				Call  PanToTarget       ( .Cam:Default 00000000 00000001 )				
				Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )	
		Thread
			Wait  4`
			Call  SetPanTarget      ( .Cam:Default -5` 130`  -602` )
			Call  SetCamSpeed       ( .Cam:Default *Fixed[0.9] )
			Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
			Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )
		EndThread	
	Call  SetNpcSpeed   ( .Npc:Shisho *Fixed[4.0] )
	Call  SetNpcSpeed   ( .Npc:Chan *Fixed[3.5] )
	Call  SetNpcSpeed   ( .Npc:Lee *Fixed[3.5] )
	Call  SetNpcJumpscale   ( .Npc:Shisho *Fixed[1.0] )
	Call  SetNpcJumpscale   ( .Npc:Chan *Fixed[1.2] )
	Call  SetNpcJumpscale   ( .Npc:Lee *Fixed[1.6] )
	Call  SetNpcAnimation   ( .Npc:Shisho 00A20005 )
	Call  SetNpcAnimation   ( .Npc:Chan 00A30003 )
	Call  SetNpcAnimation   ( .Npc:Lee 00A40003 )
    Thread
		Call  NpcMoveTo ( .Npc:Shisho  193` -577`  0` )
		Call  SetNpcAnimation   ( .Npc:Shisho 00A20010 )
		Call  NpcJump1  ( .Npc:Shisho  152`  140`  -602` 10` )
		Call  SetNpcAnimation   ( .Npc:Shisho 00A20005 )
		Call  NpcMoveTo ( .Npc:Shisho  40`  -602`  0` )
		Call  SetNpcAnimation   ( .Npc:Shisho 00A20002 )
	EndThread
    Thread
		Call  NpcMoveTo ( .Npc:Chan  193` -577`  0` )
		Call  SetNpcAnimation   ( .Npc:Chan 00A30004 )
		Call  NpcJump1  ( .Npc:Chan  152`  140` -602` 8` )
		Call  SetNpcAnimation   ( .Npc:Chan 00A30003 )
		Call  NpcMoveTo ( .Npc:Chan  64`  -629`  0` )
		Call  SetNpcAnimation   ( .Npc:Chan 00A30001 )
	EndThread
	Call  NpcMoveTo ( .Npc:Lee  193` -577`  0` )
	Call  SetNpcAnimation   ( .Npc:Lee 00A40005 )
	Wait  4`
	Call  NpcJump1  ( .Npc:Lee  152`  140` -602` 15` )
	Call  SetNpcAnimation   ( .Npc:Lee 00A40008 )
	Wait  3`
	Call  SetNpcAnimation   ( .Npc:Lee 00A40003 )
	Call  NpcMoveTo ( .Npc:Lee  82` -602`  0` )
	Call  SetNpcAnimation   ( .Npc:Lee 00A40002 )
	Wait  20`
	Call  SpeakToPlayer ( .Npc:Shisho 00A20046 00A20002 00000000 $Shisho2 )
	Call  SpeakToPlayer ( .Npc:Partner FFFFFFFF FFFFFFFF 00000005 $PartnerQuip )
	Call  SpeakToPlayer ( .Npc:Chan 00A30004 00A30001 00000000 $Chan1 )
	Call  SpeakToPlayer ( .Npc:Lee 00A40006 00A40002 00000000 $Lee1 )
	Call  SpeakToPlayer ( .Npc:Shisho 00A20009 00A20002 00000000 $Shisho3 )
	Call  SpeakToPlayer ( .Npc:Shisho 00A20009 00A20002 00000000 $Shisho4 )
	Call  SpeakToNpc    ( .Npc:Chan 00A30004 00A30001 00000000 .Npc:Shisho $Chan2 )
	Call  SpeakToNpc    ( .Npc:Lee 00A40006 00A40002 00000000 .Npc:Shisho $Lee2 )
	Call  SpeakToPlayer ( .Npc:Shisho 00A20009 00A20002 00000000 $Shisho5 )	
	Call  SetNpcPos ( .Npc:Priest  276`  110`  -560` )
	Thread
		Wait 3`
		Call  InterpNpcYaw  ( .Npc:Chan  90`  10` )
	EndThread
	Thread
		Wait 3`
		Call  InterpNpcYaw  ( .Npc:Lee  90`  10` )
	EndThread
	Call  InterpNpcYaw  ( .Npc:Shisho  90`  8` )
	ExecWait  $PosCamMush
	Call  SpeakToNpc    ( .Npc:Shisho 00A20046 00A20049 00000000 .Npc:Priest $Shisho6 )		 %He is my grandson
	ExecWait  $PosCamShisho
	Thread
		Wait 3`
		Call  InterpNpcYaw  ( .Npc:Chan  270`  10` )
	EndThread
	Thread
		Wait 3`
		Call  InterpNpcYaw  ( .Npc:Lee  270`  10` )
	EndThread
	Call  SpeakToPlayer ( .Npc:Shisho 00A20046 00A20049 00000000 $Shisho7 )	
	Call  SetPlayerAnimation 	( 0001002D )
	Wait  25`
	Call  SetPlayerAnimation 	( 00010002 )
	Call  SpeakToPlayer ( .Npc:Chan 00A30004 00A30001 00000000 $Chan3 )
	Call  SpeakToPlayer ( .Npc:Lee 00A40006 00A40002 00000000 $Lee3 )
	ExecWait  $PosCamMush
	Call  SpeakToPlayer ( .Npc:Priest FFFFFFFF FFFFFFFF 00000000 $Mush )	
	Call  SetNpcSpeed   ( .Npc:Shisho *Fixed[7.0] )
	Call  SetNpcAnimation   ( .Npc:Shisho 00A20005 )
	Call  NpcMoveTo ( .Npc:Shisho  184` -583`  0` )
	Call  NpcJump1  ( .Npc:Shisho  224`  110`  -583` 5` )
	Call  SetNpcAnimation   ( .Npc:Shisho 00A20002 )
	Call  SpeakToNpc    ( .Npc:Shisho 00A20009 00A20002 00000000 .Npc:Priest $Shisho8 )
		Thread
			Wait  4`
			Call  SetPanTarget      ( .Cam:Default -10` 140`  -602` )
			Call  SetCamSpeed       ( .Cam:Default *Fixed[1.0] )
			Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
			Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )
		EndThread	
		Call  NpcMoveTo ( .Npc:Shisho  193` -577`  0` )
		Call  SetNpcAnimation   ( .Npc:Shisho 00A20010 )
		Call  NpcJump1  ( .Npc:Shisho  152`  140`  -602` 10` )
		Call  SetNpcAnimation   ( .Npc:Shisho 00A20005 )
		Call  NpcMoveTo ( .Npc:Shisho  40`  -602`  0` )
		Call  SetNpcAnimation   ( .Npc:Shisho 00A20002 )
	Exec  $PosCamShisho
	Wait  5`
	Call  SpeakToPlayer ( .Npc:Shisho 00A20009 00A20002 00000000 $Shisho9 )	
	Set  *GF_DNJ29_Disastar .True
	Set  *ChangeEndofChapter .True
  AC8:  Call  SetCamDistance    ( .Cam:Default  900` )
  ADC:  Call  SetCamPitch   ( .Cam:Default  30`  -7` )
  B0C:  Call  SetCamSpeed   ( .Cam:Default *Fixed[0.6] )
  B20:  Call  PanToTarget   ( .Cam:Default 00000000 00000001 )
  B38:  Wait  95`
		Call  FadeOutMusic      ( 00000000 000005DC )
  B44:  Call  $Function_80240F40 ( )
  B50:  Wait  45`
    Call  GotoMapSpecial    ( "kmr_23" 00000000 5 )
	Wait  100`
	Return
	End
}

#new:Script $Script_Init_Disastar
{
     Call     BindNpcIdle 		( .Npc:Self $Script_IdleAI )
     Return
     End
}
 
#new:Script $Script_IdleAI
{
	Return
	End
}


#new:Script  $PosCamMush
{
				Call  GetNpcPos ( .Npc:Priest *Var0 *Var1 *Var2 )
				Sub   *Var1 12`
				Call  UseSettingsFrom   ( .Cam:Default  *Var0 *Var1 *Var2 )
				Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )	
				Call  SetCamDistance    ( .Cam:Default 200` )	
				Call  SetCamSpeed   ( .Cam:Default *Fixed[1.25] )	
				Call  PanToTarget       ( .Cam:Default 00000000 00000001 )				
				Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )	
				Return
				End
}

#new:Script   $PosCamShisho
{
				Call  GetNpcPos ( .Npc:Shisho *Var0 *Var1 *Var2 )
				Sub   *Var0  30`
				Call  UseSettingsFrom   ( .Cam:Default  *Var0 *Var1 *Var2 )
				Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )	
				Call  SetCamDistance    ( .Cam:Default 400` )	
				Call  SetCamSpeed   ( .Cam:Default *Fixed[1.6] )	
				Call  PanToTarget       ( .Cam:Default 00000000 00000001 )				
				Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )	
				Return
				End
}
 
 

