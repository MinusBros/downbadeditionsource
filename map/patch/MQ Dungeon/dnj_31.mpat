
#new:Header $Header
{
00000000 00000000 00000000 00000000 
$Script_Main $EntryList 00000001 00000000 
00000000 00000000 00000000 00000000 
00000000 00000000 80200000 $Function_GetTattle 
}

#new:Function $Function_GetTattle
{
	ADDIU     SP, SP, FFE8
	LIO       V0, $MapTattle
	JR        RA
	ADDIU     SP, SP, 18
}

#string $MapTattle
{
[Style Tattle]
[EnableCDownNext]Welp, we've finally made it to the[BR]
very bottom.[BR]
Boy, I totally deserve a reward[BR]
for the heck I went through.[BR]
[Wait][Next]
[Wave]A nice lady, perhaps?[/fx][BR]
[Pause 10][PrintRising]No,[/fx] how about a crepe with some[BR]
Royal Jelly spread?[BR]
[Wait][Next]
[SizeWave]Mmmmmm,[/fx] on second thought...[BR]
[Pause 8]Save the crepe for after I[BR]
get laid.[BR]
[Pause 8]Aftercare is important.[BR]
[Wait][End]
}

#new:Function_Init $Function_Init
{
	PUSH	RA
	/%
	% Override map geometry
	LIA       A0, 800D9230
	LIA       A1, "XXX_shape"
	JAL       {Func:StringPrintf}
	RESERVED
	% Override map collision
	LIA       A0, 800D91E0
	LIA       A1, "XXX_hit"
	JAL       {Func:StringPrintf}
	RESERVED
	%/
	% Override texture package
	LIA		A0, 800B0CF0
	LIA		A1, "kpa_tex"
	JAL		~Func:sprintf
	RESERVED
	% Done
	DADDU	V0, R0, R0
	JPOP	RA
}

#new:EntryList $EntryList
{
~Vec4f:Entry0 %  coordinates
}

#define .Disastar *GameByte[061]

#new:Script_Main $Script_Main
{
	Set     *GB_WorldLocation  .Location:PeachCastleGrounds %Yokubou no Naizou
	Call  SetSpriteShading  ( .Shading:mim_07 )
	Call     SetCamPerspective	( .Cam:Default  3  25` 16` 4096` ) % default type, half vertical FOV, near clip, and far clip
	Call     SetCamBGColor   	( .Cam:Default  0  0  0 ) % color values are RGB bytes; (0,0,0) is black, (255`,255`,255`) is white, etc.
	Call     SetCamEnabled 	 	( .Cam:Default  .True )   % Enabled?
	If  	 *GF_DNJ29_Disastar == .False
		Call     SetMusicTrack ( 00000000 .Song:BowsersCastleFalls 00000000 00000008 )
	Else
		Call     SetMusicTrack    	( 00000000 .Song:Alone 00000000 00000008 )
	EndIf
	Call     MakeNpcs           ( 00000001 $NpcGroupList_Disastar)
	Call	GetLoadType 	( *Var[1] )
	If		*Var[1] ==  00000001 
		Exec	EnterSavePoint 
		Exec	$Script_MakeExits
	Else
		Call  GetEntryID        ( *Var0 )
		If  *Var0  ==  ~Entry:Entry0
			Exec  $XinSuiDefeat
		Else
			Set		*Var[0] $Script_MakeExits 
			Exec	EnterWalk
		EndIf
	Set		*Var[0] $Script_MakeExits 
	EndIf
	Return
	End
}

	

#string $PriestMatte
{
[Style Right]
[PrintRising][Size 24]Stop! [BR]
[Pause 10]Do not touch that eye!
[Wait][End]
}




#new:Script $PriestInit
{
	Call  BindNpcIdle   ( .Npc:Self $PriestIdle )
	Return
	End
}



#new:Script  $PriestIdle
{
    0:  Loop
    C:  	Call  GetSelfVar    ( 00000000 *Var0 )
   20:  	If  *Var0  !=  00000000
   30:  		BreakLoop
   38:  	EndIf
   40:  	Wait  1`
   4C:  EndLoop
		Thread
	   70:  Call  GetNpcPos      ( .Npc:Priest *Var0 *Var1 *Var2 )
	   88:  Call  UseSettingsFrom   ( .Cam:Default *Var0 *Var1 *Var2 )
	   A4:  Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )
	   C0:  Call  SetCamDistance    ( .Cam:Default  500` )
	   D4:  Call  SetCamPitch       ( .Cam:Default *Fixed[17.0] *Fixed[-6.0] )
	   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[4.0] )
	  100:  Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
		EndThread
		Call  DisablePlayerInput    ( .False )
		Call  SetMusicTrack ( 00000000 .Song:Deadline 00000000 00000008 )
		Call  StartBossBattle   ( .Song:Deadline )
		Wait  2`
		Return
		End
}


#new:Script  $XinSuiDefeat
{
	
	Return
	End
}

#new:Script $Script_Init_Disastar
{
		Call     BindNpcIdle 		( .Npc:Self $Script_IdleAI )
		Call     BindNpcDefeat 	( .Npc:Self $Script_XinSuiDefeat )
		Call     BindNpcInteract	( .Npc:Self $Script_Interact )
     Return
     End
}
 
#new:Script $Script_IdleAI
{
	Loop
		If  *MapFlag[0]  ==  .True 
		 	Call     StartBossBattle 	( .Song:SunTowerSunny )
		EndIf
		Wait     00000001 
	EndLoop
	Return
	End
}
 
 
#new:Script $Script_XinSuiDefeat
{
		Call     DisablePlayerInput	( .False )
		Call     EnablePartnerAI 	( )
		Set  *GF_DNJ29_Disastar  00000001 
		Set  *MapFlag[0] .False 
		Set      .Disastar 	00000000
   Return
   End 
}

#new:NpcGroupList $NpcGroupList_Disastar
{
00000001 $NpcGroup_Disastar 3D000000 
00000001 $Priest			3D020000 
00000000 00000000 00000000
}
   
#new:NpcGroup $NpcGroup_Disastar
{
0000000A $BlankSettings ~Vec3f:disastar % 1260 0 -40
00A40D01 $Script_Init_Disastar 00000000 00000000 00000000 
~NoItems ~NoHP ~NoFP ~NoCoinBonus
~Movement:disastar
00950001 00950002 00950003 00950003 00950001 00950001 00950000 00950000 
00950001 00950002 00950003 00950003 00950001 00950001 00950000 00950000
00000000 00000000 00000000 001A0122 % he has a tattle now!
}



#define .Npc:Priest       B

#new:NpcGroup $Priest
{
	.Npc:Priest $NpcSettings_Priest ~Vec3f:Priest
	00840505 $PriestInit 00000000 00000000 180`
	~NoItems ~NoHP ~NoFP ~NoCoinBonus
	~Movement:Priest
	~AnimationTable:Priest
	00000000 00000000 00000000 00000000 
}


