
#new:Header $Header
{
00000000 00000000 00000000 00000000 
$Script_Main $EntryList 00000001 00000000 
00000000 00000000 00000000 00000000 
00000000 00000000 80200000 $Function_GetTattle 
}

#new:Function $Function_GetTattle
{
	ADDIU     SP, SP, FFE8
	LIO       V0, $MapTattle
	JR        RA
	ADDIU     SP, SP, 18
}

#string $MapTattle
{
[Style Tattle]
[EnableCDownNext]Welp, we've finally made it to the[BR]
very bottom.[BR]
Boy, I totally deserve a reward[BR]
for the heck I went through.[BR]
[Wait][Next]
[Wave]A nice lady, perhaps?[/fx][BR]
[Pause 10][PrintRising]No,[/fx] how about a crepe with some[BR]
Royal Jelly spread?[BR]
[Wait][Next]
[SizeWave]Mmmmmm,[/fx] on second thought...[BR]
[Pause 8]Save the crepe for after I[BR]
get laid.[BR]
[Pause 8]Aftercare is important.[BR]
[Wait][End]
}

#new:Function_Init $Function_Init
{
	PUSH	RA
	/%
	% Override map geometry
	LIA       A0, 800D9230
	LIA       A1, "XXX_shape"
	JAL       {Func:StringPrintf}
	RESERVED
	% Override map collision
	LIA       A0, 800D91E0
	LIA       A1, "XXX_hit"
	JAL       {Func:StringPrintf}
	RESERVED
	%/
	% Override texture package
	LIA		A0, 800B0CF0
	LIA		A1, "kpa_tex"
	JAL		~Func:sprintf
	RESERVED
	% Done
	DADDU	V0, R0, R0
	JPOP	RA
}

#new:EntryList $EntryList
{
~Vec4f:Entry0 %  coordinates
}

#define .Disastar *GameByte[061]

#new:Script_Main $Script_Main
{
	Set     *GB_WorldLocation  .Location:PeachCastleGrounds %Yokubou no Naizou
	Call  SetSpriteShading  ( .Shading:mim_07 )
	Call     SetCamPerspective	( .Cam:Default  3  25` 16` 4096` ) % default type, half vertical FOV, near clip, and far clip
	Call     SetCamBGColor   	( .Cam:Default  0  0  0 ) % color values are RGB bytes; (0,0,0) is black, (255`,255`,255`) is white, etc.
	Call     SetCamEnabled 	 	( .Cam:Default  .True )   % Enabled?
	If  	 *GF_DNJ29_Disastar == .False
		Call     SetMusicTrack ( 00000000 .Song:BowsersCastleFalls 00000000 00000008 )
	Else
		Call     SetMusicTrack    	( 00000000 .Song:Alone 00000000 00000008 )
	EndIf
	Exec  $Script_SetupTexturePan
	Call     MakeNpcs           ( 00000001 $NpcGroupList_Disastar)
	% you should only be able to refight the boss after entering the room again so we have to set a byte here
	Set      .Disastar 	00000001
	Bind     $Script_TalkEye  .Trigger:WallPressA ~Collider:talkeye  00000001 00000000 
	If  *CheckXinSui == .False
		Exec    $AutoSaveCheck
	EndIf
	Exec    $PriestCutscene
	Call	GetLoadType 	( *Var[1] )
	If		*Var[1] ==  00000001 
		Exec	EnterSavePoint 
		Exec	$Script_MakeExits
	Else
				Set		*Var[0] $Script_MakeExits 
		Exec	EnterWalk 
		Set		*Var[0] $Script_MakeExits 
	EndIf
	Return
	End
}


#import AutoSave.mpat

#new:Script  $AutoSaveCheck
{
	Label 0
	Wait  1`
	Call  GetPlayerPos      ( *Var0 *Var1 *Var2 )
	If  *Var1 == 140`
		Exec  $AutoSave
	Else
		Goto  0
	EndIf
	Return
	End
}
	
	
#new:Script $Script_TalkEye
{
Call	 DisablePlayerInput ( .True )
If *GF_DNJ29_Disastar == 00000000
Call     ShowMessageAtScreenPos     	( $FirstTimeString 000000A0 00000028 )
	Thread
		Call     PlaySoundAtCollider 	( ~Collider:talkeye 00000187 00000000 )
		Call     ShakeCam    	( .Cam:Default 00000000 00000028 *Fixed[1.0] )
		%Call     SetPlayerAnimation 	( 0001002A )
		%Call     PlaySoundAtPlayer 	( 00000263 00000000 )
		%Call     ShowEmote   	( 00000000 .Emote:Question 00000000 00000014 00000000 00000000 00000000 00000000 00000000 )
		Wait 0000000A
		Wait 00000002
	EndThread
	Wait 00000032
	Call     ShowMessageAtScreenPos     	( $PriestMatte 000000A0 00000028 )
	Set  *MapFlag[0] .True
Set  *GF_DNJ29_Disastar  00000001 
Return	
Else
	Call     ShowMessageAtScreenPos     	( $DefaultString 000000A0 00000028 )
	If      .Disastar  ==  00000001
		Call     ShowMessageAtScreenPos     	( $Refight 000000A0 00000028 )
		Call     ShowChoice		( 001E001D ) % yes / no
		If	*Var[0]  ==  0
			Set  *MapFlag[0] .True
			Return	
		EndIf
	EndIf
EndIf
Call	 DisablePlayerInput ( .False )
Return
End
}

#string $FirstTimeString
{
[Style Inspect]
NO MESSAGES (ENGLISH)
[Wait][End]
}

#string $Refight
{
[Style Inspect]
NO MESSAGES (ENGLISH)
[Wait][End]
}

#string $PriestMatte
{
[Style Right]
[PrintRising][Size 24]Stop! [BR]
[Pause 10]Do not touch that eye!
[Wait][End]
}

#string $DefaultString
{
[DelayOff][Style Inspect]
Womp
[Wait][End]
}



#new:Script $PriestInit
{
	Call  BindNpcIdle   ( .Npc:Self $PriestIdle )
	Call  BindNpcDefeat ( .Npc:Self $PriestDeath )
	Return
	End
}



#new:Script $PriestCutscene
{
		Loop
			Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
			If   *Var2 < -800`
				BreakLoop
			EndIf
			Wait  1`
		EndLoop
		Call  $SetFlagCarryOverworldMusicToBattle()
		Call  DisablePlayerInput    ( .True )
		Wait  5`
		Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
		Call  UseSettingsFrom   ( .Cam:Default  *Var0 *Var1 *Var2 )
		Call  SetPanTarget  ( .Cam:Default  *Var0 *Var1 *Var2 )
		Call  SetCamSpeed   ( .Cam:Default *Fixed[90.0] )
		Call  PanToTarget   ( .Cam:Default 00000000 00000001 )
		Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )
		Call  SetMusicTrack ( 00000000 .Song:Infiltration 00000000 00000008 )  %Priest theme
		Call     ShowMessageAtScreenPos     	( $PriestMatte 000000A0 00000028 )
		Wait  10`
		Call  SetNpcPos ( .Npc:Priest  257`  110`  -470` )
		Call  SetNpcAnimation   ( .Npc:Priest 00870406 )	
				Call  GetNpcPos ( .Npc:Priest *Var0 *Var1 *Var2 )
				Sub   *Var0  80`
				Sub   *Var1  25`
				Call  UseSettingsFrom   ( .Cam:Default  *Var0 *Var1 *Var2 )
				Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )	
				Call  SetCamSpeed   ( .Cam:Default *Fixed[90.0] )
				Call  SetCamDistance    ( .Cam:Default 300` )
				Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
				Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )
		Wait  2`
		Thread
			Wait  2`
	   A4:  Call  SetPanTarget      ( .Cam:Default -10` 140`  -602` )
	   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[1.0] )
			Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
			Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )
		EndThread
		Call  SetNpcSpeed   ( .Npc:Priest *Fixed[4.0] )
		Call  NpcMoveTo ( .Npc:Priest  202` -540`  10` )
		Call  SetNpcJumpscale   ( .Npc:Priest *Fixed[1.2] )
		Call  SetNpcAnimation   ( .Npc:Priest 00870407 )
		Thread
			Call  PlayerMoveTo  (  -50`  -602`  15` )
			Call  PlayerFaceNpc ( .Npc:Priest .False )
		EndThread
		Thread
			Call  DisablePartnerAI  ( 00000000 )
			Call  NpcMoveTo ( .Npc:Partner -32`  -643`  15` )
			Call  NpcMoveTo ( .Npc:Partner -30`  -643`  1` )
			Call  SetNpcPos ( .Npc:Partner  -30` 140` -643` )
		EndThread
		Call  NpcJump1  ( .Npc:Priest  154`  140`  -600` 20` )
		Call  SetNpcAnimation   ( .Npc:Priest 00870406 )
		Call  NpcMoveTo ( .Npc:Priest  54` -602` 8` )
		Call  SetNpcAnimation   ( .Npc:Priest 00870405 )
		Wait  10`
		Thread
			Call  SetCamDistance    ( .Cam:Default 360` )
			Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
			Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )
		EndThread
		Wait  5`
		Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000000 $PriestSpeech4 ) %This is actually his first line	
		Wait  3`
  2E4:  Call  GetCurrentPartnerID   ( *Var0 )
  2F4:  Switch  *Var0
  300:  	Case  ==  .Partner:Goombario
  30C:  		Call  SpeakToPlayer ( .Npc:Partner 00010008 00010001 00000005 $GoombariusCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestGoombarius )  %Priest talk back
  32C:  	Case  ==  .Partner:Kooper
  338:  		Call  SpeakToPlayer ( .Npc:Partner 0002000F 00020002 00000005 $KooperCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestKooper )  %Priest talk back
  358:  	Case  ==  .Partner:Bombette
  364:  		Call  SpeakToPlayer ( .Npc:Partner 0003000E 00030003 00000005 $BombetteCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestBombette )  %Priest talk back
  384:  	Case  ==  .Partner:Parakarry
  390:  		Call  SpeakToPlayer ( .Npc:Partner 00040006 00040001 00000005 $ParakariusCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestParakarius )  %Priest talk back
  300:  	Case  ==  .Partner:Bow
  30C:  		Call  SpeakToPlayer ( .Npc:Partner 0005000A 0005000E 00000005 $BowCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestBow )  %Priest talk back
  32C:  	Case  ==  .Partner:Watt
  338:  		Call  SpeakToPlayer ( .Npc:Partner 00060007 00060001 00000005 $WattageCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestWattage )  %Priest talk back
  358:  	Case  ==  .Partner:Sushie
  364:  		Call  SpeakToPlayer ( .Npc:Partner 00070006 00070001 00000005 $SushieCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestSushie )  %Priest talk back
  384:  	Case  ==  .Partner:Lakilester
  390:  		Call  SpeakToPlayer ( .Npc:Partner 0008000D 00080001 00000005 $JonathanCounter ) % 
				Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000005 $PriestJonathan )  %Priest talk back
  3B0:  EndSwitch
		Wait  3`
	   70:  Call  GetNpcPos      ( .Npc:Priest *Var0 *Var1 *Var2 )
			Sub   *Var0  50`
	   A4:  Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )
	   C0:  Call  SetCamDistance    ( .Cam:Default  200` )
	   D4:  Call  SetCamPitch       ( .Cam:Default *Fixed[17.0] *Fixed[-6.0] )
	   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[4.0] )
	  100:  Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
		Call  SpeakToPlayer    ( .Npc:Priest 00870408 00870405 00000000 $PriestSpeech3 )
		Call  SetNpcAnimation   ( .Npc:Priest 00870411 )
		Wait  10`
		Call  SetNpcVar ( .Npc:Priest 00000000 00000001 )
		Return
		End
}

#new:Script  $PriestIdle
{
    0:  Loop
    C:  	Call  GetSelfVar    ( 00000000 *Var0 )
   20:  	If  *Var0  !=  00000000
   30:  		BreakLoop
   38:  	EndIf
   40:  	Wait  1`
   4C:  EndLoop
		Thread
	   70:  Call  GetNpcPos      ( .Npc:Priest *Var0 *Var1 *Var2 )
	   88:  Call  UseSettingsFrom   ( .Cam:Default *Var0 *Var1 *Var2 )
	   A4:  Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )
	   C0:  Call  SetCamDistance    ( .Cam:Default  500` )
	   D4:  Call  SetCamPitch       ( .Cam:Default *Fixed[17.0] *Fixed[-6.0] )
	   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[4.0] )
	  100:  Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
		EndThread
		Call  DisablePlayerInput    ( .False )
		Call  SetMusicTrack ( 00000000 .Song:Deadline 00000000 00000008 )
		Call  StartBossBattle   ( .Song:Deadline )
		Wait  2`
		Return
		End
}

#new:Script  $PriestDeath
{
		Set  *MapFlag[0] .True
		Wait  1`
		ExecWait $DeathCutscene
		Return
		End
}

#new:Script  $DeathCutscene
{
				Set   *CheckXinSui .True
				Call  SetNpcPos ( .Npc:Partner  -30` 140` -643` )
				Call  NpcMoveTo ( .Npc:Partner -29`  -643`  1` )
				Call	SetEncounterStatusFlags 			( 00000001 00000001 )
				Call  DisablePartnerAI  ( 00000000 )
				Call  FadeOutMusic      ( 00000000 000005DC )
				Call  DisablePlayerInput    ( .True )
				Call  $ClearFlagCarryOverworldMusicToBattle()
				Thread
					Call  ResetCam  ( .Cam:Default  1` )
					Call  SetCamDistance    ( .Cam:Default  300` )
				EndThread
				Call  SetNpcAnimation   ( .Npc:Priest 00870413 )					
				Wait  15`
				Call  DisablePartnerAI  ( 00000000 )
				Call  SpeakToPlayer    ( .Npc:Priest 00870413 00870413 00000000 $PriestDefeat )
		  2E4:  Call  GetCurrentPartnerID   ( *Var0 )
		  2F4:  Switch  *Var0
		  300:  	Case  ==  .Partner:Goombario
		  30C:  		Call  SpeakToPlayer ( .Npc:Partner 0001000F 0001000E 00000005 $GoombariusHaha ) % 
		  32C:  	Case  ==  .Partner:Kooper
		  338:  		Call  SpeakToPlayer ( .Npc:Partner 0002000F 00020002 00000005 $KooperHaha ) % 
		  358:  	Case  ==  .Partner:Bombette
		  364:  		Call  SpeakToPlayer ( .Npc:Partner 0003000D 00030014 00000005 $BombetteHaha ) % 
		  384:  	Case  ==  .Partner:Parakarry
		  390:  		Call  SpeakToPlayer ( .Npc:Partner 00040006 00040001 00000005 $ParakariusHaha ) % 
		  300:  	Case  ==  .Partner:Bow
		  30C:  		Call  SpeakToPlayer ( .Npc:Partner 00050009 00050001 00000005 $BowHaha ) % 
		  32C:  	Case  ==  .Partner:Watt
		  338:  		Call  SpeakToPlayer ( .Npc:Partner 00060005 00060001 00000005 $WattageHaha ) % 
		  358:  	Case  ==  .Partner:Sushie
		  364:  		Call  SpeakToPlayer ( .Npc:Partner 00070008 00070007 00000005 $SushieHaha ) % 
		  384:  	Case  ==  .Partner:Lakilester
		  390:  		Call  SpeakToPlayer ( .Npc:Partner 0008000A 00080006 00000005 $JonathanHaha ) % 
		  3B0:  EndSwitch
				Wait  20`
				Call  SetNpcAnimation   ( .Npc:Priest 0087040D )	
				Thread
			   70:  Call  GetNpcPos      ( .Npc:Priest *Var0 *Var1 *Var2 )
					Sub   *Var0  50`
			   A4:  Call  SetPanTarget      ( .Cam:Default *Var0 *Var1 *Var2 )
			   C0:  Call  SetCamDistance    ( .Cam:Default  170` )
			   D4:  Call  SetCamPitch       ( .Cam:Default *Fixed[17.0] *Fixed[-6.0] )
			   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[1.25] )
			  100:  Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
				EndThread
				Call  SpeakToPlayer    ( .Npc:Priest 0087040D 0087040D 00000000 $PriestLaughter )
				Call  SetNpcAnimation   ( .Npc:Priest 00870415 )
				Call  SetMusicTrack ( 00000000 .Song:SunTowerSunny 00000001 00000008 )  %Burn in Despair
				Call  EndSpeech     ( .Npc:Priest 00870415 00870415 00000000 )
				Call  SpeakToPlayer    ( .Npc:Priest 00870414 0087040E 00000000 $PriestSpeech )
				Call  SetCamDistance    ( .Cam:Default  420` )
			   D4:  Call  SetCamPitch       ( .Cam:Default *Fixed[13.0] *Fixed[-10.0] )
			   EC:  Call  SetCamSpeed       ( .Cam:Default *Fixed[4.0] )
			  100:  Call  PanToTarget       ( .Cam:Default 00000000 00000001 )
					Call  WaitForCam    ( .Cam:Default *Fixed[1.0] )
				Wait  5`
				Call  SetNpcAnimation   ( .Npc:Priest 0087040B )
				Wait  5`
		 11AC:  Thread
		 11B4:  	Call  ShakeCam  ( .Cam:Default 00000000  20` *Fixed[8.0] )
		 11D0:  EndThread
		 11D8:  Call  PlaySound ( 00002127 )
		 1214:  Call  PlayEffect        ( ~FX:Lightning:YellowMagic2 15` 213` -867` 00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000000 )		
				Wait  10`
				Call  SetNpcAnimation   ( .Npc:Priest 0087040E )
				Call     PlaySoundAtCollider 	( ~Collider:talkeye 00000187 00000000 )
				Call     ShakeCam    	( .Cam:Default 00000000 00000028 *Fixed[1.0] )
				Wait 60`
				Call  SpeakToPlayer    ( .Npc:Priest 00870415 00870415 00000000 $PriestSpeech2 )
				Call  StopSound ( 00000187 )
				Wait  10`
				Set  *MapFlag[0] .True
				Wait  1`
				Return
				End
}


#new:Script $Script_Init_Disastar
{
		Call     BindNpcIdle 		( .Npc:Self $Script_IdleAI )
		Call     BindNpcDefeat 	( .Npc:Self $Script_XinSuiDefeat )
		Call     BindNpcInteract	( .Npc:Self $Script_Interact )
     Return
     End
}
 
#new:Script $Script_IdleAI
{
	Loop
		If  *MapFlag[0]  ==  .True 
		 	Call     StartBossBattle 	( .Song:SunTowerSunny )
		EndIf
		Wait     00000001 
	EndLoop
	Return
	End
}
 
 
#new:Script $Script_XinSuiDefeat
{
		Call     DisablePlayerInput	( .False )
		Call     EnablePartnerAI 	( )
		Set  *GF_DNJ29_Disastar  00000001 
		Set  *MapFlag[0] .False 
		Set      .Disastar 	00000000
   Return
   End 
}

