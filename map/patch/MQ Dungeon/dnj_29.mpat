#new:Script $Script_SetupTexturePan
{
	Call     802C9000 	( ~Model:fogwall 1 )
	Call     802C9000 	( ~Model:fogfloor 1 )
	Thread
		Set  *Var[0] 1
		Set  *Var[1] 0
		Set  *Var[2] 2000`
		Set  *Var[3] 0
		Set  *Var[4] 0
		Set  *Var[5] 0
		Set  *Var[6] 1
		Set  *Var[7] 0
		Set  *Var[8] 1
		Set  *Var[9] 0
		Set  *Var[A] 0
		Set  *Var[B] 0
		Set  *Var[C] 0
		Exec $Script_TexturePan_Update
	EndThread
	Return
	End
}
#new:String $PriestSpeech
