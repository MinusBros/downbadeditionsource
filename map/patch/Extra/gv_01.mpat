
#new:Function_Init $Function_Init
{
    PUSH      RA
    JAL       $IncrementDeathCounter
    NOP
    CLEAR     V0 % required for init functions
    JPOP      RA
}

@	$Header
{
	[MainScript]  $Script_GameOverDriver_Primary
	[EntryList]   $EntryList
	[EntryCount]  00000001
	[Background]  00000000
	[MapTattle]   00000000
}


%Entering the Game Over map increments the death counter, but the player may continue if they wish

#new:Script $Script_GameOverDriver_Primary
{	
   B8:  Call  DisablePlayerInput    ( .True )
   C8:  Call  ModifyGlobalOverrideFlags  ( 00000000 00020000 )
   DC:  Call  SetCamPerspective ( .Cam:Default 00000003 00000019 00000010 00001000 )
   FC:  Call  SetCamBGColor     ( .Cam:Default 00000000 00000000 00000000 )
  118:  Call  SetCamEnabled     ( .Cam:Default .True )
  12C:  Call  SetCamLeadPlayer  ( .Cam:Default .False )
  140:  Thread
  148:  	Call  GetCurrentPartnerID   ( *Var[0] )
  158:  	If  *Var[0]  !=  .Partner:None % 0
  168:  		Call  DisablePartnerAI  ( 00000000 )
  178:  		Call  SetNpcFlagBits    ( .Npc:Partner 00000200 .False )
  190:  		Call  SetNpcPos ( .Npc:Partner 00000000 FFFFFC18 00000000 )
  1AC:  	EndIf
  1B4:  	Call  SetPlayerFlagBits ( 00200000 .True )
  1C8:  	Call  InterpPlayerYaw   ( 0000005A 00000000 )
  1DC:  	Wait  2`
  1E8:  	Call  RandInt   ( 00000007 *Var[0] )  %Add more frames to pick from
  1FC:  	Switch  *Var0
  208:  		Case  ==  0`
  214:  			Call  SetPlayerAnimation    ( 0001000D )
  224:  		Case  ==  1`
  230:  			Call  SetPlayerAnimation    ( .PlayerAnim:Crouch )
  240:  		Case  ==  2`
  24C:  			Call  SetPlayerAnimation    ( .PlayerAnim:ShockStill )
  25C:  		Case  ==  3`
  268:  			Call  SetPlayerAnimation    ( .PlayerAnim:Pray )
  278:  		Case  ==  4`
  284:  			Call  SetPlayerAnimation    ( .PlayerAnim:DeadStill )
				Case  ==  5`
					Call  SetPlayerAnimation    ( 0001002F )
				Case  ==  6`
					Call  SetPlayerAnimation    ( 00080009 )
				Case  ==  7`
					Call  SetPlayerAnimation    ( 00080029 )
  294:  	EndSwitch
  29C:  EndThread
		Thread
			Call  SetMusicTrack ( 00000000 .Song:GameOver 00000000 00000008 )
			Wait  264`
			If  *Flag[05] == .False
				Call  SetMusicTrack ( 00000000 .Song:GameOver 00000001 00000008 )
			EndIf
		EndThread
  2C0:  Call  ClearAmbientSounds    ( 00000000 )
  2D0:  Thread
  2D8:  	Wait  105`
  
			If   *IWannaBeTheGuy == .True		%Check if I Wanna Be The Guy mode is on (AKA Hard but no continues)
				Exec $GoToTitle
				Return
			EndIf
			
			ExecWait  $BossCheck			%Check if boss flags have been set. If yes, then ask to run it back instead of going to Kinoko Town
			If  *Flag[05] == .True
				Return
			EndIf
			
			If  *ReturnPipeLock == .True		%If Return Pipe is locked, don't ask to return to Kinoko Town
				Exec $GoToTitle
				Return
			EndIf
			
		Switch  *GB_StoryProgress				%If you're in a Peach section, do a special death warp
			CaseOR  ==  .Story:Ch1_BeganPeachMission
			CaseOR  ==  .Story:Ch2_BeganPeachMission
			CaseOR  ==  .Story:Ch3_BeganPeachMission
			CaseOR  ==  .Story:Ch4_BeganPeachMission
			CaseOR  ==  .Story:Ch5_BeganPeachMission
			CaseOR  ==  .Story:Ch6_BeganPeachMission
				Exec  $PeachWarp
				Return
			EndCaseGroup
		EndSwitch
		
		Exec  $GameOverChoice				%If all above checks fail, ask to return to Kinoko Town or go to Title Screen, like in vanilla
  308:  EndThread
  
		%Resume vanilla Game Over script
		
  310:  Call  802D7CF8  ( 00000000 00000000 00000000 00000140 000000F0 00000080 0000000A )
  338:  Call  TranslateGroup    ( ~Model:g 00000000 000000C8 00000000 )
  354:  Call  TranslateGroup    ( ~Model:a 00000000 000000C8 00000000 )
  370:  Call  TranslateGroup    ( ~Model:m 00000000 000000C8 00000000 )
  38C:  Call  TranslateGroup    ( ~Model:e 00000000 000000C8 00000000 )
  3A8:  Call  TranslateGroup    ( ~Model:o 00000000 000000C8 00000000 )
  3C4:  Call  TranslateGroup    ( ~Model:v 00000000 000000C8 00000000 )
  3E0:  Call  TranslateGroup    ( ~Model:e2 00000000 000000C8 00000000 )
  3FC:  Call  TranslateGroup    ( ~Model:r 00000000 000000C8 00000000 )
  418:  Thread
  420:  	Wait  6`
  42C:  	Set   *Var[0]  00000004
  43C:  	Exec  $Script_GameOverDriver_Secondary
  448:  	Wait  6`
  454:  	Set   *Var[0]  00000006
  464:  	Exec  $Script_GameOverDriver_Secondary
  470:  	Wait  12`
  47C:  	Set   *Var[0]  00000008
  48C:  	Exec  $Script_GameOverDriver_Secondary
  498:  	Wait  6`
  4A4:  	Set   *Var[0]  0000000A
  4B4:  	Exec  $Script_GameOverDriver_Secondary
  4C0:  	Wait  6`
  4CC:  	Set   *Var[0]  0000000C
  4DC:  	Exec  $Script_GameOverDriver_Secondary
  4E8:  	Wait  6`
  4F4:  	Set   *Var[0]  0000000E
  504:  	Exec  $Script_GameOverDriver_Secondary
  510:  	Wait  6`
  51C:  	Set   *Var[0]  00000010
  52C:  	Exec  $Script_GameOverDriver_Secondary
  538:  	Wait  18`
  544:  	Set   *Var[0]  00000012
  554:  	Exec  $Script_GameOverDriver_Tertiary
  560:  EndThread
  604:  Return
  60C:  End
}

#new:Script $Script_GameOverDriver_Secondary
{
	 0:  UseIntBuffer  $IntTable_802415DC
    C:  Loop  0000001A
   18:  	Get1Int  *Var[1]
   24:  	Call  TranslateGroup    ( *Var[0] 00000000 *Var[1] 00000000 )
   40:  	Wait  1`
   4C:  EndLoop
   54:  Return
   End
}

#new:Script $Script_GameOverDriver_Tertiary
{
   5C:  UseIntBuffer  $IntTable_80241644
   68:  Loop  00000013
   74:  	Get1Int  *Var[1]
   80:  	Call  TranslateGroup    ( *Var[0] 00000000 *Var[1] 00000000 )
   9C:  	Wait  1`
   A8:  EndLoop
   B0:  Return
   End
}

%Under certain circumstances, the player may go to the title screen or Kinoko Town
#new:Script   $GameOverChoice
{
			Call  ShowMessageAtScreenPos    ( 001E0046  152`  50` ) % Go to Kinoko Town or title screen
			Switch  *Var0
				Case  ==  0`
					Call  DisablePlayerInput    ( .False )
					Call  FadeOutMusic  ( 00000000 00000BB8 )
					Call  FullyRestoreHPandFP ( )
					Call  GotoMapSpecial    ( "mac_00" 00000004 00000006 )
					Wait  90`
				Case  ==  1`
					Call  FadeOutMusic  ( 00000000 000009B8 )
					Set   *Flag[05]  .True
					Exec  $GoToTitle
			EndSwitch
			Return
			End
}


#new:Script  $BossCheck
{
	Set  *Var0 2`
	Wait 1`
	If *CheckCoopNotes == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckTutankoopa == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckTyrant == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckTubbs1 == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckTubbs2 == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckShyShogun == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckBowersBrother == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckMoltenPiranha == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckLordofThunder == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckBlackCrystalKing == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckPriest == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckXinSui == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If *CheckFinalBower == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If  *EscapeSequence == .True
		Call  ShowMessageAtScreenPos    ( 001E004C  152`  10` ) % Run it back	
	EndIf
	If  *Var0 == 0`		
		Set   *Flag[05]  .True
		Call  FullyRestoreHPandFP ( )
		Call  FullyRestoreSP ( )
		Call  FadeOutMusic  ( 00000000 00000BB8 )
		Wait  1`
		If *CheckCoopNotes == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "trd_10" 00000000 00000006 )
		EndIf
		If *CheckTutankoopa == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "isk_16" 00000000 00000006 )
		EndIf
		If *CheckTyrant == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "obk_09" 00000000 00000006 )
		EndIf
		If *CheckTubbs1 == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "arn_11" 00000000 00000006 )
			Return
		EndIf
		If *CheckTubbs2 == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "arn_07" 00000000 00000006 )
			Return
		EndIf
		If *CheckShyShogun == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "omo_15" 00000000 00000006 )
			Return
		EndIf
		If *CheckBowersBrother == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "kzn_16" 00000000 00000006 )
			Return
		EndIf
		If *CheckMoltenPiranha == .True
			Set  *MoltenPiranhaTurn .False
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "kzn_19" 00000001 00000006 )
			Return
		EndIf
		If *CheckLordofThunder == .True
			Set  *LordofThunderTurn .False
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "flo_21" 00000000 00000006 )
			Return
		EndIf
		If *CheckBlackCrystalKing == .True
			Set  *CrystalKingTurn .False
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "pra_32" 00000000 00000006 )
			Return
		EndIf
		If *CheckPriest == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "dnj_29" 00000000 00000006 )
			Return
		EndIf
		If *CheckXinSui == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "dnj_29" 00000000 00000006 )
			Return
		EndIf
		If *CheckFinalBower == .True
			Call	$Function_LoadItems ( )
			Call  GotoMapSpecial    ( "kkj_25" 00000001 00000006 )
			Return
		EndIf
		If *EscapeSequence == .True
			Call  GotoMapSpecial    ( "kpa_121" 00000001 00000006 )
			Return
		EndIf
	EndIf
	If  *Var0 == 1`
		Set   *Flag[05]  .True
		Exec  $GoToTitle
	EndIf
	Return
	End
}


#new:Script  $GoToTitle
{
			  2D0:  Thread
			  2D8:  	Wait  110`
			  2E4:  	Call  $Function_802405EC ( )
			  2F0:  	Call  $Function_80240688 ( )
			  2FC:  	Wait  100`
			  308:  EndThread
			  568:  Thread
			  570:  	Call  UseSettingsFrom   ( .Cam:Default  0`  10`  0` )
			  58C:  	Call  SetPanTarget  ( .Cam:Default  0`  0`  0` )
			  5A8:  	Call  SetCamSpeed   ( .Cam:Default *Fixed[0.3] )
			  5BC:  	Call  PanToTarget   ( .Cam:Default 00000000 00000001 )
			  5E0:  	Call  SetPanTarget  ( .Cam:Default  0`  0`  1000` )
			  5FC:  EndThread  
					Return
					End
}


#new:Script  $PeachWarp
{
			  2D0:  Thread
			  2D8:  	Wait  110`	
			  2FC:  	Wait  100`
						Call  GotoMapSpecial    ( "kkj_14" 00000001 00000006 )
			  308:  EndThread
			  568:  Thread
			  570:  	Call  UseSettingsFrom   ( .Cam:Default  0`  10`  0` )
			  58C:  	Call  SetPanTarget  ( .Cam:Default  0`  0`  0` )
			  5A8:  	Call  SetCamSpeed   ( .Cam:Default *Fixed[0.3] )
			  5BC:  	Call  PanToTarget   ( .Cam:Default 00000000 00000001 )
			  5E0:  	Call  SetPanTarget  ( .Cam:Default  0`  0`  1000` )
			  5FC:  EndThread  
					Return
					End
}