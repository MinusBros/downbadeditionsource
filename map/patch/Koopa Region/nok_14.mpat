   54:  	Set   *Var0  00000000
   64:  EndIf
   6C:  If  *Var0  ==  00000000
   7C:  	Call  MakeEntity        ( .Entity:BlueSwitch ~Vec4d:Entity80242D4C 80000000 )
   A0:  	Call  AssignAreaFlag    ( 00000002 )
   B0:  EndIf
   B8:  Call  MakeItemEntity    ( .Item:Coin ~Vec3d:Item80242D88 .ItemSpawnMode:Fixed_NeverVanish *GF_NOK14_Item_CoinA )
   DC:  Call  MakeItemEntity    ( .Item:Coin ~Vec3d:Item80242DAC .ItemSpawnMode:Fixed_NeverVanish *GF_NOK14_Item_CoinB )
