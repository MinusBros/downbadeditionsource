#import PartnerBlurb.mpat


#new:Script  $Script_KooperBlurb
{
			Wait  30`
			Call  GetCurrentPartnerID   ( *Var0 )
			Switch  *Var0
				Case  ==  .Partner:Kooper % 2
					Call  SpeakToPlayer ( .Npc:Partner FFFFFFFF FFFFFFFF 00000005 000C0157 ) 
			EndSwitch
			Return
			End
}


#new:Script  $PartnerBlurb
{
				Label 0
				If  *GF_NOK14_Item_ThunderBolt == .False
					Wait  1`
					Goto  0
				EndIf
				Wait  45`
				Exec  $Blurb
				Return
				End
}

#new:Script  $PartnerBlurb2
{
				Label 0
				If  *GF_NOK14_HiddenPanel == .False
					Wait  1`
					Goto  0
				EndIf
				Wait  45`
				Exec  $Blurb
				Return
				End
}

