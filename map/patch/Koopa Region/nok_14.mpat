  124:  Call  MakeItemEntity    ( .Item:Coin ~Vec3d:Item80242DF4 .ItemSpawnMode:Fixed_NeverVanish *GF_NOK14_Item_CoinD )
  148:  Call  MakeItemEntity    ( .Item:Coin ~Vec3d:Item80242E18 .ItemSpawnMode:Fixed_NeverVanish *GF_NOK14_Item_CoinE )
  16C:  Call  MakeEntity        ( .Entity:BrickBlock ~Vec4d:Entity80242E3C 80000000 )
  190:  Call  AssignScript      ( $Script_80242B54 )
  1A0:  Call  MakeItemEntity    ( .Item:ThunderBolt ~Vec3d:Item80242E70 .ItemSpawnMode:Fixed_NeverVanish *GF_NOK14_Item_ThunderBolt )
  1C4:  Set   *MapVar[0]  *Var0
  1D4:  Call  MakeEntity        ( .Entity:BrickBlock ~Vec4d:Entity80242EA4 80000000 )
  1F8:  Call  MakeEntity        ( .Entity:HiddenYellowBlock ~Vec4d:Entity80242EC8 .Item:FireFlower 80000000 )
  220:  Call  AssignBlockFlag   ( *GF_NOK14_HiddenItem_FireFlower )
  230:  Call  MakeEntity        ( .Entity:BrickBlock ~Vec4d:Entity80242F00 80000000 )
  254:  Call  MakeEntity        ( .Entity:HiddenPanel ~Vec4d:Entity80242F24 ~Model:o251 80000000 )
  27C:  Call  AssignPanelFlag   ( *GF_NOK14_HiddenPanel )
		If  *GF_NOK14_Item_ThunderBolt  == .False
			Exec  $PartnerBlurb
		EndIf
		If  *GF_NOK14_HiddenPanel  == .False
			Exec  $PartnerBlurb2
		EndIf
  28C:  Return
  294:  End
}


