@	$Script_Main
{
    0:  Set   *GB_WorldLocation  .Location:CrystalPalace
   10:  Call  SetSpriteShading  ( .Shading:mim_01 )
   20:  Call  SetCamPerspective ( .Cam:Default 00000003  25`  16`  4096` )
   40:  Call  SetCamBGColor     ( .Cam:Default  24`  24`  40` )
   5C:  Call  SetCamLeadPlayer  ( .Cam:Default .False )
   70:  Call  SetCamEnabled     ( .Cam:Default .True )
   84:  Call  MakeNpcs  ( .True $NpcGroupList_80243DB0 )
		Exec  $Script_SetupTexturePan
   98:  Set   *Var0  00000040
   A8:  Set   *Var1  00000041
   B8:  Set   *Var2  00000000
   C8:  Exec  $Script_80242CC0
   D4:  ExecWait  $Script_MakeEntities
   E0:  Exec  $Script_EnterWalk_802431C4
   EC:  Wait  1`
   F8:  If  *GF_PRA33_BombedWall  ==  .False
  108:  	Bind  $Script_802432B8 .Trigger:PointBomb $TriggerCoord_802432A8 00000001 00000000
  124:  Else
  12C:  	Call  EnableGroup   ( ~Model:g297 .False )
  140:  	Call  ModifyColliderFlags   ( 00000000 ~Collider:deilittnw 7FFFFE00 )
  158:  EndIf
  160:  Set   *Var0  00000000
  170:  Set   *Var1  *GF_PRA_BrokeIllusion
  180:  Exec  $Script_80242ED4
  18C:  Exec  $Script_80242C80
  198:  Return
  1A0:  End
}

