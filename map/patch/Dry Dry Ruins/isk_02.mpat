#define .NpcID:Pokey_00             00
#define .NpcID:Pokey_01             01
#define .NpcID:Pokey_02             02

@	$Script_Main_EnterWalk
{
    0:  Set   *GB_WorldLocation  .Location:DryDryRuins
   10:  Call  SetSpriteShading  ( .Shading:None )
   20:  Call  SetCamPerspective ( .Cam:Default 00000003  25`  16`  4096` )
   40:  Call  SetCamBGColor     ( .Cam:Default  0`  0`  0` )
   5C:  Call  SetCamLeadPlayer  ( .Cam:Default .False )
   70:  Call  SetCamEnabled     ( .Cam:Default .True )
   84:  Call  MakeNpcs  ( .True $NpcGroupList_802416F8 )
   98:  ExecWait  $Script_MakeEntities
   A4:  ExecWait  $Script_80240640
   B0:  Exec  $Script_802406D0
   BC:  Switch  *GB_StoryProgress
   C8:  	Case  <  .Story:Ch2_SolvedArtifactPuzzle % FFFFFFC7
   D4:  		Call  SetMusicTrack ( 00000000 .Song:DryDryRuins 00000000 00000008 )
				  Thread
					Wait  25`
					Call  802D5FA4  ( 00000004 )
				EndThread
   F0:  	Case  <  .Story:Ch2_DefeatedTutankoopa % FFFFFFC8
   FC:  		Call  SetMusicTrack ( 00000000 .Song:RuinsBasement 00000000 00000008 )
				  Thread
					Wait  25`
					Call  802D5FA4  ( 00000004 )
				EndThread
  118:  	Case  >=  .Story:Ch2_DefeatedTutankoopa % FFFFFFC8
  124:  		Call  SetMusicTrack ( 00000000 .Song:DryDryRuins 00000000 00000008 )
				  Thread
					Wait  25`
					Call  802D5FA4  ( 00000004 )
				EndThread
  140:  EndSwitch
  148:  Set   *Var0  $Script_80240294
  158:  Exec  EnterWalk
		If  *GF_ISK02_Item_SpikeShield  == .False
			Exec  $Script_PartnerBlurb
		EndIf
  164:  Return
  16C:  End
}



#new:Script  $Script_PartnerBlurb
{
				Label 0
				If  *GF_ISK02_Item_SpikeShield  == .False
					Wait  1`
					Goto  0
				EndIf
				Wait  30`
			Call  GetCurrentPartnerID   ( *Var0 )
			Switch  *Var0
				Case  ==  .Partner:Goombario % 1
					Call  SetPlayerFlagBits ( 000000C0 .True )
					Call  SpeakToPlayer ( .Npc:Partner 00010008 00010001 00000005 000D0110 )
					Wait  70`
					Call  SetPlayerFlagBits ( 000000C0 .False )
				Case  ==  .Partner:Kooper % 2
					Call  SpeakToPlayer ( .Npc:Partner FFFFFFFF FFFFFFFF 00000005 000D0111 )
				Case  ==  .Partner:Bombette % 3
					Call  SpeakToPlayer ( .Npc:Partner FFFFFFFF FFFFFFFF 00000005 000D0112 ) 
				Case  ==  .Partner:Parakarry % 4
					Call  SpeakToPlayer ( .Npc:Partner FFFFFFFF FFFFFFFF 00000005 000D0113 ) 
				EndSwitch
				Return
				End
}


