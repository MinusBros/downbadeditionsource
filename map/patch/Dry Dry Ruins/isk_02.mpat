	00000A00 $Script_Init_8024108C 00000000 00000000 00000130
	~Items:5:Apple:A ~HP:Generous:2 ~FP:Standard:2 ~CoinBonus:1:2
	~Movement:NPC_Pokey_00
	~AnimationTable:NPC_Pokey_00 % .Sprite:Pokey
