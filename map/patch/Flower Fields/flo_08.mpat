%Oh yes, we're adding Fuzzies

#import  FuzzyTree.mpat


#new:Script $CheckPos
{
	Label 1
	Wait  1`
	Call  GetPlayerPos  ( *Var0 *Var1 *Var2 )
	If *Var0  > -299`
		%Exec  $TreeCallback
		Wait  1`
		Return
	EndIf
	Goto  1
	Return
	End
}


@	$Script_Idle_Fuzzy
{
    0:  Call  SetNpcPos     ( .Npc:Self  0`  -1000`  0` )
   1C:  Label  0
   28:  Call  GetSelfVar    ( 00000007 *Var0 )
   3C:  Wait  1`
   48:  If  *Var0  ==  00000000
   58:  	Goto  0
   64:  EndIf
   6C:  Call  SetNpcAnimation   ( .Npc:Self 002B0309 )
   80:  Call  SetNpcFlagBits    ( .Npc:Self 00000200 .True )
   98:  Call  SetNpcFlagBits    ( .Npc:Self 00000008 .False )
   B0:  Call  SetNpcPos ( .Npc:Self  -357`  219`  9` )
   CC:  Call  PlaySoundWithVolume   ( 00000331 0000006E )
   E0:  Wait  35`
   EC:  Call  SetNpcFlagBits    ( .Npc:Self 00000200 .False )
  104:  Call  SetNpcFlagBits    ( .Npc:Self 00000008 .True )
  11C:  Call  BindNpcAI ( .Npc:Self $Script_NpcAI_Fuzzy )
  130:  Return
  138:  End
}