@	$Script_Init_80244BC8
{
    0:  Thread
    8:  	Wait  2`
   14:  	Call  GetNpcPointer ( .NpcID:Dayzee_02 *Var0 )
   28:  	If  *Var0  ==  00000000
   38:  		Call  RemoveNpc ( .Npc:Self )
   48:  		Return
   50:  	EndIf
			If   *GF_FLO08_AmazyDayzee == .True
   38:  		Call  RemoveNpc ( .Npc:Self )
   48:  		Return
			EndIf
   58:  	Call  RandInt   ( 00000064 *Var0 )
   6C:  	If  *Var0  <  0000001E
   7C:  		Call  SetNpcFlagBits    ( .NpcID:Dayzee_02 00000006 .True )
   94:  		Call  SetNpcPos ( .NpcID:Dayzee_02  0`  -1000`  0` )
   B0:  	Else
   B8:  		Call  SetNpcFlagBits    ( .Npc:Self 00000006 .True )
   D0:  		Call  SetNpcPos ( .Npc:Self  0`  -1000`  0` )
   EC:  	EndIf
   F4:  EndThread
   FC:  Return
  104:  End
}



