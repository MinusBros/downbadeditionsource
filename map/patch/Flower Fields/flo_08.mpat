#new:Script  $IsAmazyDayzeeDead
{
	Thread
		Label A
		Wait  5`
		If  *GF_FLO08_AmazyDayzee == .True
			Set  *Byte_Settings_BGM .True
		Else
			Goto A
		EndIf
	EndThread
	Return
	End
}


