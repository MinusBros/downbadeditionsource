#define .AttackTurns 1`

#new:Script $Script_Init_PacMan {
    0:  Call  BindTakeTurn      ( .Actor:Self $Script_TakeTurn_PacMan )
   14:  Call  BindIdle  ( .Actor:Self $Script_Idle_PacMan )
   28:  Call  BindHandleEvent   ( .Actor:Self $Script_HandleEvent_PacMan )
		Call  SetActorScale 	( .Actor:Self *Fixed[1.5] *Fixed[1.5] *Fixed[1.5] )
		Call  SetMusicTrack ( 00000000 .Song:Faith 00000000 00000008 )
		Call  SetActorVar   ( .Actor:Self .AttackTurns 00000000 )	%How many times Pac-Man gets to attack
   3C:  Return
   44:  End
}

#new:Script $Script_Idle_PacMan {
    0:  Return
    8:  End
}


%Here's How Pac-Man will work.
%Depending on how much HP, he will be given a set number of turns to attack.
%Each attack decrements

#new:Script $Script_TakeTurn_PacMan
{
    0:  Call  UseIdleAnimation  ( .Actor:Self .False )
   14:  Call  EnableIdleScript  ( .Actor:Self 00000000 )
		Call  GetActorHP    ( .Actor:Self *Var1 )
		Call  GetEnemyMaxHP ( .Actor:Self *Var2 )
		Mul   *Var1  100`
		Div   *Var1  *Var2 
		Switch  *Var1
			Case  <  33`
				Call  SetActorVar   ( .Actor:Self .AttackTurns 4` )
			Case  <  66`
				Call  SetActorVar   ( .Actor:Self .AttackTurns 3` )
			Case  >= 66`
				Call  SetActorVar   ( .Actor:Self .AttackTurns 2` )
		EndSwitch
		ExecWait  $PacManAttack
		ExecWait  $RandomizeIdleAnim
		Return
		End
}


#new:Script $PacManAttack {
		Label BeginTurn
   28:  Call  SetTargetActor    ( .Actor:Self .Actor:Player )
   3C:  Call  UseBattleCamPreset    ( 0000003F )
   4C:  Call  BattleCamTargetActor  ( .Actor:Self )
   5C:  Call  8024ECF8  ( FFFFFFFF 00000001 00000000 )
		Call     RandInt     	( 3` *Var9 )	%Pick which attack to do at random
		Switch *Var9
			Case == 0`
				ExecWait $WalkandKick
			Case == 1`
				Wait  6`
				ExecWait $WalkandKick
			Case == 2`
				ExecWait $ScaredRun
			Case == 3`
				ExecWait $RunAndJump
		EndSwitch
		ExecWait  $DecrementTurns
		Call  EnableIdleScript  ( .Actor:Self 00000001 )
		Call  UseIdleAnimation  ( .Actor:Self .True )
		Call  GetActorVar   ( .Actor:Self .AttackTurns *Var0 )		%If Pac-Man runs out of turns, return script. If not, go back and deplete turns until he's out.
		If  *Var0 != 0`
			Goto  BeginTurn
		EndIf
  544:  Return
  54C:  End
}

#new:Script  $DecrementTurns
{
		Call  GetActorVar   ( .Actor:Self .AttackTurns *Var1 )	%There's probably an easier way to subtract, but I'll do this for now
		Switch  *Var1
			Case == 4`
				Call  SetActorVar   ( .Actor:Self .AttackTurns 3` )
			Case == 3`
				Call  SetActorVar   ( .Actor:Self .AttackTurns 2` )
			Case == 2`
				Call  SetActorVar   ( .Actor:Self .AttackTurns 1` )
			Case == 1`
				Call  SetActorVar   ( .Actor:Self .AttackTurns 0` )
		EndSwitch
		Return
		End
}


#new:Script $WalkandKick
{
		Call     RandInt     	( 2` *VarC )
		If   *VarC == 0`
			ExecWait	$LookLook
		EndIf
    0:  Call  UseIdleAnimation  ( .Actor:Self .False )
   14:  Call  EnableIdleScript  ( .Actor:Self 00000000 )
		ExecWait  $RandomizeWalkCycle
  14C:  Call  SetGoalToTarget   ( .Actor:Self )
  15C:  Call  GetStatusFlags    ( .Actor:Self *Var0 )
  170:  If  *Var0  !&  ~Flags:StatusFlags:Shrink % 80000
  180:  	Call  AddGoalPos    ( .Actor:Self  27`  0`  -6` )
  19C:  Else
  1A4:  	Call  AddGoalPos    ( .Actor:Self  10`  0`  -6` )
  1C0:  EndIf
  1C8:  Call  RunToGoal     ( .Actor:Self  0` .False )
  1E0:  Call  SetAnimation  ( .Actor:Self 00000001 .AnimIdle )
  1F8:  Wait  10`
  20C:  Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:0 00000000 00000001 00000010 )
  230:  Switch  *Var0 
  23C:  	CaseOR  ==  .HitResult:Miss % 6
  248:  	CaseOR  ==  .HitResult:Lucky % 5
  254:  		Set   *VarA  *Var0 
				Call     RandInt     	( 1` *VarB )
				If   *VarB == 0`
					Call  SetAnimation      ( .Actor:Self 00000001 .AnimDance )
					Wait  20`
				Else
					Call  SetAnimation      ( .Actor:Self 00000001 .AnimShrug )
					Wait  30`
				EndIf
  2F0:  		Call  UseBattleCamPreset    ( 00000002 )
  300:  		Call  SetActorYaw   ( .Actor:Self  180` )
  314:  		Call  AddActorDecoration    ( .Actor:Self 00000001 00000000 .Decoration:Sweat )
  330:  		SetConst  *Var0  00000001 
  340:  		SetConst  *Var1  .AnimScaredRun 
  350:  		ExecWait  DoReturnHome 
  35C:  		Call  RemoveActorDecoration ( .Actor:Self 00000001 00000000 )
  374:  		Call  SetActorYaw   ( .Actor:Self  0` )
  388:  		Call  EnableIdleScript      ( .Actor:Self 00000001 )
  39C:  		Call  UseIdleAnimation      ( .Actor:Self .True )
  3B0:  		Return
  3B8:  	EndCaseGroup
  3C0:  EndSwitch
		Call     RandInt     	( 2` *VarD )
		Switch  *VarD
			Case == 0`	%The Pac-Man KICK!
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimKick )	%Two timings
				Call     RandInt     	( 1` *VarC )
				If   *VarC == 0`
					Wait  8`
				Else
					Call  SetAnimationRate  ( .Actor:Self 00000001 *Fixed[0.5] )
					Wait  16`		
				EndIf
				Call  PlaySoundAtActor  ( .Actor:Self 000020C5 )	
				Wait  2`
				Call  SetAnimationRate  ( .Actor:Self 00000001 *Fixed[1.0] )
				Call  SetGoalToTarget   ( .Actor:Self )
				Call  80269EAC  ( 0`)
				Call  EnemyDamageTarget ( .Actor:Self *Var0 ~Flags:DamageType:0 00000000 00000000 12` 00000020 )
			Case == 1		%The Pac-Man pimp slap
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimSlap )	%Two timings
				Call     RandInt     	( 1` *VarC )
				If   *VarC == 0`
					Wait  6`
				Else
					Call  SetAnimationRate  ( .Actor:Self 00000001 *Fixed[0.5] )
					Wait  12`		
				EndIf
				Wait  2`
				Call  80269EAC  ( 13`)
				Call  PlaySoundAtActor  ( .Actor:Self 000003ED )	
				Call  SetAnimationRate  ( .Actor:Self 00000001 *Fixed[1.0] )
				Call  SetGoalToTarget   ( .Actor:Self )
				Call  EnemyDamageTarget ( .Actor:Self *Var0 ~Flags:DamageType:0 00000000 00000000 10` 00000020 )		
			Case == 2`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimSlap2 )	%Only one timing for this one
				Wait  14`	
				Call  PlaySoundAtActor  ( .Actor:Self 000003EE )	
				Call  PlaySoundAtActor  ( .Actor:Self 000003ED )
				Call  80269EAC  ( 13`)
				Call  SetAnimationRate  ( .Actor:Self 00000001 *Fixed[1.0] )
				Call  SetGoalToTarget   ( .Actor:Self )
				Call  EnemyDamageTarget ( .Actor:Self *Var0 ~Flags:DamageType:0 00000000 00000000 11` 00000020 )
		EndSwitch
  468:  Switch  *Var0 
  474:  	CaseOR  ==  .HitResult:Hit % 0
  480:  	CaseOR  ==  .HitResult:QuakeImmune % 2
  4B8:  		Call  UseBattleCamPreset    ( 00000002 )
  4C8:  		Wait  10`
				Call     RandInt     	( 1` *VarC )
				If   *VarC == 0`
					Call  SetAnimation      ( .Actor:Self 00000001 .AnimLaugh )
					Call  PlaySoundAtActor  ( .Actor:Self 0000205E )
					Wait  30`
				EndIf
  4E0:  		SetConst  *Var0  00000001 
  4F0:  		SetConst  *Var1  .AnimRun 
  500:  		ExecWait  DoReturnHome 
  50C:  	EndCaseGroup
  514:  EndSwitch
		Return
		End
}




