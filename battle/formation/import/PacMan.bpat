.Status:SleepTurnMod     -1`
.Status:PoisonTurnMod     0`
.Status:FrozenTurnMod     0`
.Status:DizzyTurnMod     -2`
.Status:FearTurnMod       0`
.Status:StaticTurnMod     0`
.Status:ParalyzeTurnMod  -2`
.Status:ShrinkTurnMod    -1`
.Status:StopTurnMod      -2`
.Status:End
}


#new:Script $Script_HandleEvent_PacMan {
    0:  Call  UseIdleAnimation  ( .Actor:Self .False )
   14:  Call  EnableIdleScript  ( .Actor:Self 00000000 )
   28:  Call  GetLastEvent      ( .Actor:Self *Var0 )
   3C:  Switch  *Var0 
   48:  	CaseOR  ==  .Event:HitCombo % 9
   54:  	CaseOR  ==  .Event:Hit % A
   60:  		SetConst  *Var0  00000001 
   70:  		SetConst  *Var1  .AnimDamage
   80:  		ExecWait  DoNormalHit 
   8C:  	EndCaseGroup
   94:  	Case  ==  .Event:BurnHit % E
   A0:  		SetConst  *Var0  00000001 
   B0:  		SetConst  *Var1  .AnimDamage
   C0:  		SetConst  *Var2  .AnimDamage
   D0:  		ExecWait  DoBurnHit 
   DC:  	Case  ==  .Event:BurnDeath % 24
   E8:  		SetConst  *Var0  00000001 
   F8:  		SetConst  *Var1  .AnimDamage
  108:  		SetConst  *Var2  .AnimDamage
  118:  		ExecWait  DoBurnHit 
  124:  		SetConst  *Var0  00000001 
  134:  		SetConst  *Var1  .AnimDamage
  144:  		ExecWait  DoDeath 
  150:  		Return
  158:  	Case  ==  .Event:SpinSmashHit % B
  164:  		SetConst  *Var0  00000001 
  174:  		SetConst  *Var1  .AnimDamage
  184:  		ExecWait  DoSpinSmashHit 
  190:  	Case  ==  .Event:SpinSmashDeath % 21
  19C:  		SetConst  *Var0  00000001 
  1AC:  		SetConst  *Var1  .AnimDamage
  1BC:  		ExecWait  DoSpinSmashHit 
  1C8:  		SetConst  *Var0  00000001 
  1D8:  		SetConst  *Var1  .AnimDamage
  1E8:  		ExecWait  DoDeath 
  1F4:  		Return
  1FC:  	Case  ==  .Event:ShockHit % 2F
  208:  		SetConst  *Var0  00000001 
  218:  		SetConst  *Var1  .AnimScaredFlying
  228:  		ExecWait  DoShockHit 
  234:  		SetConst  *Var0  00000001 
  244:  		SetConst  *Var1  .AnimScaredFlying
  254:  		ExecWait  DoJumpBack 
				Call  SetActorYaw   ( .Actor:Self  180` )
  330:  		SetConst  *Var0  00000001 
  340:  		SetConst  *Var1  .AnimScaredRun 
  280:  		ExecWait  DoReturnHome 
				%If Pac-Man hasn't finished taking all his turns yet, execute take turn script again
				
				Call  SetActorYaw   ( .Actor:Self  0` )
				ExecWait  $DecrementTurns
				Call  GetActorVar   ( .Actor:Self .AttackTurns *Var0 )
				If  *Var0 != 0`
					Call  UseIdleAnimation  ( .Actor:Self .False )
					Call  EnableIdleScript  ( .Actor:Self 00000000 )
					ExecWait $PacManAttack
					Return
				EndIf
				
				%If he's taken all his turns, randomize idle animation like normal
				
				ExecWait  $RandomizeIdleAnim
  28C:  	Case  ==  .Event:ShockDeath % 26
  298:  		SetConst  *Var0  00000001 
  2A8:  		SetConst  *Var1  .AnimDamage
  2B8:  		ExecWait  DoShockHit 
  2C4:  		SetConst  *Var0  00000001 
  2D4:  		SetConst  *Var1  .AnimDamage
  2E4:  		ExecWait  DoDeath 
  2F0:  		Return
  2F8:  	CaseOR  ==  00000017 % 17
  304:  	CaseOR  ==  .Event:Immune % 19
  310:  	CaseOR  ==  .Event:AirLiftFailed % 1F
  31C:  		SetConst  *Var0  00000001 
  32C:  		SetConst  *Var1  .AnimStop
  33C:  		ExecWait  DoImmune 
  348:  	EndCaseGroup
  350:  	Case  ==  .Event:Death % 20
  35C:  		SetConst  *Var0  00000001 
  36C:  		SetConst  *Var1  .AnimDamage
  37C:  		ExecWait  DoNormalHit 
  388:  		Wait  10`
  394:  		SetConst  *Var0  00000001 
  3A4:  		SetConst  *Var1  .AnimDamage 
  3B4:  		ExecWait  DoDeath 
  3C0:  		Return
  3C8:  	Case  ==  .Event:RecoverStatus % 31
  3D4:  		SetConst  *Var0  00000001 
  3E4:  		SetConst  *Var1  .AnimStop 
  3F4:  		ExecWait  DoRecover 
  400:  	Case  ==  .Event:ScareAway % 39
  40C:  		SetConst  *Var0  00000001 
  41C:  		SetConst  *Var1  .AnimDamage 
  42C:  		SetConst  *Var2  .AnimScaredRun
  43C:  		ExecWait  DoScareAway 
  448:  		Return
  450:  	Case  ==  .Event:BeginAirLift % 3A
  45C:  		SetConst  *Var0  00000001 
  46C:  		SetConst  *Var1  .AnimScaredRun
  47C:  		ExecWait  DoAirLift 
  488:  	Case  ==  .Event:BlowAway % 16
  494:  		SetConst  *Var0  00000001 
  4A4:  		SetConst  *Var1  .AnimScaredRun
  4B4:  		ExecWait  DoBlowAway 
  4C0:  		Return
  4C8:  	Default
  4D0:  EndSwitch
  4D8:  Call  EnableIdleScript  ( .Actor:Self 00000001 )
  4EC:  Call  UseIdleAnimation  ( .Actor:Self .True )
  500:  Return
  508:  End
}


#new:Script 	$RandomizeIdleAnim
{
				Call     RandInt     	( 3` *Var9 )
				Switch *Var9
					Case == 0`
						Call  SetIdleAnimations ( .Actor:Self 00000001 $IdleAnimations_PacManNormal )
					Case == 1`
						Call  SetIdleAnimations ( .Actor:Self 00000001 $IdleAnimations_PacMan2 )
					Case == 2`
						Call  SetIdleAnimations ( .Actor:Self 00000001 $IdleAnimations_PacMan3 )
					Case == 3`
						Call  SetIdleAnimations ( .Actor:Self 00000001 $IdleAnimations_PacMan4 )
				EndSwitch
		  51C:  Call  EnableIdleScript  ( .Actor:Self 00000001 )
		  530:  Call  UseIdleAnimation  ( .Actor:Self .True )
				Return
				End
}