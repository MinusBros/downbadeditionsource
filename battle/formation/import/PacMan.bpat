#new:Script $RunAndJump
{
    0:  Call  UseIdleAnimation  ( .Actor:Self .False )
   14:  Call  EnableIdleScript  ( .Actor:Self 00000000 )
  584:  Call  SetGoalToTarget   ( .Actor:Self )
		Call  SetAnimation  ( .Actor:Self 00000001 .AnimRun )
		Wait  3`
		Call     RandInt     	( 1` *VarC )
		If   *VarC == 0`
			Call  SetActorSpeed     ( .Actor:Self *Fixed[12.0] )
		Else
			Call  SetActorSpeed     ( .Actor:Self *Fixed[8.0] )
		EndIf
		Call  AddGoalPos    ( .Actor:Self  30`  0`  0` )
  14C:  Call  SetGoalToTarget   ( .Actor:Self )
  1C8:  Call  RunToGoal     ( .Actor:Self  0` .False )
  20C:  Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:0 00000000 00000001 00000010 )
  230:  Switch  *Var0 
  23C:  	CaseOR  ==  .HitResult:Miss % 6
  248:  	CaseOR  ==  .HitResult:Lucky % 5
  254:  		Set   *VarA  *Var0 
  2F0:  		Call  UseBattleCamPreset    ( 00000002 )
  300:  		Call  SetActorYaw   ( .Actor:Self  180` )
  314:  		Call  AddActorDecoration    ( .Actor:Self 00000001 00000000 .Decoration:Sweat )
  330:  		SetConst  *Var0  00000001 
  340:  		SetConst  *Var1  .AnimScaredRun 
  350:  		ExecWait  DoReturnHome 
  35C:  		Call  RemoveActorDecoration ( .Actor:Self 00000001 00000000 )
  374:  		Call  SetActorYaw   ( .Actor:Self  0` )
  388:  		Call  EnableIdleScript      ( .Actor:Self 00000001 )
  39C:  		Call  UseIdleAnimation      ( .Actor:Self .True )
  3B0:  		Return
  3B8:  	EndCaseGroup
  3C0:  EndSwitch	
		Call  SetGoalToTarget       ( .Actor:Self )
		Call  GetActorPos   ( .Actor:Self *Var0 *Var1 *Var2 )
		Set   *Var1 0`
		Call  SetAnimation  ( .Actor:Self 00000001 .AnimJump )
		Call  PlaySoundAtActor  ( .Actor:Self 000020DA )
		Call  JumpToGoal    ( .Actor:Self  24` .False .True .False )
		Call  SetActorJumpGravity   ( .Actor:Self *Fixed[1.2] )
  5A0:  Call  GetStatusFlags    ( .Actor:Self *Var5 )
  5B4:  If  *Var5  !&  ~Flags:StatusFlags:Shrink % 80000
  5C4:  	Call  80269EAC  ( 24`)
  5D4:  	Call  PlaySoundAtActor  ( .Actor:Self 000020EA )
  5E8:  EndIf
  424:  Wait  2`
  440:  Call  EnemyDamageTarget ( .Actor:Self *Var0 ~Flags:DamageType:0 00000000 00000000 13` 00000020 )
  468:  Switch  *Var0 
  474:  	CaseOR  ==  .HitResult:Hit % 0
  480:  	CaseOR  ==  .HitResult:QuakeImmune % 2
				Wait  2`
				Call  SetAnimation  ( .Actor:Self 00000001 .AnimLand )
  C90:  		Wait  8`
  4E0:  		SetConst  *Var0  00000001 
  4F0:  		SetConst  *Var1  .AnimRun 
  500:  		ExecWait  DoReturnHome 
  50C:  	EndCaseGroup
  514:  EndSwitch
		Wait  5`
		Return
		End
}


#new:Script  $LookLook
{
	Thread
		Loop  2`
			Call  PlaySoundAtActor  ( .Actor:Self 000003DA )  %Look!
			Wait  15`
		EndLoop
	EndThread
	Thread
	Call     RandInt     	( 4` *VarB )
		Switch   *VarB
			Case == 2`
				Wait  15`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimPoint )
			Case == 3`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimLookAround )	
		EndSwitch
	EndThread
	Call  SetAnimation      ( .Actor:Self 00000002 .AnimIdle )
	Call  SetAnimation      ( .Actor:Self 00000002 .AnimLookLook )
	Call  GetActorPos       ( .Actor:Self *Var0 *Var1 *Var2 )
	Sub  *Var0 20`
	Add  *Var1 80`
	Call  SetPartPos        ( .Actor:Self 00000002 *Var0 *Var1 *Var2 )
	Call  SetPartFlagBits   ( .Actor:Self 00000002 00000001 .False )	
	Wait  40`
	Return
	End
}

#new:Script  $RandomizeWalkCycle
{
		Call     RandInt     	( 4` *VarC )
		Switch   *VarC
			Case == 0`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimSmugWalk )
				Call  SetActorSpeed     ( .Actor:Self *Fixed[3.0] )
			Case == 1`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimWalk )
				Call  SetActorSpeed     ( .Actor:Self *Fixed[4.0] )
			Case == 2`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimProudWalk )
				Call  SetActorSpeed     ( .Actor:Self *Fixed[5.0] )
			Case == 3`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimSadWalk )
				Call  SetActorSpeed     ( .Actor:Self *Fixed[2.0] )				
			Case == 4`
				Call  SetAnimation      ( .Actor:Self 00000001 .AnimRun )
				Call  SetActorSpeed     ( .Actor:Self *Fixed[6.0] )		
		EndSwitch
		Return
		End
}


