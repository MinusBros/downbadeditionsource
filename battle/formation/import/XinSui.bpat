  1A8:  				SetConst  *Var[1]  007E0201 
  1B8:  			Case  ==  00000001 
  1C4:  				SetConst  *Var[0]  00000001 
  1D4:  				SetConst  *Var[1]  007E0204 
  1E4:  		EndSwitch
  1EC:  		ExecWait DoImmune 
  1F8:  	Case  ==  .Event:Immune
