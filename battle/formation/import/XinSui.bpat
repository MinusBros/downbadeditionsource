%If in phase 2 and below 50% HP (in this case half of 66), go for the ultimate attack always

#new:Script $Script_TakeTurn_XinSui
{
   80:  Call     UseIdleAnimation 	( .Actor:Self .False )
    0:  Call  GetActorHP    ( .Actor:Self *Var0 )
   48:  If  *Var0  <  34` 
   6C:  	Call     GetActorVar 	( .Actor:Self 00000006 *Var0 )
			If   *Var0 == 1`
				ExecWait  $Script_XinSuiUltimate
				Return
			EndIf
   78:  EndIf
   94:  Call     GetActorVar 	( .Actor:Self 00000003 *Var[0] )
   AC:  Switch  *Var[0] 
   B8:  	Case  ==  00000000 
				Exec $MoveCamXinSui
   C4:  		Call     ActorSpeak  	( $Turn1 .Actor:Self 00000001 007E0209 007E0209 ) 
   E4:  	Case  ==  00000001 
				Exec $MoveCamXinSui
   F0:  		Call     ActorSpeak  	( $Turn2 .Actor:Self 00000001 007E0209 007E0209 )  
  110:  	Case  ==  00000002
				Exec $MoveCamXinSui
  11C:  		Call     ActorSpeak  	( $Turn3 .Actor:Self 00000001 007E0209 007E0209 )    
  110:  	Case  ==  00000003 
				Exec $MoveCamXinSui
  11C:  		Call     ActorSpeak  	( $Turn4 .Actor:Self 00000001 007E0209 007E0209 )    
  110:  	Case  ==  00000004 
				Exec $MoveCamXinSui
  11C:  		Call     ActorSpeak  	( $Turn5 .Actor:Self 00000001 007E0209 007E0209 )    
  110:  	Case  ==  00000005 
				Exec $MoveCamXinSui
  11C:  		Call     ActorSpeak  	( $Turn6 .Actor:Self 00000001 007E0209 007E0209 )
			Case  ==  00000006
				Exec $MoveCamXinSui
			    Call     ActorSpeak  	( $Turn10 .Actor:Self 00000001 007E0209 007E0209 )
  164:  EndSwitch
Call     GetActorVar 	( .Actor:Self 00000003 *Var[9] ) % Lets get some new attacks up in this joint, this is turn count
Call     GetActorVar 	( .Actor:Self 00000004 *Var[8] ) % What move did I just use?
Switch  *Var[9]
	Case <= 00000001
		ExecWait $Script_XinSuiRegular % First 2 turns will always be the normal monstar attack, getting stronger each turn
	Case == 00000002
		ExecWait $Script_QuickAttack % fast attack
	Case == 00000003
		ExecWait $Script_Multiattack %  multiattack
	Case == 00000004
		ExecWait $Script_XinSuiDebuff
	Case == 00000005
		ExecWait $Script_XinSuiRegular % normal monstar attack, damage = turn #
	Case == 00000006
		ExecWait $Script_QuickAttack %  fast attack
	Case == 00000007
		ExecWait $Script_Multiattack %  multiattack
	Case == 00000008
		ExecWait $Script_XinSuiRegular % normal monstar attack, damage = turn #
	Case == 00000009
		ExecWait $Script_XinSuiDebuff
	Case == 0000000A
		ExecWait $Script_GoInvisible
	Case == 0000000E % turn 15, 14 in hex
		ExecWait $Script_XinSuiRegular
	Case == 00000014
		ExecWait $Script_GoInvisible
	Default
		Switch *Var[8]
			Case == 0`
				ExecWait $Script_XinSuiRegular
				Call     SetActorVar 	( .Actor:Self 00000004 00000001 )
			Case == 1`
				ExecWait $Script_QuickAttack
				Call     SetActorVar 	( .Actor:Self 00000004 00000002 )
			Case == 2`
				ExecWait $Script_Multiattack
				Call     SetActorVar 	( .Actor:Self 00000004 00000000 )
		EndSwitch
EndSwitch
  16C:  Call     AddActorVar 	( .Actor:Self 00000003 00000001 )
  184:  Call     UseIdleAnimation 	( .Actor:Self .True )
  	ExecWait	$Script_UpdateDefenseTable
  1B8:  Return
  1C0:  End
}


