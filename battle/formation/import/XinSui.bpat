#new:Script $Script_8021B898DISASTAR
{
    0:  Call     SetAnimation 	( .Actor:Self *Var[0] *Var[1] )
   18:  Call     80269E80 ( *Var[3] )
   28:  Switch  *Var[3] 
   34:  	Case  ==  00000009 
   40:  		Call     GetOriginalActorType 	( .Actor:Self *Var[7] )
   54:  		Switch  *Var[7] 
   60:  			CaseOR  ==  00000012 
   6C:  			CaseOR  ==  00000030 
