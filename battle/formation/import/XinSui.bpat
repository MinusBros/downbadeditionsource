#new:Script $Script_UpdateDefenseTable
{
   94:  Call     GetActorVar 	( .Actor:Self 00000003 *Var[1] )
	Switch	*Var[1]
			Case  ==  00000000
				Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_0 )
				Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_0 )
			Case  ==  00000001
				Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_1 )
				Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_1 )
			Case  ==  00000002
				Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_2 )			
				Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_2 )			
			Case  ==  00000003
				Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_3 )			
				Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_3 )			
			Case  ==  00000004
				Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_4 )			
				Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_4 )			
			Case  ==  00000005
				Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_5 )
				Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_5 )
			Case  ==  00000006
				Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_6 )
				Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_6 )				
			Default
				Call     GetActorVar 	( .Actor:Self 00000006 *Var5 )
				If      *Var5 > 0`
					Call     SetDefenseTable 	( .Actor:Enemy0 00000001 $DefenseTable_0 )
					Call     SetDefenseTable 	( .Actor:Enemy0 00000002 $DefenseTable_0 )
					Thread
						Call  ActorSpeak        ( 001F00D1 .Actor:Enemy0 00000001 FFFFFFFF FFFFFFFF )  %Defence is now 0!
					EndThread
				EndIf
		EndSwitch
  Return
  End
}
  
