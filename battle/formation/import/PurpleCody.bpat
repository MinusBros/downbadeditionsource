    		Wait     00000001 
    		Call     SetActorScale 	( *Var8 *Fixed[1.2001953] *Fixed[0.9003906] *Fixed[1.0] )
    		Wait     00000001 
    		Call     SetActorScale 	( *Var8 *Fixed[1.1005859] *Fixed[0.9501953] *Fixed[1.0] )
    		Wait     00000001 
    	EndLoop
    	Call     SetActorScale 	( *Var8 *Fixed[1.0] *Fixed[1.0] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[1.1005859] *Fixed[1.0] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[1.2001953] *Fixed[0.9501953] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[1.3007812] *Fixed[0.9003906] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[1.3505859] *Fixed[0.85058594] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[1.3808594] *Fixed[0.80078125] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[1.4003906] *Fixed[0.80078125] *Fixed[1.0] )
    	Wait     00000001 
    	Call     PlaySoundAtActor 	( *Var8 0000208E )
    	Call     SetActorScale 	( *Var8 *Fixed[0.9003906] *Fixed[1.3007812] *Fixed[1.0] )
		Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[0.9003906] *Fixed[1.2001953] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[0.9501953] *Fixed[1.1005859] *Fixed[1.0] )
    	Wait     00000001 
    	Call     SetActorScale 	( *Var8 *Fixed[1.0] *Fixed[1.0] *Fixed[1.0] )
    	Wait     00000001 
    EndThread
	Call	 GetActorPos	( *Var8 *Var[0] *Var[1] *Var[2] )
    Loop     00000009 
    	Call     PlaySoundAtActor 	( *Var8 00000369 )
    	Call     PlayEffect  	( ~FX:Steam:TinyOutward *Var[0] *Var[1] *Var[2] 00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000000 )
    	Call     PlayEffect  	( ~FX:Steam:SmallOutward *Var[0] *Var[1] *Var[2] 00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000000 )
		Wait     00000004 
	EndLoop
	Call  $HustleTarget		( *Var8 00000001 )
		Wait  8`
		Call	$ShowCustomMessage	( 001F0068 20` ) 
	Wait     18` 
	Return
	End
}


