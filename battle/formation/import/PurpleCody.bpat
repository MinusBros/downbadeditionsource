  890:  			If  *Var3  &  ~Flags:StatusFlags:Shrink % 80000
  8A0:  				Sub   *Var0  00000008 
  8B0:  				Add   *Var1  00000008 
  8C0:  			Else
  8C8:  				Sub   *Var0  00000014 
  8D8:  				Add   *Var1  00000014 
  8E8:  			EndIf
  920:  		Wait  50`
  92C:  		If  *Var9  ==  .HitResult:Lucky % 5
  93C:  			Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:TriggerLucky 00000000 00000000 00000000 )
  960:  		EndIf
  968:  		Wait  15`
  980:  		Call  UseIdleAnimation  ( .Actor:Self .True )
  9C0:  		Return
  9C8:  	EndCaseGroup
  9D0:  EndSwitch
  A04:  Call  PlaySoundAtActor  ( .Actor:Self 000003AB )
  A58:  	Call  SetAnimation  ( .Actor:Self 00000001 00560803 )
  AC8:  Wait  5`
  1CC:  Call  SetGoalToTarget   ( .Actor:Self )
  1DC:  Call  GetGoalPos    ( .Actor:Self *Var0 *Var1 *Var2 )
  BA8:  	Call  GetStatusFlags    ( .Actor:Self *Var3 )
  20C:  If  *VarA  &  ~Flags:StatusFlags:Shrink % 80000
  21C:  	Add   *Var0  0000000B 
  22C:  	Set   *Var1  00000005 
  23C:  	SetF  *Var3  *Fixed[0.6] 
  24C:  Else
  254:  	Add   *Var0  00000016 
  264:  	Set   *Var1  0000000D 
  274:  	SetF  *Var3  *Fixed[1.2] 
  284:  EndIf
  C1C:  	Call  $Function_PoisonCloud ( *Var2 *Var0 *Var1 *Var2 *Var3 0000001E 00000078 00000000 00000078 )
  D88:  Wait  17`
  DEC:  	Call  EnemyDamageTarget ( .Actor:Self *Var0 ~Flags:DamageType:0 0000FFFF ~DebuffType:Poison:5:100` 0000000A 00000020 )
  E1C:  Switch  *Var0 
  E28:  	CaseOR  ==  .HitResult:Hit % 0
  E34:  	CaseOR  ==  .HitResult:QuakeImmune % 2
  E40:  		Wait  10`
  E58:  	EndCaseGroup
  E60:  EndSwitch
  E68:  Call  UseIdleAnimation  ( .Actor:Self .True )
  EA8:  Return
  EB0:  End
}

