%Problem: blocking in a certain combination will crash the game (particle overflow?)

#new:Script $Script_BooCannon	
{
	Call     SetTargetActor ( .Actor:Self .Actor:Player )
	Call     UseIdleAnimation 	( .Actor:Self .False )
    Call     EnableIdleScript 	( .Actor:Self 00000000 )
	Call     SetAnimation 		( .Actor:Self 00000001 00F30003 )
	Set *Flag[01] 1 %flag for entering state 2
	Call	GetPlayerHP ( *Var[F] )
	Loop 4`
		Thread
			Call     SummonEnemy		( $BooFormation 00000000 )
			Set *Var[1] *Var[0]
			Call	 GetActorPos		( .Actor:Self *Var[A] *Var[B] *Var[C] )
			Sub *Var[A] 5`
			Add *Var[B] 45`
			Add *Var[C] 15`
			Call	 SetActorPos 		( *Var[1] *Var[A] *Var[B] *Var[C] )
			Call     UseIdleAnimation 	( *Var[1] .False )
			Call     EnableIdleScript 	( *Var[1] 00000000 )
			Call	 SetAnimation 		( *Var[1] 00000001 00950510 )
			Call     SetTargetActor ( *Var[1] .Actor:Player )
			Call     SetGoalToTarget 	( *Var[1] )
			Call     SetActorSpeed     	( *Var[1] *Fixed[18.0] ) %12 -> 18
			Call     SetActorJumpGravity 	( *Var[1] *Fixed[1.0] )
			Call     JumpToGoal      	( *Var[1] 0000000A 00000000 00000001 00000000 ) 
			Wait 	 2`
			Call	EnemyTestTarget ( .Actor:Self  *Var[5] 00000000 00000000 00000001 00000010 )
			Switch  *Var[5] 
				CaseOR  ==  00000006 
				CaseOR  ==  00000005 % lucky, transparent
				Set *Flag[01] 0
				Goto 00000001
			EndSwitch
				Call     EnemyDamageTarget 	( *Var[1] *Var[8] 10000000 00000000 00000000 00000005 00000020 )
			Wait     1`
			% Go off-screen
			Label 00000001
			Call     SetGoalPos		( *Var[1] -300` 0` 0` )
			Call     SetActorJumpGravity 	( *Var[1] *Fixed[1.0] )
			Call     JumpToGoal    		( *Var[1] 0000000A 00000000 00000001 00000000 )
			Wait     3`
			Call     RemoveActor 	( *Var[1] )
		EndThread
		Thread
			Wait 	 10`
			Call     SummonEnemy		( $BooFormation 00000000 )
			Set *Var[2] *Var[0]
			Call	 GetActorPos		( .Actor:Self *Var[A] *Var[B] *Var[C] )
			Sub *Var[A] 5`
			Add *Var[B] 45`
			Add *Var[C] 15`
			Call	 SetActorPos 		( *Var[2] *Var[A] *Var[B] *Var[C] )			
			Call     UseIdleAnimation 	( *Var[2] .False )
			Call     EnableIdleScript 	( *Var[2] 00000000 )
			Call	 SetAnimation 		( *Var[2] 00000001 00950510 )
			Call     SetTargetActor ( *Var[2] .Actor:Player )
			Call     SetGoalToTarget 	( *Var[2] )
			Call     SetActorSpeed     	( *Var[2] *Fixed[30.0] ) %20 -> 30
			Call     SetActorJumpGravity 	( *Var[2] *Fixed[0.2] )
			Call     JumpToGoal      	( *Var[2] 0000000A 00000000 00000001 00000000 ) 
			Wait 	 2`
			Call	EnemyTestTarget ( .Actor:Self  *Var[5] 00000000 00000000 00000001 00000010 )
			Switch  *Var[5] 
				CaseOR  ==  00000006 
				CaseOR  ==  00000005 % lucky, transparent
				Set *Flag[01] 0
				Goto 00000001
			EndSwitch
				Call     EnemyDamageTarget 	( *Var[2] *Var[8] 10000000 00000000 00000000 00000005 00000020 )
			Wait     1`
			% Go off-screen
			Label 00000001
			Call     SetGoalPos		( *Var[2] -300` 0` 0` )
			Call     SetActorJumpGravity 	( *Var[2] *Fixed[1.0] )
			Call     JumpToGoal    		( *Var[2] 0000000A 00000000 00000001 00000000 )
			Wait     3`
			Call     RemoveActor 	( *Var[2] )
		EndThread
		Wait 25` 
	EndLoop
	Call	GetPlayerHP ( *Var[E] )
	Sub *Var[F] *Var[E] %find HP difference
	If *Var[F] < 4 %took less than 4 damage
		If *Flag[01] == 00000001
			Call SetActorVar (.Actor:Self 00000003 00000002 )
		EndIf
	EndIf
	Call     UseIdleAnimation 	( .Actor:Self .True )
    Call     EnableIdleScript 	( .Actor:Self 00000001 )
	Return
	End
}



#new:Script  $Overdrive
{	
	Call     UseIdleAnimation 	( .Actor:Self .False )
    Call     EnableIdleScript 	( .Actor:Self .False )
	Call     GetActorVar (.Actor:Self 00000008 *Var[3] )
	Switch   *Var3
		Case == 1`
		C:  Call  UseBattleCamPreset    ( 00000013 )
	   1C:  Call  GetActorPos       ( .Actor:Self *Var0 *Var1 *Var2 )
	   38:  Add   *Var1  00000048 
	   48:  Call  SetBattleCamTarget    ( *Var0 *Var1 *Var2 )
	   60:  Call  SetBattleCamZoom  (  340` )
	   70:  Call  MoveBattleCamOver (  20` )
			Wait  30`
			Call	SetIdleAnimations 	( .Actor:Self 00000001 $IdleAnimations_TsarBoo_Charged )
			Call    SetDefenseTable   ( .Actor:Self 00000001 $DefenseTable_Overdrive )
			Call  BindIdle  ( .Actor:Self $Script_Idle_TsarBooOverdrive )
			Call	SetActorVar	( .Actor:Self 00000008 00000002 )	
			Call  8026ED20      ( FFFFFF81 00000001 00000001 )
			Call  8026EBF8      ( FFFFFF81 00000001 00000001 00000000 00000000 00000006 0000000C 00000006 00000000 00000000 )
			Call  8026EA7C      ( FFFFFF81 00000001 0000000F )
		Case == 2`
			Call	SetActorRotation	( .Actor:Self 00000001 00000001 00000001 )
			Call  SetTargetActor    ( .Actor:Self .Actor:Player )
			Call	SetAnimation 	( .Actor:Self 00000001 .AnimTsarSpook )
			SetConst  *Var[0]  00000001 
			SetConst  *Var[1]  .AnimTsarSpook 
			Exec DoDeath
			Wait  1`
			Loop  3`	
				Call  GetActorPos       ( .Actor:Self *Var0 *Var1 *Var2 )
				Wait  8`
				Call  PlaySoundAtActor  ( .Actor:Self .Sound:Cannon3 )
				Call  PlayEffect    ( ~FX:RedImpact:Huge *Var0 00000000 *Var2 00000003 00000009 00000009 00000009 00000009 00000009 00000009 00000009 00000009 )
				Wait  1`
			EndLoop
			Thread
				Wait  8`
				Call  PlaySoundAtActor  ( .Actor:Self .Sound:Cannon3 )
				Call  PlayEffect    ( ~FX:RedImpact:Huge *Var0 00000000 *Var2 00000003 00000009 00000009 00000009 00000009 00000009 00000009 00000009 00000009 )
				Wait  1`
			EndThread
			Call	EnemyTestTarget ( .Actor:Self *Var[0] 10000000 00000000 *Var[1] 00000010 )
			Switch  *Var[0] 
				CaseOR   ==  00000006 
				CaseOR   ==  00000005 
	  3CC:  		If  *VarA  ==  .HitResult:Lucky % 5
	  3DC:  			Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:TriggerLucky 00000000 00000000 00000000 )
	  400:  		EndIf
					Wait  10`
					Thread		
						Wait  20`
						Call  SetMusicTrack ( 00000000 .Song:MailCall 00000001 00000008 )  %Ending stinger
						Wait  202`
						Call  SetMusicTrack ( 00000000 .Song:BossLevelUp 00000001 00000008 )  %In case player levels up
					EndThread
					Return
				EndCaseGroup
			EndSwitch
			Call  SetGoalToTarget   ( .Actor:Self )
			Call  80269EAC  ( 0000001A )
			Call	EnemyDamageTarget 	( .Actor:Self *Var0 ~Flags:DamageType:Blast|Unblockable|NoContact 00000000 00000000 60` 00000020 )
			Thread		
				Wait  15`
				Call  SetMusicTrack ( 00000000 .Song:MailCall 00000001 00000008 )  %Ending stinger
				Wait  202`
				Call  SetMusicTrack ( 00000000 .Song:BossLevelUp 00000001 00000008 )  %In case player levels up
			EndThread
			Return
	EndSwitch
	Call  UseBattleCamPreset    ( 00000002 )
	Call  MoveBattleCamOver (  20` )
	Wait  5`
	Call     UseIdleAnimation 	( .Actor:Self .True )
    Call     EnableIdleScript 	( .Actor:Self .True )
	Return
	End
}

