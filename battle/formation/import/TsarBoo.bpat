%Atomic Boo from Dark Star Edition, with scripts from Master Quest as well

%New Bomb Boo boss fight called Tsar Boo
%Credit to my friend Based Bahamut for the name idea

#define .AnimTsarStop	00F30005
#define .AnimTsarIdle	00F30000
#define .AnimTsarRun	00F30004
#define .AnimTsarPain	00F30001
#define .AnimTsarHide	00F30002
#define .AnimTsarSpook	00F30003
#define .AnimTsarMiss	00F30006

%might add dizzy animation later
#define .AnimTsarDizzy	00F30007
%#define .AnimTsarDead	00950012 %unused?
#define .AnimTsarDead	00F30001


#new:Actor $TsarBoo
{
% stats
[Index]        F8b 
[Level]       105`b 
[MaxHP]       155`b 
[Coins]         0`b 
[Flags]       00000200 
[StatusTable] $StatusTable_TsarBoo 
% ai
[PartsCount]   1`s 
[PartsTable] $PartsTable_TsarBoo 
[Script]      $Script_Init_TsarBoo 
% move effectiveness
[Escape]        0`b %no escape 
[Item]          0`b 
[AirLift]       0`b 
[Hurricane]     0`b % Bow's "Spook" as well
[UpAndAway]     0`b 
[PowerBounce]   3`b 
[SpinSmash]     4`b % weight (0-4)
% ui positions
[Size]        100`b 100`b % width height
[HealthBar]     0`b   0`b % dx dy
[StatusTurn]  -45`b 75`b % dx dy (usually top left)
[StatusIcon]   45`b 75`b % dx dy (usually top right)
}

%regular boo is 48 x 40, atomic boo is (usually) 120 x 108

