  628:  	EndCaseGroup
  630:  EndSwitch
  638:  Call  EnableIdleScript  ( .Actor:Self 00000001 )
  64C:  Call  UseIdleAnimation  ( .Actor:Self .True )
  660:  Return
  668:  End
}


#new:Script $Script_IceBalls {
    0:  Call  UseIdleAnimation  ( .Actor:Self .False )
   14:  Call  EnableIdleScript  ( .Actor:Self 00000000 )
   28:  Call  SetTargetActor    ( .Actor:Self .Actor:Player )
   84:  	Call  UseBattleCamPreset    ( 00000002 )
   94:  	Call  MoveBattleCamOver     (  10` )
   AC:  Call  PlaySoundAtActor  ( .Actor:Self .Sound:SpellCast1 )
   C0:  Call  GetActorPos       ( .Actor:Self *Var0 *Var1 *Var2 )
   DC:  Call  GetStatusFlags    ( .Actor:Self *VarA )
   F0:  If  *VarA  &  ~Flags:StatusFlags:Shrink % 80000
  100:  	Sub   *Var0  0000000C 
  110:  	Add   *Var1  0000000E 
  120:  Else
  128:  	Sub   *Var0  0000001E 
  138:  	Add   *Var1  00000024 
  148:  EndIf
  150:  Call  PlayEffect        ( ~FX:GatherMagic:Pink *Var0 *Var1 *Var2 *Fixed[0.5] 0000001E 00000000 00000000 00000000 00000000 00000000 00000000 00000000 )
  194:  
		Call  SetActorVar   ( .Actor:Self 00000001 00000000 )
		Label IceBalls
		Call  SetAnimation      ( .Actor:Self 00000001 0056050A )
  1AC:  Wait  10`
  1B8:  Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:0 00000000 00000001 00000010 )
  1DC:  Switch  *Var0 
  1E8:  	CaseOR  ==  .HitResult:Miss % 6
  1F4:  	CaseOR  ==  .HitResult:Lucky % 5
  200:  		Set   *VarA  *Var0 
  210:  		Call  PlaySoundAtActor  ( .Actor:Self 00002109 )
  224:  		Call  SetAnimation      ( .Actor:Self 00000001 00560503 )
  23C:  		Wait  5`
  248:  		Call  GetActorPos       ( .Actor:Self *Var0 *Var1 *Var2 )
  264:  		Call  GetStatusFlags    ( .Actor:Self *Var9 )
  278:  		If  *Var9  &  ~Flags:StatusFlags:Shrink % 80000
  288:  			Sub   *Var0  00000008 
  298:  			Add   *Var1  00000008 
  2A8:  		Else
  2B0:  			Sub   *Var0  00000014 
  2C0:  			Add   *Var1  00000014 
  2D0:  		EndIf
  2D8:  		Call  SetGoalToTarget       ( .Actor:Self )
  2E8:  		Call  GetGoalPos    ( .Actor:Self *Var3 *Var4 *Var5 )
  304:  		Sub   *Var3  00000032 
  314:  		Set   *Var4  00000000 
  34C:  		Wait  30`
  358:  		If  *VarA  ==  .HitResult:Lucky % 5
  368:  			Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:TriggerLucky 00000000 00000000 00000000 )
  38C:  		EndIf
  394:  		Wait  14`
  3AC:  		Call  AddActorDecoration    ( .Actor:Self 00000001 00000000 .Decoration:Sweat )
  3C8:  		Wait  30`
  3D4:  		Call  RemoveActorDecoration ( .Actor:Self 00000001 00000000 )
				Goto  AfterIceBall
  414:  		Return
  41C:  	EndCaseGroup
  424:  EndSwitch
  42C:  Call  PlaySoundAtActor  ( .Actor:Self 00002109 )
		%  Throwing magic
		Set   *Var8 00000002
  440:  Call  SetAnimation      ( .Actor:Self 00000001 00560503 )
    Call  GetBattlePhase    ( *Var0 )
    If  *Var0  ==  00000001
      Call  SetPartPos        ( .Actor:Self *Var8 00000000 00000000 00000000 )
      Call  SetPartFlagBits   ( .Actor:Self *Var8 00000001 .False )
      Goto  64
    EndIf
    Call  GetActorPos   ( .Actor:Self *Var0 *Var1 *Var2 )
    Sub   *Var0  00000017 
    Add   *Var1  00000001 
    Sub   *Var2  00000002 
    Call  SetPartPos    ( .Actor:Self *Var8 *Var0 *Var1 *Var2 )
    Wait  6
    Call  SetPartFlagBits   ( .Actor:Self *Var8 00000001 .False )
    Label  64
    Call  GetStatusFlags    ( .Actor:Self *Var0 )
    If  *Var0  &  ~Flags:StatusFlags:Shrink % 80000
      Call  SetPartScale  ( .Actor:Self *Var8 *Fixed[0.4] *Fixed[0.4] *Fixed[0.4] )
    Else
      Call  SetPartScale  ( .Actor:Self *Var8 *Fixed[1.0] *Fixed[1.0] *Fixed[1.0] )
    EndIf
    Call  SetPartSounds     ( .Actor:Self *Var8 .ActorSound:Jump 00000000 00000000 )
    Call  PlaySoundAtPart   ( .Actor:Self *Var8 000002EF )
    Call  SetGoalToTarget   ( .Actor:Self )
    % 1st jump
    Call  GetGoalPos        ( .Actor:Self *Var0 *Var1 *Var2 )
    Call  GetActorPos ( .Actor:Self *Var3 *Var4 .False )
    Call  GetDist2D ( *Var3 *Var0 *Var1 *Var3 *Var4 )
    Div   *Var3 2
    Add   *Var0 *Var3
    Call  SetPartMoveSpeed  ( .Actor:Self *Var8 *Fixed[10.0] )
    Call  SetPartJumpGravity    ( .Actor:Self *Var8 *Fixed[1.0] )
    Call  JumpPartTo ( .Actor:Self *Var8 *Var0 .False *Var2 .False .True )
    % 2nd jump
    Call  GetGoalPos        ( .Actor:Self *Var0 *Var1 *Var2 )
    Call  JumpPartTo ( .Actor:Self *Var8 *Var0 *Var1 *Var2 .False .True )
    Call  EnemyTestTarget   ( .Actor:Self *VarA ~Flags:DamageType:0 00000000 00000001 00000010 )
    Switch  *VarA
      CaseOR  ==  .HitResult:Miss % 6
      CaseOR  ==  .HitResult:Lucky % 5
          If  *VarA  ==  .HitResult:Lucky % 5
              Call  EnemyTestTarget   ( .Actor:Self *VarA ~Flags:DamageType:TriggerLucky 00000000 00000000 00000000 )
          EndIf
      EndCaseGroup
      Default
		  Call  PlaySoundAtPart   ( .Actor:Self *Var8 000002E0 )
          Call  EnemyDamageTarget ( .Actor:Self *Var0 ~Flags:DamageType:NoContact|Magic|Ice 00000000 00000000 00000007 00000020 )
    EndSwitch
		Call  SetPartFlagBits   ( .Actor:Self *Var8 00000001 .True )
		Label  AfterIceBall
		Call  AddActorVar   ( .Actor:Self 00000001 1` )
		Call  GetActorVar   ( .Actor:Self 00000001 *Var0 )
		If    *Var0  != 3`
			Goto  IceBalls
		EndIf
  598:  Switch  *Var0 
  5A4:  	CaseOR  ==  .HitResult:Hit % 0
  5B0:  	CaseOR  ==  .HitResult:QuakeImmune % 2
  5BC:  		Wait  19`
  5D4:  	EndCaseGroup
  5DC:  EndSwitch
  5E4:  Call  EnableIdleScript  ( .Actor:Self 00000001 )
  5F8:  Call  UseIdleAnimation  ( .Actor:Self .True )
  60C:  Return
  614:  End
}





