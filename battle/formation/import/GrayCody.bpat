   C4:  		Sub   *Var0  0000000A 
   D4:  		Call  SetPartAlpha  ( .Actor:Self 00000001 *Var0 )
   EC:  		Wait  1`
   F8:  	EndLoop
		Wait  20`
		Call  PlaySoundAtActor  ( .Actor:Self 000002DC )
		Wait  10`
		Call  EnemyDamageTarget ( .Actor:Self *Var0 ~Flags:DamageType:NoContact 00000000 00004364 00000005 00000020 )
		Wait  15`
  4D0:  Switch  *Var0 
  4DC:  	CaseOR  ==  .HitResult:Hit % 0
  4E8:  	CaseOR  ==  .HitResult:QuakeImmune % 2
  4F4:  		Call  UseBattleCamPreset    ( 00000002 )
