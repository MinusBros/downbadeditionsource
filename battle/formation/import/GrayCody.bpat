  5B8:  		Set   *Var0  00000037 
  5C8:  		Loop  00000014 
  5D4:  			Add   *Var0  0000000A 
  5E4:  			Call  SetPartAlpha  ( .Actor:Self 00000001 *Var0 )
  5FC:  			Wait  1`
  608:  		EndLoop
