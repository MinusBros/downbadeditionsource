#new:Script  $HealBuff
{
    Call  UseBattleCamPreset    ( 0000000E )
    Call  BattleCamTargetActor  ( .Actor:Self )
    Call  MoveBattleCamOver (  16` )
	Call  SetAnimation  ( .Actor:Self 00000001 00870411 )  %Grab cross
	Wait  6`
	Call  SetAnimationRate      ( .Actor:Self 00000001 *Fixed[1.75] )
	Call  PlaySoundAtActor  ( *Var8 000002DD )
	Thread
		Call	8026BF48 ( 00000001 )
		Call	BoostAttack  ( .Actor:Self 00000001 )
		Call	8026BF48 ( 00000000 )
	EndThread
	Thread
		Wait    30`
		Call	8026BF48 ( 00000001 )
		Call	BoostDefense  ( .Actor:Self 00000001 )
		Call	8026BF48 ( 00000000 )
	EndThread
	Thread
		Call	8026BF48	( 00000001 )
		Call    HealActor 	( .Actor:Self 10` 00000000 )
		Call	8026BF48	( 00000000 )
	EndThread
	Call  WaitForBuffDone ( )
	Wait  6`
	Call  SetAnimation  ( .Actor:Self 00000001 00870412 )  %Grab cross
	Wait  6`
	Return
	End
}





#new:Script $Script_HandleEvent_Priest {
    0:  Call  UseIdleAnimation  ( .Actor:Self .False )
   14:  Call  GetLastEvent      ( .Actor:Self *Var0 )
   28:  Switch  *Var0 
   34:  	CaseOR  ==  .Event:HitCombo % 9
   40:  	CaseOR  ==  .Event:Hit % A
   4C:  		SetConst  *Var0  00000001 
   5C:  		SetConst  *Var1  00870409 
   6C:  		ExecWait  DoNormalHit 
   78:  	EndCaseGroup
   80:  	Case  ==  .Event:BurnHit % E
   8C:  		SetConst  *Var0  00000001 
   9C:  		SetConst  *Var1  00870909 
   AC:  		SetConst  *Var2  00870909 
   BC:  		ExecWait  DoBurnHit 
   C8:  	Case  ==  .Event:BurnDeath % 24
   D4:  		SetConst  *Var0  00000001 
   E4:  		SetConst  *Var1  00870909 
   F4:  		SetConst  *Var2  00870909 
  104:  		ExecWait  DoBurnHit 
  110:  		SetConst  *Var0  00000001 
  120:  		SetConst  *Var1  00870413 
				ExecWait  $PriestDeath 
  13C:  		Return
  144:  	Case  ==  .Event:SpinSmashHit % B
  150:  		SetConst  *Var0  00000001 
  160:  		SetConst  *Var1  00870409 
  170:  		ExecWait  DoSpinSmashHit 
  17C:  	Case  ==  .Event:SpinSmashDeath % 21
  188:  		SetConst  *Var0  00000001 
  198:  		SetConst  *Var1  00870409 
  1A8:  		ExecWait  DoSpinSmashHit 
  1B4:  		SetConst  *Var0  00000001 
  1C4:  		SetConst  *Var1  00870413 
				ExecWait  $PriestDeath
  1E0:  		Return
  1E8:  	Case  ==  .Event:ShockHit % 2F
  1F4:  		SetConst  *Var0  00000001 
  204:  		SetConst  *Var1  00870409 
  214:  		ExecWait  DoShockHit 
  220:  		SetConst  *Var0  00000001 
  230:  		SetConst  *Var1  00870409 
  240:  		ExecWait  DoJumpBack 
  24C:  		Call  SetActorSpeed ( .Actor:Self *Fixed[8.0] )
  26C:  	Case  ==  .Event:ShockDeath % 26
  278:  		SetConst  *Var0  00000001 
  288:  		SetConst  *Var1  00870409 
  298:  		ExecWait  DoShockHit 
  2A4:  		SetConst  *Var0  00000001 
  2B4:  		SetConst  *Var1  00870413 
				ExecWait  $PriestDeath
  2D0:  		Return
  2D8:  	CaseOR  ==  00000017 % 17
  2E4:  	CaseOR  ==  .Event:Immune % 19
  2F0:  	CaseOR  ==  .Event:AirLiftFailed % 1F
  2FC:  		SetConst  *Var0  00000001 
  30C:  		SetConst  *Var1  0087040D 
  31C:  		ExecWait  DoImmune 
				Call  GetActorVar   ( .Actor:Self 00000001 *Var0 )
				If    *Var0 == 0`
					Call  SetActorVar   ( .Actor:Self 00000001 1` )
					Wait  5`
					Call  ActorSpeak        ( 000B0124 .Actor:Self 00000001 00870408 00870405 )
					Call  SetAnimationRate      ( .Actor:Self 00000001 *Fixed[1.0] )
				EndIf
  328:  	EndCaseGroup
  330:  	Case  ==  .Event:Death % 20
  33C:  		SetConst  *Var0  00000001 
  34C:  		SetConst  *Var1  00870409 
  35C:  		ExecWait  DoNormalHit 
  368:  		Wait  10`
  374:  		SetConst  *Var0  00000001 
  384:  		SetConst  *Var1  00870414 
				ExecWait  $PriestDeath
  3A0:  		Return
  3A8:  	Case  ==  .Event:RecoverStatus % 31
  3B4:  		SetConst  *Var0  00000001 
  3C4:  		SetConst  *Var1  00870405 
  3D4:  		ExecWait  DoRecover 
  3E0:  	Case  ==  .Event:ScareAway % 39
  2FC:  		SetConst  *Var0  00000001 
  30C:  		SetConst  *Var1  0087040D 
  31C:  		ExecWait  DoImmune 
				Call  GetActorVar   ( .Actor:Self 00000001 *Var0 )
				If    *Var0 == 0`
					Call  SetActorVar   ( .Actor:Self 00000001 1` )
					Wait  5`
					Call  ActorSpeak        ( 000B0124 .Actor:Self 00000001 00870408 00870405 )
				EndIf
  430:  	Case  ==  .Event:BeginAirLift % 3A
  43C:  		SetConst  *Var0  00000001 
  44C:  		SetConst  *Var1  00870409 
  45C:  		ExecWait  DoAirLift 
  468:  	Case  ==  .Event:BlowAway % 16
  474:  		SetConst  *Var0  00000001 
  484:  		SetConst  *Var1  00870411
  494:  		ExecWait  DoBlowAway 
  4A0:  		Return
  4A8:  	Default
  4B0:  EndSwitch
  4B8:  Call  UseIdleAnimation  ( .Actor:Self .True )
  4CC:  Return
  4D4:  End
}


#new:Script $PriestDeath
{
			Thread	
				Wait  10`
				Call  SetMusicTrack ( 00000000 .Song:IllusionaryDance 00000001 00000008 )  %Ending stinger
				Wait  218`
				Call  SetMusicTrack ( 00000000 .Song:BossLevelUp 00000001 00000008 )  %In case player levels up
			EndThread
			Wait  18`
			Call  DropStarPoints    ( .Actor:Self )
			Call  SetAnimation      ( .Actor:Self 00000001 00870413 )
			Wait  1`
			Call  SetActorFlagBits  ( .Actor:Self 00660000 .True ) %Skip turn, no target, no health bar
			Call  SetPartFlagBits   ( .Actor:Self 00000001 00020000 .True )
			Return
			End
}

