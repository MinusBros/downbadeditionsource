		Return
		End
}

#new:Script $Script_TakeTurn_Priest {
		Call UseIdleAnimation  ( .Actor:Self .False )
		Call EnableIdleScript  ( .Actor:Self .False )
		Call  SetMusicTrack ( 00000000 .Song:IllusionaryDance 00000000 00000008 )
		Call  GetActorVar   ( .Actor:Self 00000001 *Var0 )
		Switch *Var0
			Case == 0`
				ExecWait  $XBoomerang
				Call  AddActorVar   ( .Actor:Self 1` 1` )
			Case == 1`
				ExecWait  $HolyBreaker
				Call  AddActorVar   ( .Actor:Self 1` 1` )
			Case == 2`
				ExecWait  $Lightning
				Call  AddActorVar   ( .Actor:Self 1` 1` )
			Case == 3`
				Call     RandInt     	( 2` *VarC )
				If  *VarC == 0`
					ExecWait  $HolyBreaker
				Else
					ExecWait  $XBoomerang
				EndIf	
				Call  AddActorVar   ( .Actor:Self 1` 1` )
			Case == 4`
				Call     RandInt     	( 2` *VarC )
				If  *VarC == 0`
					ExecWait  $XBoomerang
				Else
					ExecWait  $HolyBreaker
				EndIf	
				Call  AddActorVar   ( .Actor:Self 1` 1` )	
			Case == 5`
				ExecWait  $Lightning
				Call  SetActorVar   ( .Actor:Self 1` 0` )   %Reset pattern
		EndSwitch
		Wait  2`
  228:  Call  GetActorHP    ( .Actor:Self *Var0 )
  23C:  Call  GetEnemyMaxHP ( .Actor:Self *Var1 )
  250:  Mul   *Var0  00000064 
  260:  Div   *Var0  *Var1 
  270:  If  *Var0  <  00000032 
			Call  GetActorVar       ( .Actor:Self 4` *Var4 )
   68:  	If  *Var4  !&  00000001 
   78:  		ConstOR  *Var4 00000001 
				Call  SetActorVar       ( .Actor:Self 4` *Var4 )
   A0:  		Call  UseBattleCamPreset    ( 0000000E )
   B0:  		Call  BattleCamTargetActor  ( .Actor:Self )
   C0:  		Call  MoveBattleCamOver (  16` )
				Wait  3`
				Call  ActorSpeak        ( $NotWeak .Actor:Self 00000001 00870414 0087040D )	
				ExecWait $HealBuff
			EndIf
		EndIf	
		Call EnableIdleScript  ( .Actor:Self .True )
		Call UseIdleAnimation  ( .Actor:Self .True )
		Return
		End
}

%A simple lightning strike from the cross.
%If fought in the prologue, it's unblockable.

#new:Script $Lightning
{
		If    *GB_EnemyDefense != 3`
			Exec  $ShowMessage1
		EndIf
		Wait  4`
		Call  SetTargetActor    ( .Actor:Self .Actor:Player )
		Call  SetAnimation  ( .Actor:Self 00000001 0087040B )
   14:  Call  UseBattleCamPreset    ( 0000000D )
   24:  Call  BattleCamTargetActor  ( .Actor:Self )
   44:  Call  UseBattleCamPreset    ( 00000002 )
   54:  Call  MoveBattleCamOver (  30` )
  410:  Call  PlaySoundAtActor  ( .Actor:Self 00002127 )
  424:  Call  SetGoalToTarget   ( .Actor:Self )
		Wait  8`
  434:  Thread
  43C:  	Call  GetGoalPos    ( .Actor:Self *Var0 00000000 *Var1 )
  458:  	Call  $Function_8021CFC0_23 ( *Var0 *Var1 )
  46C:  EndThread
  474:  Call  EnemyTestTarget   ( .Actor:Self *VarA ~Flags:DamageType:0 00000000 00000001 00000010 )
  498:  Switch  *VarA 
  4A4:  	CaseOR  ==  .HitResult:Miss % 6
  4B0:  	CaseOR  ==  .HitResult:Lucky % 5
  4BC:  		Wait  10`
  4C8:  		If  *VarA  ==  .HitResult:Lucky % 5
  4D8:  			Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:TriggerLucky 00000000 00000000 00000000 )
  4FC:  			Wait  20`
  514:  		Else
  51C:  			Wait  20`
  534:  		EndIf
  56C:  		Return
  574:  	EndCaseGroup
  584:  EndSwitch
  58C:  Wait  5`
  598:  Call  SetGoalToTarget   ( .Actor:Self )
		If    *GB_EnemyDefense == 3`
			Call  EnemyDamageTarget ( .Actor:Self *VarF ~Flags:DamageType:NoContact|Unblockable|Electric 00000000 00000000 24` 00000020 )		
		Else
			Call  EnemyDamageTarget ( .Actor:Self *VarF ~Flags:DamageType:NoContact|Electric 00000000 00000000 24` 00000020 )
		EndIf
  650:  Switch  *VarF 
  65C:  	CaseOR  ==  .HitResult:Hit % 0
  668:  	CaseOR  ==  .HitResult:QuakeImmune % 2
  674:  	CaseOR  ==  0000000A % A
  680:  		Wait  30`
  6E8:  	EndCaseGroup
  6F0:  EndSwitch
		Return
		End
}

