#new:Script $HolyBreaker
{
		Call  SetTargetActor    ( .Actor:Self .Actor:Player )
		Exec  $ShowMessage3
		Call  802535B4  ( 00000000 )
   14:  Call  UseBattleCamPreset    ( 0000000D )
   24:  Call  BattleCamTargetActor  ( .Actor:Self )
		Call  SetBattleCamZoom      (  370` )
   54:  Call  MoveBattleCamOver (  20` )
		Call  SetGoalToTarget   ( .Actor:Self )
		Call  SetAnimation      ( .Actor:Self 00000001 00870406 )  %Walking anim
		Call  GetActorVar       ( .Actor:Self 4` *VarA )
		If    *VarA == 0`	
			Call  SetActorSpeed     ( .Actor:Self *Fixed[9.0] )
		Else
			Call  SetActorSpeed     ( .Actor:Self *Fixed[15.0] )
		EndIf
		Call     RandInt     	( 1` *VarB )
		If   *VarB == 0`																%Rises, spins 3 times and then slams into Mario
			Call  AddGoalPos        ( .Actor:Self  80`  0`  0` )   
			Call  RunToGoal     ( .Actor:Self  0` .False )
			Call  SetAnimation      ( .Actor:Self 00000001 0087040B )  %Raise cross
			Call  PlaySound ( 000020E6 )
			Wait  2`
			Call  AddGoalPos        ( .Actor:Self  -20`  90`  0` )
			Call  GetActorVar       ( .Actor:Self 4` *VarA )
			If    *VarA == 0`	
				Call  SetActorSpeed ( .Actor:Self *Fixed[6.0] )
				Call  FlyToGoal     ( .Actor:Self  0`  12` .Easing:Linear )
			Else
				Call  SetActorSpeed ( .Actor:Self *Fixed[9.0] )
				Call  FlyToGoal     ( .Actor:Self  0`  6` .Easing:Linear )
			EndIf
			Wait  2`
			Call  UseBattleCamPreset    ( 00000002 )
			Call  PlaySoundAtActor  ( .Actor:Self 0000031B )
			Loop  16`
				Add   *Var0  16`
				Call  SetActorRotation  ( .Actor:Self 00000000 00000000 *Var0 )
				Wait  1`
			EndLoop
			Call  PlaySoundAtActor  ( .Actor:Self 0000031D )
			Loop  15`
				Add   *Var0  32`
				Call  SetActorRotation  ( .Actor:Self 00000000 00000000 *Var0 )
				Wait  1`
			EndLoop
			Call  PlaySoundAtActor  ( .Actor:Self 0000031F )
			Loop  13`
				Add   *Var0  32`
				Call  SetActorRotation  ( .Actor:Self 00000000 00000000 *Var0 )
				Wait  1`
			EndLoop
			Call  SetActorRotation  ( .Actor:Self 00000000 00000000 75` )
			Call  SetTargetActor    ( .Actor:Self .Actor:Player )
			Call  SetGoalToTarget       ( .Actor:Self )
			Call  GetActorVar       ( .Actor:Self 4` *VarA )
			If    *VarA == 0`	
				Call  SetActorSpeed     ( .Actor:Self *Fixed[22.0] )
			Else
				Call  SetActorSpeed     ( .Actor:Self *Fixed[25.0] )
			EndIf
			Call  AddGoalPos    ( .Actor:Self  10`  -30`  0` )	
		Else																		%Rises, spins 4 times and then slams the ground and makes a shockwave
			Call  AddGoalPos        ( .Actor:Self  115`  0`  0` )   
			Call  RunToGoal     ( .Actor:Self  0` .False )
			Call  PlaySound ( 000020E6 )
			Call  SetAnimation      ( .Actor:Self 00000001 0087040B )  %Raise cross
			Wait  2`
			Call  AddGoalPos        ( .Actor:Self  -10`  90`  0` )
			Call  GetActorVar       ( .Actor:Self 4` *VarA )
			If    *VarA == 0`	
				Call  SetActorSpeed ( .Actor:Self *Fixed[6.0] )
				Call  FlyToGoal     ( .Actor:Self  0`  12` .Easing:Linear )
			Else
				Call  SetActorSpeed ( .Actor:Self *Fixed[9.0] )
				Call  FlyToGoal     ( .Actor:Self  0`  6` .Easing:Linear )
			EndIf
			Wait  2`
			Call  UseBattleCamPreset    ( 00000002 )
			Call  PlaySoundAtActor  ( .Actor:Self 0000031B )
			Loop  16`
				Add   *Var0  16`
				Call  SetActorRotation  ( .Actor:Self 00000000 00000000 *Var0 )
				Wait  1`
			EndLoop
			Call  PlaySoundAtActor  ( .Actor:Self 0000031D )
