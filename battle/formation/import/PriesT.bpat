			Loop  16`
				Add   *Var0  32`
				Call  SetActorRotation  ( .Actor:Self 00000000 00000000 *Var0 )
				Wait  1`
			EndLoop
			Call  SetActorRotation  ( .Actor:Self 00000000 00000000 105` )
			Wait  2`
			Call  SetActorRotation  ( .Actor:Self 00000000 00000000 120` )
			Call  SetTargetActor    ( .Actor:Self .Actor:Player )
			Call  SetGoalToTarget       ( .Actor:Self )
			Call  GetActorVar       ( .Actor:Self 4` *VarA )
			If    *VarA == 0`	
				Call  SetActorSpeed     ( .Actor:Self *Fixed[19.0] )
			Else
				Call  SetActorSpeed     ( .Actor:Self *Fixed[22.0] )
			EndIf
		
			Call  AddGoalPos    ( .Actor:Self  114`  -8`  0` )	
		EndIf
		Call  FlyToGoal     ( .Actor:Self  0`  0` .Easing:Linear )
		Call  EnemyTestTarget   ( .Actor:Self *VarA ~Flags:DamageType:0 00000000 00000001 00000010 )
		Switch  *VarA 
			CaseOR  ==  .HitResult:Miss % 6
			CaseOR  ==  .HitResult:Lucky % 5
				Wait  3`
				If  *VarA  ==  .HitResult:Lucky % 5
					Call  EnemyTestTarget   ( .Actor:Self *Var0 ~Flags:DamageType:TriggerLucky 00000000 00000000 00000000 )
					Wait  20`
				Else
					Wait  20`				
				EndIf
				Goto  69
			EndCaseGroup
		EndSwitch
		Wait  2`
		Call  PlaySoundAtActor      ( .Actor:Self 00000026 )
