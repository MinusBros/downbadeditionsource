#new:Script $Script_Init_802238C8_27 {
   14:  Call  BindIdle  ( .Actor:Self $Script_Idle_Priest )
   28:  Call  BindHandleEvent   ( .Actor:Self $Script_HandleEvent_Priest )
		Call  SetActorVar       ( .Actor:Self 1` 0` )  %Move selector
		Call  SetActorVar       ( .Actor:Self 2` 0` )  %Intro dialogue
		Call  SetActorVar       ( .Actor:Self 3` 0` )  %Control boomerang rotation
		Call  SetActorVar       ( .Actor:Self 4` 0` )  %Is it time for second phase? 
		Exec  $CheckDeathPriest
		If    *GB_EnemyDefense == 3`  %Prologue version
			Call  $Function_SetName_C ( F4 002900C4 )
			Call  $Function_SetTattle_C ( F4 001C00DE )	
			Call  BindTakeTurn      ( .Actor:Self $Script_TakeTurn_PriestPrologue )
			Call  BindNextTurn  ( .Actor:Self $Script_NextTurn_PriestPrologue )
			Call  SetDefenseTable   ( .Actor:Self 00000001 $DefenseTable_PriestPrologue )
			Call  SetBattleFlagBits ( 00800000 .True )
		Else
			Call  BindTakeTurn      ( .Actor:Self $Script_TakeTurn_Priest )
			Call  BindNextTurn  ( .Actor:Self $Script_NextTurn_Priest )
			Call  SetDefenseTable   ( .Actor:Self 00000001 $DefenseTable_Priest )
			Exec  $MonitorPos
		EndIf
   3C:  Return
   44:  End
}

%If player dies (and doesn't have a Life Shroom) play the end of battle stinger
#new:Script $CheckDeathPriest
{		
		Label 1
		Call FindItem  ( .Item:LifeShroom *VarE ) 
		If *VarE == 00000000
			Set  *VarD  1`
		Else
			Set  *VarD  0`
		EndIf
		If    *VarD  == 0`
				Loop 60`
				Call  GetActorHP    ( .Actor:Player *VarC )
				If  *VarC  ==  00000000 
						Call  SetMusicTrack ( 00000000 .Song:IllusionaryDance 00000001 00000008 )  %Ending stinger
						Return
				EndIf
				Wait  1`
				EndLoop
		EndIf
		Wait  1`
		Goto  1
		Return
		End
}



#new:Script  $MonitorPos
{
	Loop
	Call  GetActorPos       ( .Actor:Player *Var7 *Var8 *Var9 )
		If  *Var7 > -85`
			BreakLoop
		EndIf
		Wait  1`
	Call  GetActorPos       ( .Actor:Partner *Var7 *Var8 *Var9 )
		If  *Var7 > -45`
			BreakLoop
		EndIf
	Wait 1`
	EndLoop
	Set  *PriesTTurn .True
	Exec  $ShowSong
	Call  SetMusicTrack ( 00000000 .Song:IllusionaryDance 00000000 00000008 )
	Return
	End
}

