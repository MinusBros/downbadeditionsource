			Set   *GB_EnemyDefense 2`
			Call  SetDefenseTable   ( .Actor:Self 00000001 $DefenseTable_8022DA38_Resting )
			Goto 00000001
		EndIf
	EndIf
	% When he isn't exhausted, he will hit like a freight train moving at warp 7 into a collapsing star
	Label 6
			Call  SetPartEventBits  ( .Actor:Self 00000001 00040000 .True )
	Call     GetActorVar 	( .Actor:Self 00000005 *Var[2] ) % what move to use?
	Switch *Var[2]
		Case == 0`
			Exec  $ShowMessage2
			ExecWait $Script_MeleeComboA
			Call     SetActorVar 	( .Actor:Self 00000005 00000001 )
		Case == 1`
			Exec  $ShowMessage3
			ExecWait $Script_TeleportCombo
			Call     SetActorVar 	( .Actor:Self 00000005 00000002 )
		Case == 2`
			Exec  $ShowMessage4
			ExecWait $Script_MeleeComboB
			Call     SetActorVar 	( .Actor:Self 00000005 00000003 )
		Case == 3`
			If  *Var[0]  >  200` % you can block the dash so it's not that bad
				Exec  $ShowMessage3
				ExecWait $Script_TeleportCombo
			Else
				Exec  $ShowMessage1
				ExecWait $Script_DashAttack
			EndIf
			Call     SetActorVar 	( .Actor:Self 00000005 00000004 )
		Case == 4` %New: added perish paralyzing combo from Master Quest
			
			ExecWait $Script_NowPerish
			Call     SetActorVar 	( .Actor:Self 00000005 00000005 )
		Case == 5`
			ExecWait $Kamehameha
			Call     SetActorVar 	( .Actor:Self 00000005 00000000 )
	EndSwitch
	%50-50 chance to change stance at the end of turn
	%If recovering from rest turn, always stance change
	Call     GetActorVar 	( .Actor:Self 00000007 *Var[2] )
	If    *Var2  == 1`
		Call     SetActorVar 	( .Actor:Self 00000007 0` )
		ExecWait  $StanceChange
		Goto  1
	EndIf
	Call  RandInt   ( 00000001 *Var0 )
	If  *Var0  == 1`
		ExecWait  $StanceChange
	EndIf
	Label 1
	Call     EnableIdleScript 	( .Actor:Self 00000001 )
	Call     UseIdleAnimation 	( .Actor:Self .True )
	Return
	End
}	

