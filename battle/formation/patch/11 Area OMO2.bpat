@	$Script_TakeTurn_80218BA0
{
    0:  Call  GetActorVar   ( .Actor:Self 00000000 *Var0 )
   18:  If  *Var0  ==  00000000
   28:  	Return
   30:  EndIf
 		Kill  $MonitorPos
		Wait  2`
		Call  802D5FA4  ( 00000007 )
   38:  Call  ActorExists   ( .Actor:Enemy2 *Var0 )
   4C:  If  *Var0  !=  .False
   5C:  	Call  GetStatusFlags    ( .Actor:Partner *Var0 )
   70:  	If  *Var0  !&  ~Flags:StatusFlags:KO % 1000000
   80:  		Call  RandInt   ( 00000064 *Var0 )
   94:  		If  *Var0  <  0000003C
					Exec  $ShowMessage1
   A4:  			ExecWait  $Script_LightningAttack
					Exec  $MonitorPos
   B0:  			Return
   B8:  		EndIf
   C0:  	EndIf
   C8:  EndIf
		Exec  $ShowMessage2
   D0:  ExecWait  $Script_BombAttack
		ExecWait  $Script_BombAttack
		Exec  $MonitorPos
   DC:  Return
   E4:  End
}


#new:Script  $MonitorPos
{

	Loop
	Call  GetActorPos       ( .Actor:Player *Var7 *Var8 *Var9 )
		If  *Var7 > -88`
			BreakLoop
		EndIf
		Wait  1`
	Call  GetActorPos       ( .Actor:Partner *Var7 *Var8 *Var9 )
		If  *Var7 > -45`
			BreakLoop
		EndIf
	Wait 1`
		Add  *Var6  1`
		Switch  *Var6
		Case  > 400`
			Call  802D5FA4  ( 00000004 )
		Case  > 120`
			Call  802D5FA4  ( 00000005 )
		EndSwitch
	EndLoop
	Call  802D5FA4  ( 00000007 )
	Return
	End
}



