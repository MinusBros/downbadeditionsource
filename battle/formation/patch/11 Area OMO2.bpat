@	$Script_HandleEvent_8022CE5C
{
    0:  Call  SetActorVar       ( .Actor:Self 00000009 00000001 )
   18:  Call  UseIdleAnimation  ( .Actor:Self .False )
   2C:  Call  GetLastEvent      ( .Actor:Self *Var0 )
   40:  Switch  *Var0
   4C:  	Case  ==  .Event:HitCombo % 9
   58:  		ExecWait  $Script_8022D238
				ExecWait  $ShyShogunReaction
   E0:  	CaseOR  ==  .Event:Hit % A
   EC:  	CaseOR  ==  .Event:BurnHit % E
   F8:  		ExecWait  $Script_8022D238
				ExecWait  $ShyShogunReaction
  180:  	EndCaseGroup
  188:  	Case  ==  .Event:SpinSmashHit % B
  194:  		ExecWait  $Script_8022D238
				ExecWait  $ShyShogunReaction
  21C:  	Case  ==  00000017 % 17
  228:  		Call  8026E914  ( *Var0 *Var1 )
				ExecWait $ShyShogunImmune
  274:  	Case  ==  .Event:Immune % 19
				ExecWait $ShyShogunImmune
  2B8:  	Case  ==  .Event:AirLiftFailed % 1F
  2C4:  		Call  PlayModelAnimation    ( 00000000 $ModelAnimation_8021E798 )
  2D8:  		Wait  30`
  2E4:  	CaseOR  ==  .Event:Death % 20
  2F0:  	CaseOR  ==  .Event:BurnDeath % 24
  2FC:  		ExecWait  $Script_8022D238
  308:  		ExecWait  $Script_8022ED80
  314:  		Return
  31C:  	EndCaseGroup
  324:  	Case  ==  .Event:SpinSmashDeath % 21
  330:  		ExecWait  $Script_8022D238
  33C:  		ExecWait  $Script_8022ED80
  348:  		Return
  350:  	Case  ==  .Event:SpikeContact % 2A
  35C:  	Case  ==  .Event:BurnContact % 2C
  368:  	Case  ==  .Event:ShockHit % 2F
  374:  	Case  ==  .Event:EndFirstStrike % 35
  380:  	Default
  388:  EndSwitch
  390:  Call  SetActorVar       ( .Actor:Self 00000009 00000000 )
  3A8:  Call  UseIdleAnimation  ( .Actor:Self .True )
  3BC:  Return
  3C4:  End
}

