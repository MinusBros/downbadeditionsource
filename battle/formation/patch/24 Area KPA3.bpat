   EC:  Set   *Var1  00000000
   FC:  Call  SetGoalPos        ( .Actor:Enemy0 *Var0 *Var1 *Var2 )
  118:  Call  RunToGoal ( .Actor:Enemy0  0` .False )
  130:  Call  EnemyTestTarget   ( .Actor:Enemy0 *Var0 ~Flags:DamageType:0 00000000 00000001 00000010 )
  154:  Switch  *Var0
  160:  	CaseOR  ==  .HitResult:Miss % 6
  16C:  	CaseOR  ==  .HitResult:Lucky % 5
  178:  		Set   *VarA  *Var0
  188:  		Call  SetActorSounds    ( .Actor:Enemy0 .ActorSound:Jump 000002EF 00000000 )
  1A4:  		Call  SetActorSounds    ( .Actor:Enemy0 .ActorSound:Walk 000020BA 000003B4 )
  1C0:  		Call  SetActorSounds    ( .Actor:Enemy0 .ActorSound:WalkIncrement 0000000A 00000000 )
  1DC:  		Call  SetActorSpeed ( .Actor:Enemy0 *Fixed[9.0] )
  1F0:  		Call  SetAnimation  ( .Actor:Enemy0 00000001 003B0504 )
  208:  		Call  SetGoalToTarget   ( .Actor:Enemy0 )
  218:  		Call  RunToGoal     ( .Actor:Enemy0  0` .False )
  230:  		Call  SetAnimation  ( .Actor:Enemy0 00000001 003B0505 )
  25C:  		Call  SetActorJumpGravity   ( .Actor:Enemy0 *Fixed[0.5] )
  270:  		Call  GetActorPos   ( .Actor:Enemy0 *Var0 *Var1 *Var2 )
  28C:  		Sub   *Var0  0000001E
  29C:  		Call  SetGoalPos    ( .Actor:Enemy0 *Var0 *Var1 *Var2 )
  2B8:  		Call  JumpToGoal    ( .Actor:Enemy0  8` .False .True .False )
  2D8:  		If  *VarA  ==  .HitResult:Lucky % 5
  2E8:  			Call  EnemyTestTarget   ( .Actor:Enemy0 *VarA ~Flags:DamageType:TriggerLucky 00000000 00000000 00000000 )
  30C:  		EndIf
  314:  		Call  ResetAllActorSounds   ( .Actor:Enemy0 )
  324:  		Sub   *Var0  00000014
  334:  		Call  SetGoalPos        ( .Actor:Enemy0 *Var0 *Var1 *Var2 )
  350:  		Call  JumpToGoal        ( .Actor:Enemy0  8` .False .True .False )
  370:  		Wait  5`
  37C:  		Call  UseBattleCamPreset    ( 00000002 )
  38C:  		Call  SetActorYaw       ( .Actor:Enemy0  180` )
  3A0:  		Call  AddActorDecoration    ( .Actor:Enemy0 00000001 00000000 .Decoration:Sweat )
  3BC:  		Call  SetActorSpeed     ( .Actor:Enemy0 *Fixed[10.0] )
  560:  Call  SetGoalPos        ( .Actor:Enemy0 20` 0` 0` )
  57C:  Call  RunToGoal ( .Actor:Enemy0  0` .False )	
  3FC:  		Call  RemoveActorDecoration ( .Actor:Enemy0 00000001 00000000 )
  414:  		Call  SetActorYaw       ( .Actor:Enemy0  0` )
  428:  		Call  SetAnimation      ( .Actor:Enemy0 00000001 003B0501 )
				ExecWait $TrollHeal
