  52C:  		SetConst  *VarA  000C0005
  53C:  		ExecWait  $Script_8023A164
  548:  	EndCaseGroup
  550:  EndSwitch
  558:  Call  EnableIdleScript  ( .Actor:Partner 00000001 )
  56C:  Call  UseIdleAnimation  ( .Actor:Partner .True )
  580:  Return
  588:  End
}

