					Add		*Var4 10
					Add		*Var5 12
					Call	PlayEffect ( 00000040 00000001 *Var4 *Var5 *Var6 *VarC 00000000 00000000 00000000 00000000 00000000 00000000 )						
	
				EndSwitch
