%Airlift
%Removes enemies with 100% chance if they are at least 25% suseptible
%However, Airlift can only be used (successfully) once per battle

#new:Function $DisableAirLift
{
PUSH	RA
ADDI	V0, R0, 1
SAB		V0, $AirLiftBool
POP		RA
JR		RA
ORI		V0, R0, 2
}


