#new:Script  $ApplyDebuffs
{
					Wait 1`
					Call  RandInt   ( 00000003 *Var9 )
					If  *Var9  >  00000000
						Call     $Function_CheckChillDefense ( ) %0 = immune to chill out
						If  *Var[0]  ==  00000001 
							Call     $Function_ChillTargetDefenseWeak ( )
							Call	 SetGoalToTarget ( .Actor:Self )
							Call	 GetGoalPos ( .Actor:Self *Var5 *Var6 *Var7 ) 
							Call	 $Function_DebuffEffect2 ( )		
							Wait  5`
						EndIf
					EndIf	
					Call  RandInt   ( 00000003 *Var9 )
					If  *Var9  >  00000000
						Call     $Function_CheckChillAttack ( ) %0 = immune to chill out
						If  *Var[0]  ==  00000001 
							Call     $Function_ChillTargetAttack ( )
							Call	 SetGoalToTarget ( .Actor:Self )
							Call	 GetGoalPos ( .Actor:Self *Var5 *Var6 *Var7 ) 
							Call  $Function_ChillWaveEffect    ( *Var5 *Var6 *Var7 )					
						EndIf 
					EndIf
					Return
					End
}





