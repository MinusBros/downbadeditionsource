#new:Function $IncrementOuttaSightCost
{
%Cost is +1 per use
PUSH	RA
LAW		V0, $OuttaSightAddress
LB		V1, 0 (V0)
ADDI	V1, V1, 1
SB		V1, 0 (V0)
POP		RA
JR		RA
ORI		V0, R0, 2
}

