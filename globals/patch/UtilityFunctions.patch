    NOP
    % Set bit1 as True
    BEQ     R0, R0, .SaveBit
    ADDIU   A2, A2, 2
    .Set_bit1_as_False
    % Check if bit1 is already False
    BEQ     T0, R0, .End % it is, bypass everything
    NOP
    % Set bit1 as False
    ORI     T1, R0, 2
    BEQ     R0, R0, .SaveBit
    SUBU    A2, A2, T1
    %===============
    .bit2
    %===============
    ORI     T1, R0, 2
    BNE     S3, T1, .bit3
    NOP
    % get current bit boolean value
    SLL    	T0, T0, 29` % bit2
