#new:Script $BattleTexPanner
{
    0:  Set   *VarA  *Var1
   10:  Call  SetTexPanner  ( *Var0 *Var1 )
   24:  Set   *Var0  00000000
   34:  Set   *Var1  00000000
   44:  Loop
   50:  	Call  SetTexPanOffset   ( *VarA 00000000 *Var0 00000000 )
   6C:  	Call  SetTexPanOffset   ( *VarA 00000001 *Var1 00000000 )
   88:  	Sub   *Var0  FFFFFED4
   98:  	Sub   *Var1  00000000
   A8:  	Wait  1`
   B4:  EndLoop
   A0:  Return
   A8:  End
}

#new:Script  $BeforeBattlePit
{
		Set   *Byte_Settings_BGM  1`
		Set   *Byte_Settings_BGM2 1`	%Normalize battle music
		Call     RandInt     	( 4` *Var9 )
		Switch  *Var9
			Case == 0`
				Call  PushSong      ( .Song:NormalBattle 0 ) %Superstar Saga battle theme
			Case == 1`
				Call  PushSong      ( .Song:ForeverForestWarning  0 ) %Superkids battle theme
			Case == 2`
				Call  PushSong      ( .Song:RidingTheWhale 0 )  %Battle for the Glory
			Case == 3`
				Call  PushSong      ( .Song:SafeHeaven 1 )	%Mega Man X5 boss theme
			Case == 4`
				Call  PushSong      ( .Song:PuffPuffMachine 0 ) %Jin Kazama
		EndSwitch	
   2C:  Set   *Var0  00000012
   3C:  Set   *Var1  00000000
   4C:  Exec  $BattleTexPanner
   2C:  Set   *Var0  00000013
   3C:  Set   *Var1  00000001
   4C:  Exec  $BattleTexPanner  
		Return
		End
}

#new:Script  $AfterBattlePit
{
	Call PopSong ( )
	Return
	End
}

