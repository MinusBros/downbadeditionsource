%Reduce defdown
@Hook 17111C %8024283C
{
	LB		V0, 226 (V1)
	ADDI	V0, V0, FFFF 	%there is no SUBI instruction :P
	SLT		A0, R0, V0
	BNE		A0, R0, .gt
	NOP
	ORI		V0, R0, 0		%Reset to 0
	SB		R0, 225 (V1) 	%defdown strength
	.gt
	SB		V0, 226 (V1) 	%defdown duration
	LB		V0, 224 (V1)
	J 		80242844
	LBU		A0, 224 (V1)
}


