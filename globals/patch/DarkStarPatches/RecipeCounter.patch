        .o5C
	LW        A1, 0 (S2)
	BEQ       A1, R0, .o84
	SLL       V0, S1, 10
	%Set flag
	%A0 = command data
	%A1 = var to set
	%A2 = new val
	COPY	  A0, S3
	LI		  A2, 0
	JAL       ~Func:set_variable
