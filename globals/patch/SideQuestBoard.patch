%This rudimentary file controls all of the sidequests in the game.
%The game will check for story progression and then display every sidequest in the game that's available.



#new:Script  $CheckForSidequests
{
	If  *GB_StoryProgress  ==  .Story:Epilogue
		Call  ShowMessageAtScreenPos    ( 00170019  160`  40` ) % Sidequests are not available in epilogue
		Return
	EndIf
	If  *GB_StoryProgress  >=  .Story:Ch1_StarSpritDeparted
		If  *GoompaCompleted == .False
			Add  *Var2 1`
			Call  ShowMessageAtScreenPos    ( 00170001  160`  40` ) % Goompa sidequest
		EndIf
	EndIf	
	
	If  *GB_StoryProgress  >=  .Story:Ch2_ShadyMouseLeftShop
		If  *BubUlbCompleted == .False
			Add  *Var2 1`
			Call  ShowMessageAtScreenPos    ( 00170000  160`  40` ) % Bub-Ulb sidequest
		EndIf
	EndIf
	
	If  *GB_StoryProgress  >=  .Story:Ch2_GotPulseStone
		If  *GF_HOS06_Gift_MerluvleesAutograph  == .False
			Add  *Var2 1`
			Call  ShowMessageAtScreenPos    ( 00170003  160`  40` ) % Donluvlee sidequest
		EndIf
	EndIf

	If  *GB_StoryProgress  >=  .Story:Ch2_BeganPeachMission
		If  *GF_MAC05_SimonGotMelody == .False
			Add  *Var2 1`
			Call  ShowMessageAtScreenPos    ( 00170002  160`  40` ) % Chanterelle sidequest (vanilla)
		EndIf
	EndIf
	

	
	If  *GB_StoryProgress  >= .Story:Ch5_StarSpritDeparted
		If *GF_ARN05_GaveGiftAdvice == .False
			Add  *Var2 1`
			Call  ShowMessageAtScreenPos    ( 00170005  160`  40` ) % Stanley sidequest (vanilla)
		EndIf
	EndIf
	
	If   *Var2 < 1`
		Call  ShowMessageAtScreenPos    ( 00170018  160`  40` ) % No sidequests :(
	EndIf
	Return
	End
}


#new:Script $ProblemSolved
{
	Call  PlaySound     ( 000000D4 )
	Thread
		Call  SetPlayerAnimation    ( 00010032 )
		Wait  32`
		Call  SetPlayerAnimation    ( 00010002 )
	EndThread
	Call  ShowMessageAtScreenPos    ( 001F00D0  160`  80` )
	Return
	End
}

#export  $ProblemSolved
#export  $CheckForSidequests