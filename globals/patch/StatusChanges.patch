	LB		A2, 211 (S1)
}
   	
 
 %8027DCBC + BC = 8027DD78
 %8027DD78 - 800D1720 = 1AC658
@Hook 1AC658
{
	SB		R0, 21C (S1)	 %these two lines were clobbered by hook - run them	
	SB		R0, 21C (S0)
