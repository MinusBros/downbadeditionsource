%%% PART TEN - PARALYSIS ON SHOCKHIT
%%% When Mario takes electricity damage, we want to AfflictActor him with paralysis.
% We hook a convenient script call in the middle, and replace it with our own script.

@Data 1B4380
{
	$AfflictParaWrapper
}

#new:Script:Battle $AfflictParaWrapper
{
	ExecWait  802988F0 %in original script
	Call  GetPlayerHP ( *Var[0] )
	If *Var[0] > 0
		Call  $IsBadgeEquippedScriptVer (35 *Var[0]) %35 = jr. emblem
		If *Var[0] == 0`
			Call  AfflictActor  ( .Actor:Player .Status:Paralyze 00000001 )
		EndIf
	EndIf
	Return
	End
}




