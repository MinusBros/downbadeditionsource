%%% PART ONE - SETTING THE STATUS TRACKER
%%% Actor Var [F] is repurposed for this. If you overwrite Actor Var [F], there may be unexpected results. Not many enemies do that, though. And most that do are immune.

%802653A4 + 400 = 802657A4
%802657A4 - 800D1720 = 194084
@Hook 194084 
{
	%for reference: Actor variables are in Actor+88, 8C, 90, 94, 98, ... C4
	%actor struct is in S1 as we go into this
	LBU		V0, 1E (S4) 	%read in power bounce variable
	SLTI	V0, V0, 4		%check for boss (PB == 3) 
	BEQ		V0, R0, .store 	%if not a boss, only delay slot is run
	ADDIU	V0, R0, 202 	%delay slot - run in all circumstances. normal value
	ADDIU	V0, R0, 101 	%jumped over if not a boss. boss stat tracker value
	.store
	SW		V0, C4 (S1) 	%store value in ActorVar[F] - actor init script WILL overwrite this if it uses ActorVar[F]. That's fine.
	LW		V0, C (S3)	 	%these two instructions were overwritten by our hook. we run them before returning.
 	J 		802657AC				%802653A4 + 400 + 8 => return to where we left off
 	SW		V0, 88 (S1)		%second overwritten instruction - we can put it in the delay slot. Sets actor var 1, loaded by first instruction.
}
 
 
 %%% PART TWO - OVERRIDING STATUS CHANCE MECHANICS
 %%% All we really have to do here is set the chance to 100% if it's nonzero, and 0% otherwise.
 
 %placing MANUAL hooks at 80265E98+34, 48 = 80265ECC / 80265EE0
 
 %80265ECC - 800D1720 = 1947AC
 %80265EE0 - 800D1720 = 1947C0
 
 
@Function 1947AC
{
	J 		$Function_FixStatusChance
 	COPY 	V0, A2 %this line was in the original source, but it was clobbered by the 'hook'
}

 @Function 1947C0
{
	J 		$Function_FixStatusChance
 	COPY 	V0, A2
}
 
 #new:Function $Function_FixStatusChance
{
	%when we arrive, V0 will have the set status chance
 	BNEL 	V0, R0, .done
 	ADDIU	V0, R0, 64		%set it to 100% if it's nonzero at all
 	.done 
 	JR RA					%we now return you to before GetStatusChance was called
 	NOP
}
 
 

 
 %%% PART THREE - ACTUALLY CHECK THE BYTE (AND DECREMENT IT)
 %%% Both of these sections hook into the actual status infliction function. This part needs to:
 %%% Check for a status that's not on the list - LET IT THROUGH
 %%% Check for actor = Mario/Partner - LET IT THROUGH
 %%% Check for target's AV[F] - BLOCK IT
 %%% In this order.
 
 % so we need to talk a bit about how ActuallyInflictStatus WORKS. The status ID is read, and used as an index to this jump table:
% $JumpTable_8029D5E0
% $Function_80265F40[2F8] $Function_80265F40[2F8] $Function_80265F40[2F8] $Function_80265F40[40] 
% $Function_80265F40[40] $Function_80265F40[40] $Function_80265F40[40] $Function_80265F40[40] 
% $Function_80265F40[40] $Function_80265F40[40] $Function_80265F40[40] $Function_80265F40[1F8] 
% $Function_80265F40[24C] $Function_80265F40[280] $Function_80265F40[2B8] 

%decoded, that's: 
%0-2 = 2F8: return 1 (failure, I think)
%3-A = 40: all go through the same script, which runs through to another jump table:
%3-A are mystery, Dizzy, Paralysis, Sleep, Freeze, Stop, Poison, Shrink, in that order.

% $JumpTable_8029D620
% $Function_80265F40[1A4] $Function_80265F40[190] $Function_80265F40[170] $Function_80265F40[150] 
% $Function_80265F40[EC] $Function_80265F40[2F8] $Function_80265F40[1C4] $Function_80265F40[1E4] 

% We can ignore this second jump table, because it only routes to functions that handle animations.
 
% back at the first jump table, the remaining statuses go here: - but that isn't really important for what we want to do. 
% B (Static) = 1F8 
% C (Stone) = 24C
% D (Partner KO) = 280
% E (Invis) = 2B8
 
% So we already have a jump table that jumps to areas of this routine. The simplest way is to override the calls to $Function_80265F40[40] with our own jump target.
% Once it's there, we go through a series of checks:
% We don't actually need to check status ID because we're limited to the ones listed above - 3-A. We can customize the jump table further to JUST hook the ones we really wanna look at, anyway.
% Check actor ID. If < 200, jump to $Function_80265F40[40], which runs normally.
% Check ActorVar[F]. If 0, jump to $Function_80265F40[2F8], which bails out.
% If we got this far, subtract 101 from ActorVar[F] and store it again.
% And then jump to $Function_80265F40[40], which runs normally.

@Data 001CBED0  %the table starts at 001CBEC0 (8029D5E0), but we don't care about the first four words - only the next seven.
{
	$Function_StatusCheck
	$Function_StatusCheck
	$Function_StatusCheck
	$Function_StatusCheck
	$Function_StatusCheck
	$Function_StatusCheck
	$Function_StatusCheck
}
 
  #new:Function $Function_StatusCheck
{
	LH		V0, 192 (S0)	%S0 = actor struct - +192 is actor ID
	SLTI  	V0, V0, 0200	%if this is not aimed at an enemy, we're good to go!
	BNE		V0, R0, .statusOK
	LW		V0, C4 (S0)		%now S0 has ActorVar[F]
	BEQ		V0, R0, .statusNOPE
 	%if we're doing separate status checks, we might want to AND chunks of S0, or LBs from it depending on circumstances.
 	%right now we just subtract 101.
 	ADDIU	V0, V0, FEFF    % AVF -= 101
 	SW		V0, C4 (S0)		%store ActorVar[F] back
 	%now we fall through
 	.statusOK
 	J		80265F80 		%80265F40[40]	%80265F40 + 40 = 80265F80
 	NOP
 	.statusNOPE
 	J		8026623C 		%80265F40[2FC]	%80265F40 + 2FC = 8026623C
 	CLEAR	V0				%indicate status failure
}
 
