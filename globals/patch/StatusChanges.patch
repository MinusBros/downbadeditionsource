	ADDIU	V1, R0, 6 %sleep
	BNE		V0, V1, .done
		LHU		V0, 1FC (S3)	%in original code
	SH		R0, 210 (S3)	%now clear debuff status and counter
	SH		R0, 216 (S3)	%clears 210-11 (debuff) and 216-17 (marker/partner stun)
	%clearing actor marker... I think
	LW		V1, 440 (S3)
	LW		V1, C (V1)
	SW		R0, 3C (V1)	
	%call to clear status anim uses V0, V1, A0, RA (but V1 is overwritten just below)
	PUSH      V0, A0, RA
	JAL       80047898
	LH        A0, 436 (S3)
	POP		  V0, A0, RA
	.done
	J 		80251A4C  %802516E8+364
		LHU		V1, 1FA (S3)	%in original code
}


